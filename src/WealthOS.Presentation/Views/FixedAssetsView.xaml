<UserControl x:Class="WealthOS.Presentation.Views.FixedAssetsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:WealthOS.Presentation.Converters"
             xmlns:views="clr-namespace:WealthOS.Presentation.Views">

    <UserControl.Resources>
        <conv:CurrencyConverter x:Key="CurrencyConv"/>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>

    <Grid>
        <Border Background="{StaticResource PrimaryBrush}" 
                Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}"
                Panel.ZIndex="50" HorizontalAlignment="Stretch" VerticalAlignment="Top" Height="3"/>

        <views:ErrorBanner DataContext="{Binding}"/>

        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="28,24">
            <StackPanel MaxWidth="1200">
                <!-- 页面标题 -->
                <Grid Margin="0,0,0,24">
                    <StackPanel>
                        <TextBlock Style="{StaticResource PageTitleStyle}">
                            <TextBlock.Text><Binding Source="{StaticResource FixedAssets.Title}"/></TextBlock.Text>
                        </TextBlock>
                        <TextBlock FontSize="13" Foreground="{StaticResource TextTertiaryBrush}" Margin="0,4,0,0">
                            <Run Text="&#x1F3E2; "/>
                            <Run Text="{DynamicResource FixedAssets.Subtitle}"/>
                        </TextBlock>
                    </StackPanel>
                </Grid>

                <!-- KPI 统计卡片 -->
                <Grid Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- 购入价值 -->
                    <Border Grid.Column="0" CornerRadius="14" Padding="20,16"
                            BorderThickness="1" BorderBrush="{StaticResource BorderBrush}"
                            Background="{StaticResource CardBackgroundBrush}">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                <Border Width="36" Height="36" CornerRadius="{StaticResource IconCornerRadius}" Margin="0,0,12,0">
                                    <Border.Background>
                                        <SolidColorBrush Color="{StaticResource IconBgBlueColor}"/>
                                    </Border.Background>
                                    <TextBlock Text="&#x1F4B0;" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="{DynamicResource FixedAssets.InitialValue}" FontSize="12" 
                                           Foreground="{StaticResource TextTertiaryBrush}" VerticalAlignment="Center"/>
                            </StackPanel>
                            <TextBlock FontSize="22" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}">
                                <TextBlock.Text><Binding Path="TotalInitialValue" Converter="{StaticResource CurrencyConv}"/></TextBlock.Text>
                            </TextBlock>
                        </StackPanel>
                    </Border>

                    <!-- 当前价值 -->
                    <Border Grid.Column="2" CornerRadius="14" Padding="20,16"
                            BorderThickness="1" BorderBrush="{StaticResource BorderBrush}"
                            Background="{StaticResource CardBackgroundBrush}">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                <Border Width="36" Height="36" CornerRadius="{StaticResource IconCornerRadius}" Margin="0,0,12,0">
                                    <Border.Background>
                                        <SolidColorBrush Color="{StaticResource IconBgGreenColor}"/>
                                    </Border.Background>
                                    <TextBlock Text="&#x1F4CA;" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="{DynamicResource FixedAssets.CurrentValue}" FontSize="12" 
                                           Foreground="{StaticResource TextTertiaryBrush}" VerticalAlignment="Center"/>
                            </StackPanel>
                            <TextBlock FontSize="22" FontWeight="Bold" Foreground="{StaticResource AccentBrush}">
                                <TextBlock.Text><Binding Path="TotalCurrentValue" Converter="{StaticResource CurrencyConv}"/></TextBlock.Text>
                            </TextBlock>
                        </StackPanel>
                    </Border>

                    <!-- 累计折旧 -->
                    <Border Grid.Column="4" CornerRadius="14" Padding="20,16"
                            BorderThickness="1" BorderBrush="{StaticResource BorderBrush}"
                            Background="{StaticResource CardBackgroundBrush}">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                <Border Width="36" Height="36" CornerRadius="{StaticResource IconCornerRadius}" Margin="0,0,12,0">
                                    <Border.Background>
                                        <SolidColorBrush Color="{StaticResource IconBgRedColor}"/>
                                    </Border.Background>
                                    <TextBlock Text="&#x1F4C9;" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="{DynamicResource FixedAssets.Depreciation}" FontSize="12" 
                                           Foreground="{StaticResource TextTertiaryBrush}" VerticalAlignment="Center"/>
                            </StackPanel>
                            <TextBlock FontSize="22" FontWeight="Bold" Foreground="{StaticResource ExpenseBrush}">
                                <TextBlock.Text><Binding Path="TotalDepreciation" Converter="{StaticResource CurrencyConv}"/></TextBlock.Text>
                            </TextBlock>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- 空状态 -->
                <Border Padding="60">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding FixedAssets.Count}" Value="0"><Setter Property="Visibility" Value="Visible"/></DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Style="{StaticResource EmptyStateIconStyle}" Text="&#x1F3E2;"/>
                        <TextBlock Style="{StaticResource EmptyStateTitleStyle}">
                            <TextBlock.Text><Binding Source="{StaticResource FixedAssets.NoAssets}"/></TextBlock.Text>
                        </TextBlock>
                        <TextBlock Style="{StaticResource EmptyStateHintStyle}">
                            <TextBlock.Text><Binding Source="{StaticResource FixedAssets.NoAssetsHint}"/></TextBlock.Text>
                        </TextBlock>
                    </StackPanel>
                </Border>

                <!-- 资产卡片列表 -->
                <ItemsControl ItemsSource="{Binding FixedAssets}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border CornerRadius="14" Padding="20" Margin="0,0,16,16" Width="300"
                                    BorderThickness="1" BorderBrush="{StaticResource BorderBrush}"
                                    Background="{StaticResource CardBackgroundBrush}">
                                <StackPanel>
                                    <!-- 标题行 -->
                                    <Grid Margin="0,0,0,16">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" Orientation="Horizontal">
                                            <Border Width="36" Height="36" CornerRadius="{StaticResource IconCornerRadius}" Margin="0,0,10,0">
                                                <Border.Background>
                                                    <SolidColorBrush Color="{StaticResource IconBgYellowColor}"/>
                                                </Border.Background>
                                                <TextBlock Text="&#x1F3E2;" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <TextBlock Text="{Binding Name}" FontSize="15" FontWeight="SemiBold" 
                                                       Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Grid>

                                    <!-- 价值对比 -->
                                    <Grid Margin="0,0,0,12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock FontSize="11" Foreground="{StaticResource TextTertiaryBrush}">
                                                <TextBlock.Text><Binding Source="{StaticResource FixedAssets.PurchasePrice}"/></TextBlock.Text>
                                            </TextBlock>
                                            <TextBlock FontSize="16" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}">
                                                <TextBlock.Text><Binding Path="InitialValue" Converter="{StaticResource CurrencyConv}"/></TextBlock.Text>
                                            </TextBlock>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                                            <TextBlock FontSize="11" Foreground="{StaticResource TextTertiaryBrush}">
                                                <TextBlock.Text><Binding Source="{StaticResource FixedAssets.Estimated}"/></TextBlock.Text>
                                            </TextBlock>
                                            <TextBlock FontSize="16" FontWeight="Bold" Foreground="{StaticResource AccentBrush}">
                                                <TextBlock.Text><Binding Path="DepreciatedValue" Converter="{StaticResource CurrencyConv}"/></TextBlock.Text>
                                            </TextBlock>
                                        </StackPanel>
                                    </Grid>

                                    <!-- 折旧信息 -->
                                    <Border CornerRadius="8" Padding="12" Background="{StaticResource SurfaceBrush}">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock FontSize="12" Foreground="{StaticResource TextTertiaryBrush}" Margin="0,0,16,0">
                                                <Run><Run.Text><Binding Source="{StaticResource FixedAssets.Rate}" Mode="OneWay"/></Run.Text></Run>
                                                <Run Text="{Binding DepreciationRate, StringFormat='{}{0}%'}"/>
                                            </TextBlock>
                                            <TextBlock FontSize="12" Foreground="{StaticResource TextTertiaryBrush}">
                                                <Run><Run.Text><Binding Source="{StaticResource FixedAssets.Age}" Mode="OneWay"/></Run.Text></Run>
                                                <Run><Run.Text><MultiBinding StringFormat="{}{0} {1}"><Binding Path="AgeMonths"/><Binding Source="{StaticResource Unit.Month}" Mode="OneWay"/></MultiBinding></Run.Text></Run>
                                            </TextBlock>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <Border Height="20"/>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
