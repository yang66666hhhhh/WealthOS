<UserControl x:Class="WealthOS.Presentation.Views.FixedAssetsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:WealthOS.Presentation.Converters">

    <UserControl.Resources>
        <conv:CurrencyConverter x:Key="CurrencyConv"/>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>

    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="32,24">
            <StackPanel MaxWidth="1200">
                <TextBlock Style="{StaticResource PageTitleStyle}">
                    <TextBlock.Text><Binding Source="{DynamicResource FixedAssets.Title}"/></TextBlock.Text>
                </TextBlock>

                <ProgressBar IsIndeterminate="True" Height="3" Margin="0,0,0,16"
                             Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}"
                             Background="Transparent" Foreground="{StaticResource PrimaryBrush}"/>

                <!-- Summary -->
                <Grid Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock FontSize="13" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,8">
                                <TextBlock.Text><Binding Source="{DynamicResource FixedAssets.InitialValue}"/></TextBlock.Text>
                            </TextBlock>
                            <TextBlock FontSize="28" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}">
                                <TextBlock.Text><Binding Path="TotalInitialValue" Converter="{StaticResource CurrencyConv}"/></TextBlock.Text>
                            </TextBlock>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="2" Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock FontSize="13" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,8">
                                <TextBlock.Text><Binding Source="{DynamicResource FixedAssets.CurrentValue}"/></TextBlock.Text>
                            </TextBlock>
                            <TextBlock FontSize="28" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}">
                                <TextBlock.Text><Binding Path="TotalCurrentValue" Converter="{StaticResource CurrencyConv}"/></TextBlock.Text>
                            </TextBlock>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="4" Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock FontSize="13" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,8">
                                <TextBlock.Text><Binding Source="{DynamicResource FixedAssets.Depreciation}"/></TextBlock.Text>
                            </TextBlock>
                            <TextBlock FontSize="28" FontWeight="Bold" Foreground="{StaticResource ExpenseBrush}">
                                <TextBlock.Text><Binding Path="TotalDepreciation" Converter="{StaticResource CurrencyConv}"/></TextBlock.Text>
                            </TextBlock>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- Empty State -->
                <Border Padding="60" Visibility="{Binding FixedAssets.Count, Converter={StaticResource BoolToVis}}">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding FixedAssets.Count}" Value="0"><Setter Property="Visibility" Value="Visible"/></DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock FontSize="20" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Center">
                            <TextBlock.Text><Binding Source="{DynamicResource FixedAssets.NoAssets}"/></TextBlock.Text>
                        </TextBlock>
                        <TextBlock FontSize="14" Foreground="{StaticResource TextHintBrush}" HorizontalAlignment="Center" Margin="0,12,0,0">
                            <TextBlock.Text><Binding Source="{DynamicResource FixedAssets.NoAssetsHint}"/></TextBlock.Text>
                        </TextBlock>
                    </StackPanel>
                </Border>

                <!-- Asset Cards -->
                <ItemsControl ItemsSource="{Binding FixedAssets}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Style="{StaticResource CardStyle}" Margin="0,0,16,16" Width="300">
                                <StackPanel>
                                    <TextBlock Text="{Binding Name}" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,12"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock FontSize="11" Foreground="{StaticResource TextSecondaryBrush}">
                                                <TextBlock.Text><Binding Source="{DynamicResource FixedAssets.PurchasePrice}"/></TextBlock.Text>
                                            </TextBlock>
                                            <TextBlock FontSize="16" FontWeight="Bold">
                                                <TextBlock.Text><Binding Path="InitialValue" Converter="{StaticResource CurrencyConv}"/></TextBlock.Text>
                                            </TextBlock>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                                            <TextBlock FontSize="11" Foreground="{StaticResource TextSecondaryBrush}">
                                                <TextBlock.Text><Binding Source="{DynamicResource FixedAssets.Estimated}"/></TextBlock.Text>
                                            </TextBlock>
                                            <TextBlock FontSize="16" FontWeight="Bold" Foreground="{StaticResource AccentBrush}">
                                                <TextBlock.Text><Binding Path="DepreciatedValue" Converter="{StaticResource CurrencyConv}"/></TextBlock.Text>
                                            </TextBlock>
                                        </StackPanel>
                                    </Grid>
                                    <Border Background="{StaticResource SurfaceBrush}" CornerRadius="6" Padding="8,6" Margin="0,12,0,0">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,12,0">
                                                <Run><Run.Text><Binding Source="{DynamicResource FixedAssets.Rate}"/></Run.Text></Run>
                                                <Run Text="{Binding DepreciationRate, StringFormat='{}{0}%'}"/>
                                            </TextBlock>
                                            <TextBlock FontSize="12" Foreground="{StaticResource TextSecondaryBrush}">
                                                <Run><Run.Text><Binding Source="{DynamicResource FixedAssets.Age}"/></Run.Text></Run>
                                                <Run Text="{Binding AgeMonths, StringFormat='{}{0} 个月'}"/>
                                            </TextBlock>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
