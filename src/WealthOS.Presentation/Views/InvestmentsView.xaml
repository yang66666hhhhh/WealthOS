<UserControl x:Class="WealthOS.Presentation.Views.InvestmentsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:WealthOS.Presentation.Converters"
             xmlns:enums="clr-namespace:WealthOS.Domain.Enums;assembly=WealthOS.Domain"
             xmlns:views="clr-namespace:WealthOS.Presentation.Views">

    <UserControl.Resources>
        <conv:CurrencyConverter x:Key="CurrencyConv"/>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <ObjectDataProvider x:Key="InvestmentTypes" MethodName="GetValues" ObjectType="{x:Type enums:AssetType}">
            <ObjectDataProvider.MethodParameters><x:Type TypeName="enums:AssetType"/></ObjectDataProvider.MethodParameters>
        </ObjectDataProvider>
    </UserControl.Resources>

    <Grid>
        <Border Background="{StaticResource PrimaryBrush}" 
                Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}"
                Panel.ZIndex="50" HorizontalAlignment="Stretch" VerticalAlignment="Top" Height="3"/>

        <views:ErrorBanner DataContext="{Binding}"/>

        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="28,24">
            <StackPanel MaxWidth="1200">
                <!-- 页面标题 -->
                <Grid Margin="0,0,0,24">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Style="{StaticResource PageTitleStyle}">
                            <TextBlock.Text><Binding Source="{StaticResource Investments.Title}"/></TextBlock.Text>
                        </TextBlock>
                        <TextBlock FontSize="13" Foreground="{StaticResource TextTertiaryBrush}" Margin="0,4,0,0">
                            <Run Text="&#x1F4C8; "/>
                            <Run Text="{DynamicResource Investments.Subtitle}"/>
                        </TextBlock>
                    </StackPanel>
                    <Button Grid.Column="1" Style="{StaticResource PrimaryButton}" Command="{Binding ShowAddDialogCommand}" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#x2795;" FontSize="14" Margin="0,0,8,0"/>
                            <TextBlock Text="{DynamicResource Investments.Add}"/>
                        </StackPanel>
                    </Button>
                </Grid>

                <!-- KPI 统计卡片 -->
                <Grid Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- 总市值 -->
                    <Border Grid.Column="0" CornerRadius="14" Padding="20,16"
                            BorderThickness="1" BorderBrush="{StaticResource BorderBrush}"
                            Background="{StaticResource CardBackgroundBrush}">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                <Border Width="36" Height="36" CornerRadius="{StaticResource IconCornerRadius}" Margin="0,0,12,0">
                                    <Border.Background>
                                        <SolidColorBrush Color="{StaticResource IconBgPurpleColor}"/>
                                    </Border.Background>
                                    <TextBlock Text="&#x1F4CA;" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="{DynamicResource Investments.TotalValue}" FontSize="12" 
                                           Foreground="{StaticResource TextTertiaryBrush}" VerticalAlignment="Center"/>
                            </StackPanel>
                            <TextBlock FontSize="22" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}">
                                <TextBlock.Text><Binding Path="TotalValue" Converter="{StaticResource CurrencyConv}"/></TextBlock.Text>
                            </TextBlock>
                        </StackPanel>
                    </Border>

                    <!-- 总成本 -->
                    <Border Grid.Column="2" CornerRadius="14" Padding="20,16"
                            BorderThickness="1" BorderBrush="{StaticResource BorderBrush}"
                            Background="{StaticResource CardBackgroundBrush}">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                <Border Width="36" Height="36" CornerRadius="{StaticResource IconCornerRadius}" Margin="0,0,12,0">
                                    <Border.Background>
                                        <SolidColorBrush Color="{StaticResource IconBgRedColor}"/>
                                    </Border.Background>
                                    <TextBlock Text="&#x1F4B0;" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="{DynamicResource Investments.TotalCost}" FontSize="12" 
                                           Foreground="{StaticResource TextTertiaryBrush}" VerticalAlignment="Center"/>
                            </StackPanel>
                            <TextBlock FontSize="22" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}">
                                <TextBlock.Text><Binding Path="TotalCost" Converter="{StaticResource CurrencyConv}"/></TextBlock.Text>
                            </TextBlock>
                        </StackPanel>
                    </Border>

                    <!-- 盈亏 -->
                    <Border Grid.Column="4" CornerRadius="14" Padding="20,16"
                            BorderThickness="1" BorderBrush="{StaticResource BorderBrush}"
                            Background="{StaticResource CardBackgroundBrush}">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                <Border Width="36" Height="36" CornerRadius="{StaticResource IconCornerRadius}" Margin="0,0,12,0">
                                    <Border.Background>
                                        <SolidColorBrush Color="{StaticResource IconBgGreenColor}"/>
                                    </Border.Background>
                                    <TextBlock Text="&#x1F4C8;" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="{DynamicResource Investments.ProfitLoss}" FontSize="12" 
                                           Foreground="{StaticResource TextTertiaryBrush}" VerticalAlignment="Center"/>
                            </StackPanel>
                            <TextBlock FontSize="22" FontWeight="Bold">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding TotalProfitLoss}" Value="0">
                                                <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                                <TextBlock.Text>
                                    <MultiBinding StringFormat="{}{0} ({1:F2}%)">
                                        <Binding Path="TotalProfitLoss" Converter="{StaticResource CurrencyConv}"/>
                                        <Binding Path="TotalProfitLossPercentage"/>
                                    </MultiBinding>
                                </TextBlock.Text>
                            </TextBlock>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- 空状态 -->
                <Border Padding="60">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Holdings.Count}" Value="0"><Setter Property="Visibility" Value="Visible"/></DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Style="{StaticResource EmptyStateIconStyle}" Text="&#x1F4C8;"/>
                        <TextBlock Style="{StaticResource EmptyStateTitleStyle}">
                            <TextBlock.Text><Binding Source="{StaticResource Investments.NoHoldings}"/></TextBlock.Text>
                        </TextBlock>
                        <TextBlock Style="{StaticResource EmptyStateHintStyle}">
                            <TextBlock.Text><Binding Source="{StaticResource Investments.NoHoldingsHint}"/></TextBlock.Text>
                        </TextBlock>
                    </StackPanel>
                </Border>

                <!-- 持仓列表 -->
                <Border CornerRadius="14" Padding="0" Margin="0,0,0,20"
                        BorderThickness="1" BorderBrush="{StaticResource BorderBrush}"
                        Background="{StaticResource CardBackgroundBrush}">
                    <StackPanel>
                        <Grid Margin="20,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{DynamicResource Investments.Symbol}" FontSize="12" 
                                       FontWeight="SemiBold" Foreground="{StaticResource TextTertiaryBrush}"/>
                            <TextBlock Grid.Column="1" Text="{DynamicResource Investments.CurrentPrice}" FontSize="12" 
                                       FontWeight="SemiBold" Foreground="{StaticResource TextTertiaryBrush}" 
                                       HorizontalAlignment="Right" Margin="16,0"/>
                            <TextBlock Grid.Column="2" Text="{DynamicResource Investments.TotalValue}" FontSize="12" 
                                       FontWeight="SemiBold" Foreground="{StaticResource TextTertiaryBrush}" 
                                       HorizontalAlignment="Right" Margin="16,0"/>
                            <TextBlock Grid.Column="3" Text="{DynamicResource Investments.PL}" FontSize="12" 
                                       FontWeight="SemiBold" Foreground="{StaticResource TextTertiaryBrush}" 
                                       HorizontalAlignment="Right" Margin="16,0"/>
                            <TextBlock Grid.Column="4" Width="60"/>
                        </Grid>

                        <ItemsControl ItemsSource="{Binding Holdings}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="16,12" BorderThickness="0,0,0,1" BorderBrush="{StaticResource BorderLightBrush}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <StackPanel Grid.Column="0">
                                                <StackPanel Orientation="Horizontal">
                                                    <Border CornerRadius="6" Padding="8,4" Margin="0,0,8,0">
                                                        <Border.Background>
                                                            <SolidColorBrush Color="{StaticResource IconBgPurpleColor}"/>
                                                        </Border.Background>
                                                        <TextBlock Text="{Binding Symbol}" FontSize="13" FontWeight="Bold" 
                                                                   Foreground="{StaticResource PrimaryBrush}"/>
                                                    </Border>
                                                    <TextBlock Text="{Binding Name}" FontSize="13" 
                                                               Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                                                </StackPanel>
                                                <TextBlock FontSize="11" Foreground="{StaticResource TextTertiaryBrush}" Margin="0,4,0,0">
                                                    <Run Text="{Binding Quantity}"/>
                                                    <Run Text=" × "/>
                                                    <Run Text="{Binding AverageCost, StringFormat='￥{0:N2}'}"/>
                                                </TextBlock>
                                            </StackPanel>

                                            <TextBlock Grid.Column="1" FontSize="13" FontWeight="SemiBold" 
                                                       VerticalAlignment="Center" HorizontalAlignment="Right" Margin="16,0">
                                                <TextBlock.Text><Binding Path="CurrentPrice" StringFormat="￥{0:N2}"/></TextBlock.Text>
                                            </TextBlock>

                                            <TextBlock Grid.Column="2" FontSize="13" FontWeight="SemiBold"
                                                       VerticalAlignment="Center" HorizontalAlignment="Right" Margin="16,0">
                                                <TextBlock.Text><Binding Path="TotalValue" Converter="{StaticResource CurrencyConv}"/></TextBlock.Text>
                                            </TextBlock>

                                            <StackPanel Grid.Column="3" HorizontalAlignment="Right" Margin="16,0" VerticalAlignment="Center">
                                                <Border CornerRadius="6" Padding="8,4">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Setter Property="Background">
                                                                <Setter.Value>
                                                                    <SolidColorBrush Color="{StaticResource IconBgGreenColor}"/>
                                                                </Setter.Value>
                                                            </Setter>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding ProfitLoss}" Value="0">
                                                                    <Setter Property="Background">
                                                                        <Setter.Value>
                                                                            <SolidColorBrush Color="{StaticResource SurfaceColor}"/>
                                                                        </Setter.Value>
                                                                    </Setter>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <TextBlock FontSize="12" FontWeight="SemiBold">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding ProfitLoss}" Value="0">
                                                                        <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                        <TextBlock.Text>
                                                            <MultiBinding StringFormat="{}{0} ({1:F1}%)">
                                                                <Binding Path="ProfitLoss" Converter="{StaticResource CurrencyConv}"/>
                                                                <Binding Path="ProfitLossPercentage"/>
                                                            </MultiBinding>
                                                        </TextBlock.Text>
                                                    </TextBlock>
                                                </Border>
                                            </StackPanel>

                                            <StackPanel Grid.Column="4" Orientation="Horizontal" VerticalAlignment="Center">
                                                <Button Content="&#x270E;" FontSize="14" Background="Transparent" BorderThickness="0"
                                                        Foreground="{StaticResource TextTertiaryBrush}" Cursor="Hand" Padding="6,2"
                                                        ToolTip="{DynamicResource Tooltip.Edit}"
                                                        Command="{Binding DataContext.ShowEditDialogCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                        CommandParameter="{Binding Id}"/>
                                                <Button Content="&#x2716;" FontSize="12" Background="Transparent" BorderThickness="0"
                                                        Foreground="{StaticResource TextHintBrush}" Cursor="Hand" Padding="6,2"
                                                        ToolTip="{DynamicResource Tooltip.Delete}"
                                                        Command="{Binding DataContext.ConfirmDeleteCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                        CommandParameter="{Binding Id}"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <!-- Add Dialog -->
                <Border Background="{StaticResource DialogOverlayBrush}" Visibility="{Binding IsAddDialogOpen, Converter={StaticResource BoolToVis}}" Panel.ZIndex="100">
                    <Border.InputBindings>
                        <KeyBinding Key="Escape" Command="{Binding CancelAddCommand}"/>
                        <KeyBinding Key="Enter" Command="{Binding ConfirmAddCommand}"/>
                    </Border.InputBindings>
                    <Border Background="{StaticResource DialogBackgroundBrush}" CornerRadius="{StaticResource CardCornerRadius}" Padding="28" Width="460" VerticalAlignment="Center" HorizontalAlignment="Center">
                        <StackPanel>
                            <TextBlock Style="{StaticResource DialogTitleStyle}">
                                <TextBlock.Text><Binding Source="{StaticResource Investments.AddTitle}"/></TextBlock.Text>
                            </TextBlock>
                            <Grid Margin="0,0,0,16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="12"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Style="{StaticResource LabelStyle}">
                                        <TextBlock.Text><Binding Source="{StaticResource Investments.Symbol}"/></TextBlock.Text>
                                    </TextBlock>
                                    <TextBox Text="{Binding NewSymbol, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource InputStyle}"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Style="{StaticResource LabelStyle}">
                                        <TextBlock.Text><Binding Source="{StaticResource Investments.Name}"/></TextBlock.Text>
                                    </TextBlock>
                                    <TextBox Text="{Binding NewName, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource InputStyle}"/>
                                </StackPanel>
                            </Grid>
                            <TextBlock Style="{StaticResource LabelStyle}">
                                <TextBlock.Text><Binding Source="{StaticResource Investments.Type}"/></TextBlock.Text>
                            </TextBlock>
                            <ComboBox ItemsSource="{Binding Source={StaticResource InvestmentTypes}}" SelectedItem="{Binding NewAssetType}" Margin="0,0,0,16"/>
                            <Grid Margin="0,0,0,16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="12"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Style="{StaticResource LabelStyle}">
                                        <TextBlock.Text><Binding Source="{StaticResource Investments.Quantity}"/></TextBlock.Text>
                                    </TextBlock>
                                    <TextBox Text="{Binding NewQuantity, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource InputStyle}"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Style="{StaticResource LabelStyle}">
                                        <TextBlock.Text><Binding Source="{StaticResource Investments.AverageCost}"/></TextBlock.Text>
                                    </TextBlock>
                                    <TextBox Text="{Binding NewAverageCost, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource InputStyle}"/>
                                </StackPanel>
                            </Grid>
                            <TextBlock Style="{StaticResource LabelStyle}">
                                <TextBlock.Text><Binding Source="{StaticResource Investments.CurrentPrice}"/></TextBlock.Text>
                            </TextBlock>
                            <TextBox Text="{Binding NewCurrentPrice, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource InputStyle}" Margin="0,0,0,16"/>
                            <TextBlock Style="{StaticResource LabelStyle}">
                                <TextBlock.Text><Binding Source="{StaticResource Investments.Note}"/></TextBlock.Text>
                            </TextBlock>
                            <TextBox Text="{Binding NewNote, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource InputStyle}" Margin="0,0,0,24"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <Button Style="{StaticResource SecondaryButton}" Command="{Binding CancelAddCommand}" Margin="0,0,12,0">
                                    <Button.Content><Binding Source="{StaticResource Common.Cancel}"/></Button.Content>
                                </Button>
                                <Button Style="{StaticResource PrimaryButton}" Command="{Binding ConfirmAddCommand}">
                                    <Button.Content><Binding Source="{StaticResource Common.Add}"/></Button.Content>
                                </Button>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Border>

                <!-- Edit Dialog -->
                <Border Background="{StaticResource DialogOverlayBrush}" Visibility="{Binding IsEditDialogOpen, Converter={StaticResource BoolToVis}}" Panel.ZIndex="100">
                    <Border.InputBindings>
                        <KeyBinding Key="Escape" Command="{Binding CancelEditCommand}"/>
                        <KeyBinding Key="Enter" Command="{Binding ConfirmEditCommand}"/>
                    </Border.InputBindings>
                    <Border Background="{StaticResource DialogBackgroundBrush}" CornerRadius="{StaticResource CardCornerRadius}" Padding="28" Width="460" VerticalAlignment="Center" HorizontalAlignment="Center">
                        <StackPanel>
                            <TextBlock Style="{StaticResource DialogTitleStyle}">
                                <TextBlock.Text><Binding Source="{StaticResource Investments.EditTitle}"/></TextBlock.Text>
                            </TextBlock>
                            <Grid Margin="0,0,0,16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="12"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Style="{StaticResource LabelStyle}">
                                        <TextBlock.Text><Binding Source="{StaticResource Investments.Symbol}"/></TextBlock.Text>
                                    </TextBlock>
                                    <TextBox Text="{Binding NewSymbol, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource InputStyle}"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Style="{StaticResource LabelStyle}">
                                        <TextBlock.Text><Binding Source="{StaticResource Investments.Name}"/></TextBlock.Text>
                                    </TextBlock>
                                    <TextBox Text="{Binding NewName, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource InputStyle}"/>
                                </StackPanel>
                            </Grid>
                            <TextBlock Style="{StaticResource LabelStyle}">
                                <TextBlock.Text><Binding Source="{StaticResource Investments.Type}"/></TextBlock.Text>
                            </TextBlock>
                            <ComboBox ItemsSource="{Binding Source={StaticResource InvestmentTypes}}" SelectedItem="{Binding NewAssetType}" Margin="0,0,0,16"/>
                            <Grid Margin="0,0,0,16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="12"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Style="{StaticResource LabelStyle}">
                                        <TextBlock.Text><Binding Source="{StaticResource Investments.Quantity}"/></TextBlock.Text>
                                    </TextBlock>
                                    <TextBox Text="{Binding NewQuantity, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource InputStyle}"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Style="{StaticResource LabelStyle}">
                                        <TextBlock.Text><Binding Source="{StaticResource Investments.AverageCost}"/></TextBlock.Text>
                                    </TextBlock>
                                    <TextBox Text="{Binding NewAverageCost, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource InputStyle}"/>
                                </StackPanel>
                            </Grid>
                            <TextBlock Style="{StaticResource LabelStyle}">
                                <TextBlock.Text><Binding Source="{StaticResource Investments.CurrentPrice}"/></TextBlock.Text>
                            </TextBlock>
                            <TextBox Text="{Binding NewCurrentPrice, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource InputStyle}" Margin="0,0,0,16"/>
                            <TextBlock Style="{StaticResource LabelStyle}">
                                <TextBlock.Text><Binding Source="{StaticResource Investments.Note}"/></TextBlock.Text>
                            </TextBlock>
                            <TextBox Text="{Binding NewNote, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource InputStyle}" Margin="0,0,0,24"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <Button Style="{StaticResource SecondaryButton}" Command="{Binding CancelEditCommand}" Margin="0,0,12,0">
                                    <Button.Content><Binding Source="{StaticResource Common.Cancel}"/></Button.Content>
                                </Button>
                                <Button Style="{StaticResource PrimaryButton}" Command="{Binding ConfirmEditCommand}">
                                    <Button.Content><Binding Source="{StaticResource Common.Save}"/></Button.Content>
                                </Button>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Border>

                <!-- Delete Confirmation -->
                <Border Background="{StaticResource DialogOverlayBrush}" Visibility="{Binding IsConfirmDeleteOpen, Converter={StaticResource BoolToVis}}" Panel.ZIndex="100">
                    <Border.InputBindings>
                        <KeyBinding Key="Escape" Command="{Binding CancelDeleteCommand}"/>
                        <KeyBinding Key="Enter" Command="{Binding ExecuteDeleteCommand}"/>
                    </Border.InputBindings>
                    <Border Background="{StaticResource DialogBackgroundBrush}" CornerRadius="{StaticResource CardCornerRadius}" Padding="28" Width="400" VerticalAlignment="Center" HorizontalAlignment="Center">
                        <StackPanel>
                            <TextBlock Style="{StaticResource DialogTitleStyle}">
                                <TextBlock.Text><Binding Source="{StaticResource Investments.DeleteTitle}"/></TextBlock.Text>
                            </TextBlock>
                            <TextBlock FontSize="13" Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap" Margin="0,0,0,24">
                                <TextBlock.Text><Binding Source="{StaticResource Investments.DeleteMessage}"/></TextBlock.Text>
                            </TextBlock>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <Button Style="{StaticResource SecondaryButton}" Command="{Binding CancelDeleteCommand}" Margin="0,0,12,0">
                                    <Button.Content><Binding Source="{StaticResource Common.Cancel}"/></Button.Content>
                                </Button>
                                <Button Style="{StaticResource DangerButton}" Command="{Binding ExecuteDeleteCommand}">
                                    <Button.Content><Binding Source="{StaticResource Common.Delete}"/></Button.Content>
                                </Button>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Border>

                <Border Height="20"/>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
