<UserControl x:Class="WealthOS.Presentation.Views.AccountsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:WealthOS.Presentation.Converters"
             xmlns:enums="clr-namespace:WealthOS.Domain.Enums;assembly=WealthOS.Domain">

    <UserControl.Resources>
        <conv:CurrencyConverter x:Key="CurrencyConv"/>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <ObjectDataProvider x:Key="AccountTypes" MethodName="GetValues" ObjectType="{x:Type enums:AssetType}">
            <ObjectDataProvider.MethodParameters><x:Type TypeName="enums:AssetType"/></ObjectDataProvider.MethodParameters>
        </ObjectDataProvider>
    </UserControl.Resources>

    <Grid>
        <Border Background="{StaticResource PrimaryBrush}" 
                Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}"
                Panel.ZIndex="50" HorizontalAlignment="Stretch" VerticalAlignment="Top" Height="3"/>

        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="28,24">
            <StackPanel MaxWidth="1200">
                <!-- 页面标题 -->
                <Grid Margin="0,0,0,24">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="{DynamicResource Accounts.Title}" FontSize="24" FontWeight="Bold" 
                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                        <TextBlock FontSize="13" Foreground="{StaticResource TextTertiaryBrush}" Margin="0,4,0,0">
                            <Run Text="&#x1F3E6; "/>
                            <Run Text="{DynamicResource Accounts.Subtitle}"/>
                        </TextBlock>
                    </StackPanel>
                    <Button Grid.Column="1" Style="{StaticResource PrimaryButton}" Command="{Binding ShowAddDialogCommand}" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#x2795;" FontSize="14" Margin="0,0,8,0"/>
                            <TextBlock Text="{DynamicResource Accounts.Add}"/>
                        </StackPanel>
                    </Button>
                </Grid>

                <!-- 总余额卡片 -->
                <Border CornerRadius="14" Padding="24,20" Margin="0,0,0,20"
                        BorderThickness="1" BorderBrush="{StaticResource BorderBrush}"
                        Background="{StaticResource CardBackgroundBrush}">
                    <Grid>
                        <StackPanel>
                            <TextBlock FontSize="13" Foreground="{StaticResource TextTertiaryBrush}" Margin="0,0,0,8" FontWeight="Medium">
                                <TextBlock.Text><Binding Source="{StaticResource Accounts.TotalBalance}"/></TextBlock.Text>
                            </TextBlock>
                            <TextBlock FontSize="36" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}">
                                <TextBlock.Text><Binding Path="TotalBalance" Converter="{StaticResource CurrencyConv}"/></TextBlock.Text>
                            </TextBlock>
                        </StackPanel>
                        <Border Width="48" Height="48" CornerRadius="12" HorizontalAlignment="Right" VerticalAlignment="Top">
                            <Border.Background>
                                <SolidColorBrush Color="#EFF6FF"/>
                            </Border.Background>
                            <TextBlock Text="&#x1F3E6;" FontSize="22" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </Grid>
                </Border>

                <!-- 空状态 -->
                <Border Padding="60" Visibility="{Binding Accounts.Count, Converter={StaticResource BoolToVis}}">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Accounts.Count}" Value="0"><Setter Property="Visibility" Value="Visible"/></DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Style="{StaticResource EmptyStateIconStyle}" Text="&#x1F3E6;"/>
                        <TextBlock Style="{StaticResource EmptyStateTitleStyle}">
                            <TextBlock.Text><Binding Source="{StaticResource Accounts.NoAccounts}"/></TextBlock.Text>
                        </TextBlock>
                        <TextBlock Style="{StaticResource EmptyStateHintStyle}">
                            <TextBlock.Text><Binding Source="{StaticResource Accounts.NoAccountsHint}"/></TextBlock.Text>
                        </TextBlock>
                    </StackPanel>
                </Border>

                <!-- 账户列表 -->
                <ItemsControl ItemsSource="{Binding Accounts}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border CornerRadius="14" Padding="20" Margin="0,0,16,16" Width="280"
                                    BorderThickness="1" BorderBrush="{StaticResource BorderBrush}"
                                    Background="{StaticResource CardBackgroundBrush}">
                                <StackPanel>
                                    <Grid Margin="0,0,0,16">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <!-- 机构标签 -->
                                        <Border Grid.Column="0" CornerRadius="6" Padding="8,4" 
                                                Background="{StaticResource SurfaceBrush}" HorizontalAlignment="Left">
                                            <TextBlock Text="{Binding Institution}" FontSize="11" 
                                                       Foreground="{StaticResource TextTertiaryBrush}" FontWeight="Medium"/>
                                        </Border>
                                        <!-- 操作按钮 -->
                                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                                            <Button Content="&#x270E;" FontSize="14" Background="Transparent" BorderThickness="0" 
                                                    Foreground="{StaticResource TextTertiaryBrush}" Cursor="Hand" Padding="6,2"
                                                    Command="{Binding DataContext.ShowEditDialogCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                    CommandParameter="{Binding Id}"/>
                                            <Button Content="&#x2716;" FontSize="12" Background="Transparent" BorderThickness="0" 
                                                    Foreground="{StaticResource TextHintBrush}" Cursor="Hand" Padding="6,2"
                                                    Command="{Binding DataContext.ConfirmDeleteCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                    CommandParameter="{Binding Id}"/>
                                        </StackPanel>
                                    </Grid>
                                    <!-- 账户名称 -->
                                    <TextBlock Text="{Binding Name}" FontSize="15" FontWeight="SemiBold" 
                                               Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,12"/>
                                    <!-- 余额 -->
                                    <TextBlock FontSize="24" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}">
                                        <TextBlock.Text><Binding Path="Balance" Converter="{StaticResource CurrencyConv}"/></TextBlock.Text>
                                    </TextBlock>
                                    <!-- 类型标签 -->
                                    <Border CornerRadius="6" Padding="8,4" Margin="0,12,0,0" HorizontalAlignment="Left">
                                        <Border.Background>
                                            <SolidColorBrush Color="#EEF2FF"/>
                                        </Border.Background>
                                        <TextBlock Text="{Binding Type}" FontSize="11" 
                                                   Foreground="{StaticResource PrimaryBrush}" FontWeight="Medium"/>
                                    </Border>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Add Dialog -->
                <Border Background="{StaticResource DialogOverlayBrush}" Visibility="{Binding IsAddDialogOpen, Converter={StaticResource BoolToVis}}" Panel.ZIndex="100">
                    <Border Background="{StaticResource DialogBackgroundBrush}" CornerRadius="16" Padding="28" Width="440" VerticalAlignment="Center" HorizontalAlignment="Center">
                        <StackPanel>
                            <TextBlock Style="{StaticResource DialogTitleStyle}">
                                <TextBlock.Text><Binding Source="{StaticResource Accounts.AddTitle}"/></TextBlock.Text>
                            </TextBlock>
                            <TextBlock Style="{StaticResource LabelStyle}">
                                <TextBlock.Text><Binding Source="{StaticResource Accounts.Name}"/></TextBlock.Text>
                            </TextBlock>
                            <TextBox Text="{Binding NewName, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource InputStyle}" Margin="0,0,0,16"/>
                            <TextBlock Style="{StaticResource LabelStyle}">
                                <TextBlock.Text><Binding Source="{StaticResource Accounts.Type}"/></TextBlock.Text>
                            </TextBlock>
                            <ComboBox ItemsSource="{Binding Source={StaticResource AccountTypes}}" SelectedItem="{Binding NewType}" Margin="0,0,0,16"/>
                            <TextBlock Style="{StaticResource LabelStyle}">
                                <TextBlock.Text><Binding Source="{StaticResource Accounts.Institution}"/></TextBlock.Text>
                            </TextBlock>
                            <TextBox Text="{Binding NewInstitution, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource InputStyle}" Margin="0,0,0,16"/>
                            <TextBlock Style="{StaticResource LabelStyle}">
                                <TextBlock.Text><Binding Source="{StaticResource Accounts.Balance}"/></TextBlock.Text>
                            </TextBlock>
                            <TextBox Text="{Binding NewBalance, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource InputStyle}" Margin="0,0,0,16"/>
                            <TextBlock Style="{StaticResource LabelStyle}">
                                <TextBlock.Text><Binding Source="{StaticResource Accounts.Note}"/></TextBlock.Text>
                            </TextBlock>
                            <TextBox Text="{Binding NewNote, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource InputStyle}" Margin="0,0,0,24"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <Button Style="{StaticResource SecondaryButton}" Command="{Binding CancelAddCommand}" Margin="0,0,12,0">
                                    <Button.Content><Binding Source="{StaticResource Common.Cancel}"/></Button.Content>
                                </Button>
                                <Button Style="{StaticResource PrimaryButton}" Command="{Binding ConfirmAddCommand}">
                                    <Button.Content><Binding Source="{StaticResource Common.Add}"/></Button.Content>
                                </Button>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Border>

                <!-- Edit Dialog -->
                <Border Background="{StaticResource DialogOverlayBrush}" Visibility="{Binding IsEditDialogOpen, Converter={StaticResource BoolToVis}}" Panel.ZIndex="100">
                    <Border Background="{StaticResource DialogBackgroundBrush}" CornerRadius="16" Padding="28" Width="440" VerticalAlignment="Center" HorizontalAlignment="Center">
                        <StackPanel>
                            <TextBlock Style="{StaticResource DialogTitleStyle}">
                                <TextBlock.Text><Binding Source="{StaticResource Accounts.EditTitle}"/></TextBlock.Text>
                            </TextBlock>
                            <TextBlock Style="{StaticResource LabelStyle}">
                                <TextBlock.Text><Binding Source="{StaticResource Accounts.Name}"/></TextBlock.Text>
                            </TextBlock>
                            <TextBox Text="{Binding NewName, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource InputStyle}" Margin="0,0,0,16"/>
                            <TextBlock Style="{StaticResource LabelStyle}">
                                <TextBlock.Text><Binding Source="{StaticResource Accounts.Type}"/></TextBlock.Text>
                            </TextBlock>
                            <ComboBox ItemsSource="{Binding Source={StaticResource AccountTypes}}" SelectedItem="{Binding NewType}" Margin="0,0,0,16"/>
                            <TextBlock Style="{StaticResource LabelStyle}">
                                <TextBlock.Text><Binding Source="{StaticResource Accounts.Institution}"/></TextBlock.Text>
                            </TextBlock>
                            <TextBox Text="{Binding NewInstitution, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource InputStyle}" Margin="0,0,0,16"/>
                            <TextBlock Style="{StaticResource LabelStyle}">
                                <TextBlock.Text><Binding Source="{StaticResource Accounts.Balance}"/></TextBlock.Text>
                            </TextBlock>
                            <TextBox Text="{Binding NewBalance, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource InputStyle}" Margin="0,0,0,16"/>
                            <TextBlock Style="{StaticResource LabelStyle}">
                                <TextBlock.Text><Binding Source="{StaticResource Accounts.Note}"/></TextBlock.Text>
                            </TextBlock>
                            <TextBox Text="{Binding NewNote, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource InputStyle}" Margin="0,0,0,24"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <Button Style="{StaticResource SecondaryButton}" Command="{Binding CancelEditCommand}" Margin="0,0,12,0">
                                    <Button.Content><Binding Source="{StaticResource Common.Cancel}"/></Button.Content>
                                </Button>
                                <Button Style="{StaticResource PrimaryButton}" Command="{Binding ConfirmEditCommand}">
                                    <Button.Content><Binding Source="{StaticResource Common.Save}"/></Button.Content>
                                </Button>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Border>

                <!-- Delete Confirmation -->
                <Border Background="{StaticResource DialogOverlayBrush}" Visibility="{Binding IsConfirmDeleteOpen, Converter={StaticResource BoolToVis}}" Panel.ZIndex="100">
                    <Border Background="{StaticResource DialogBackgroundBrush}" CornerRadius="16" Padding="28" Width="400" VerticalAlignment="Center" HorizontalAlignment="Center">
                        <StackPanel>
                            <TextBlock Style="{StaticResource DialogTitleStyle}">
                                <TextBlock.Text><Binding Source="{StaticResource Accounts.DeleteTitle}"/></TextBlock.Text>
                            </TextBlock>
                            <TextBlock FontSize="13" Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap" Margin="0,0,0,24">
                                <TextBlock.Text><Binding Source="{StaticResource Accounts.DeleteMessage}"/></TextBlock.Text>
                            </TextBlock>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <Button Style="{StaticResource SecondaryButton}" Command="{Binding CancelDeleteCommand}" Margin="0,0,12,0">
                                    <Button.Content><Binding Source="{StaticResource Common.Cancel}"/></Button.Content>
                                </Button>
                                <Button Style="{StaticResource DangerButton}" Command="{Binding ExecuteDeleteCommand}">
                                    <Button.Content><Binding Source="{StaticResource Common.Delete}"/></Button.Content>
                                </Button>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Border>

                <Border Height="20"/>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
