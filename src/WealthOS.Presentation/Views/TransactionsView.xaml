<UserControl x:Class="WealthOS.Presentation.Views.TransactionsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:WealthOS.Presentation.Converters"
             xmlns:enums="clr-namespace:WealthOS.Domain.Enums;assembly=WealthOS.Domain">

    <UserControl.Resources>
        <conv:CurrencyConverter x:Key="CurrencyConv"/>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <conv:TransactionSignMultiConverter x:Key="SignConv"/>
        <ObjectDataProvider x:Key="TransactionTypes" MethodName="GetValues"
                            ObjectType="{x:Type enums:TransactionType}">
            <ObjectDataProvider.MethodParameters>
                <x:Type TypeName="enums:TransactionType"/>
            </ObjectDataProvider.MethodParameters>
        </ObjectDataProvider>
    </UserControl.Resources>

    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="32,24">
            <StackPanel MaxWidth="1200">
                <!-- Header -->
                <Grid Margin="0,0,0,24">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Transactions" Style="{StaticResource PageTitleStyle}"/>
                    <Button Grid.Column="1" Content="+ Add Transaction" Style="{StaticResource PrimaryButton}"
                            Command="{Binding ShowAddCommand}" VerticalAlignment="Center"/>
                </Grid>

                <!-- Filter -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                    <Button Content="All" Margin="0,0,8,0" Padding="12,6" FontSize="12"
                            Background="Transparent" BorderThickness="1"
                            BorderBrush="{StaticResource BorderBrush}" Cursor="Hand"/>
                    <Button Content="Income" Margin="0,0,8,0" Padding="12,6" FontSize="12"
                            Background="Transparent" BorderThickness="1"
                            BorderBrush="{StaticResource BorderBrush}" Cursor="Hand"/>
                    <Button Content="Expense" Margin="0,0,8,0" Padding="12,6" FontSize="12"
                            Background="Transparent" BorderThickness="1"
                            BorderBrush="{StaticResource BorderBrush}" Cursor="Hand"/>
                </StackPanel>

                <!-- Transaction List -->
                <Border Style="{StaticResource CardStyle}">
                    <ItemsControl ItemsSource="{Binding Transactions}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="0,14" BorderThickness="0,0,0,1"
                                        BorderBrush="{StaticResource BorderBrush}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Ellipse Grid.Column="0" Width="10" Height="10" Margin="0,0,14,0">
                                            <Ellipse.Style>
                                                <Style TargetType="Ellipse">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Type}" Value="Income">
                                                            <Setter Property="Fill" Value="{StaticResource IncomeBrush}"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Type}" Value="Expense">
                                                            <Setter Property="Fill" Value="{StaticResource ExpenseBrush}"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Type}" Value="Transfer">
                                                            <Setter Property="Fill" Value="{StaticResource TransferBrush}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Ellipse.Style>
                                        </Ellipse>
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="{Binding Note, FallbackValue='Transaction'}"
                                                       FontSize="14" FontWeight="Medium"
                                                       Foreground="{StaticResource TextPrimaryBrush}"/>
                                            <TextBlock FontSize="12" Foreground="{StaticResource TextSecondaryBrush}">
                                                <Run Text="{Binding CategoryName, FallbackValue=''}"/>
                                                <Run Text="{Binding AccountName, FallbackValue=''}"/>
                                                <Run Text=" · "/>
                                                <Run Text="{Binding OccurredAt, StringFormat='yyyy-MM-dd'}"/>
                                            </TextBlock>
                                        </StackPanel>
                                        <TextBlock Grid.Column="2" FontSize="15" FontWeight="SemiBold"
                                                   VerticalAlignment="Center" Margin="0,0,16,0">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Type}" Value="Income">
                                                            <Setter Property="Foreground" Value="{StaticResource IncomeBrush}"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Type}" Value="Expense">
                                                            <Setter Property="Foreground" Value="{StaticResource ExpenseBrush}"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Type}" Value="Transfer">
                                                            <Setter Property="Foreground" Value="{StaticResource TransferBrush}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                            <TextBlock.Text>
                                                <MultiBinding Converter="{StaticResource SignConv}">
                                                    <Binding Path="Type"/>
                                                    <Binding Path="Amount"/>
                                                </MultiBinding>
                                            </TextBlock.Text>
                                        </TextBlock>
                                        <Button Grid.Column="3" Content="×" FontSize="14"
                                                Background="Transparent" BorderThickness="0"
                                                Foreground="{StaticResource TextHintBrush}" Cursor="Hand"
                                                Padding="4,0" VerticalAlignment="Center"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Border>

                <!-- Add Dialog -->
                <Border Background="#80000000" Visibility="{Binding IsAddDialogOpen, Converter={StaticResource BoolToVis}}"
                        Panel.ZIndex="100">
                    <Border Background="White" CornerRadius="20" Padding="32" Width="480"
                            VerticalAlignment="Center" HorizontalAlignment="Center">
                        <StackPanel>
                            <TextBlock Text="Add Transaction" FontSize="22" FontWeight="Bold"
                                       Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,24"/>

                            <TextBlock Text="Type" FontSize="13" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,6"/>
                            <ComboBox ItemsSource="{Binding Source={StaticResource TransactionTypes}}"
                                      SelectedItem="{Binding NewType}" Margin="0,0,0,16"/>

                            <TextBlock Text="Amount" FontSize="13" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,6"/>
                            <TextBox Text="{Binding NewAmount, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource InputStyle}" Margin="0,0,0,16"/>

                            <TextBlock Text="Date" FontSize="13" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,6"/>
                            <DatePicker SelectedDate="{Binding NewDate}" Margin="0,0,0,16"/>

                            <TextBlock Text="Note" FontSize="13" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,6"/>
                            <TextBox Text="{Binding NewNote, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource InputStyle}" Margin="0,0,0,24"/>

                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <Button Content="Cancel" Style="{StaticResource SecondaryButton}"
                                        Command="{Binding CancelAddCommand}" Margin="0,0,12,0"/>
                                <Button Content="Add" Style="{StaticResource PrimaryButton}"
                                        Command="{Binding ConfirmAddCommand}"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
