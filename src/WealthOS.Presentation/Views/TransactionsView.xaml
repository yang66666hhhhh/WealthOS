<UserControl x:Class="WealthOS.Presentation.Views.TransactionsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:WealthOS.Presentation.Converters"
             xmlns:enums="clr-namespace:WealthOS.Domain.Enums;assembly=WealthOS.Domain">

    <UserControl.Resources>
        <conv:CurrencyConverter x:Key="CurrencyConv"/>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <conv:TransactionSignMultiConverter x:Key="SignConv"/>
        <ObjectDataProvider x:Key="TransactionTypes" MethodName="GetValues" ObjectType="{x:Type enums:TransactionType}">
            <ObjectDataProvider.MethodParameters><x:Type TypeName="enums:TransactionType"/></ObjectDataProvider.MethodParameters>
        </ObjectDataProvider>
    </UserControl.Resources>

    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="32,24">
            <StackPanel MaxWidth="1200">
                <Grid Margin="0,0,0,24">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Style="{StaticResource PageTitleStyle}">
                        <TextBlock.Text><Binding Source="{DynamicResource Transactions.Title}"/></TextBlock.Text>
                    </TextBlock>
                    <Button Grid.Column="1" Style="{StaticResource PrimaryButton}" Command="{Binding ShowAddCommand}" VerticalAlignment="Center">
                        <Button.Content><Binding Source="{DynamicResource Transactions.Add}"/></Button.Content>
                    </Button>
                </Grid>

                <ProgressBar IsIndeterminate="True" Height="3" Margin="0,0,0,16"
                             Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}"
                             Background="Transparent" Foreground="{StaticResource PrimaryBrush}"/>

                <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                    <Button Margin="0,0,8,0" Padding="12,6" FontSize="12" Background="Transparent" BorderThickness="1"
                            BorderBrush="{StaticResource BorderBrush}" Cursor="Hand"
                            Command="{Binding FilterByTypeCommand}" CommandParameter="{x:Null}">
                        <Button.Content><Binding Source="{DynamicResource Transactions.Filter.All}"/></Button.Content>
                    </Button>
                    <Button Margin="0,0,8,0" Padding="12,6" FontSize="12" Background="Transparent" BorderThickness="1"
                            BorderBrush="{StaticResource BorderBrush}" Cursor="Hand"
                            Command="{Binding FilterByTypeCommand}" CommandParameter="Income">
                        <Button.Content><Binding Source="{DynamicResource Transactions.Filter.Income}"/></Button.Content>
                    </Button>
                    <Button Margin="0,0,8,0" Padding="12,6" FontSize="12" Background="Transparent" BorderThickness="1"
                            BorderBrush="{StaticResource BorderBrush}" Cursor="Hand"
                            Command="{Binding FilterByTypeCommand}" CommandParameter="Expense">
                        <Button.Content><Binding Source="{DynamicResource Transactions.Filter.Expense}"/></Button.Content>
                    </Button>
                </StackPanel>

                <Border Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <Border Padding="40" Visibility="{Binding Transactions.Count, Converter={StaticResource BoolToVis}}">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Transactions.Count}" Value="0"><Setter Property="Visibility" Value="Visible"/></DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock FontSize="16" Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Center">
                                    <TextBlock.Text><Binding Source="{DynamicResource Transactions.NoTransactions}"/></TextBlock.Text>
                                </TextBlock>
                                <TextBlock FontSize="13" Foreground="{StaticResource TextHintBrush}" HorizontalAlignment="Center" Margin="0,8,0,0">
                                    <TextBlock.Text><Binding Source="{DynamicResource Transactions.NoTransactionsHint}"/></TextBlock.Text>
                                </TextBlock>
                            </StackPanel>
                        </Border>

                        <ItemsControl ItemsSource="{Binding Transactions}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="0,14" BorderThickness="0,0,0,1" BorderBrush="{StaticResource BorderBrush}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <Ellipse Grid.Column="0" Width="10" Height="10" Margin="0,0,14,0">
                                                <Ellipse.Style>
                                                    <Style TargetType="Ellipse">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Type}" Value="Income"><Setter Property="Fill" Value="{StaticResource IncomeBrush}"/></DataTrigger>
                                                            <DataTrigger Binding="{Binding Type}" Value="Expense"><Setter Property="Fill" Value="{StaticResource ExpenseBrush}"/></DataTrigger>
                                                            <DataTrigger Binding="{Binding Type}" Value="Transfer"><Setter Property="Fill" Value="{StaticResource TransferBrush}"/></DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Ellipse.Style>
                                            </Ellipse>
                                            <StackPanel Grid.Column="1">
                                                <TextBlock Text="{Binding Note, FallbackValue='Transaction'}" FontSize="14" FontWeight="Medium" Foreground="{StaticResource TextPrimaryBrush}"/>
                                                <TextBlock FontSize="12" Foreground="{StaticResource TextSecondaryBrush}">
                                                    <Run Text="{Binding AccountName, FallbackValue=''}"/>
                                                    <Run Text=" · "/>
                                                    <Run Text="{Binding OccurredAt, StringFormat='yyyy-MM-dd'}"/>
                                                </TextBlock>
                                            </StackPanel>
                                            <TextBlock Grid.Column="2" FontSize="15" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,16,0">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Type}" Value="Income"><Setter Property="Foreground" Value="{StaticResource IncomeBrush}"/></DataTrigger>
                                                            <DataTrigger Binding="{Binding Type}" Value="Expense"><Setter Property="Foreground" Value="{StaticResource ExpenseBrush}"/></DataTrigger>
                                                            <DataTrigger Binding="{Binding Type}" Value="Transfer"><Setter Property="Foreground" Value="{StaticResource TransferBrush}"/></DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                                <TextBlock.Text>
                                                    <MultiBinding Converter="{StaticResource SignConv}">
                                                        <Binding Path="Type"/>
                                                        <Binding Path="Amount"/>
                                                    </MultiBinding>
                                                </TextBlock.Text>
                                            </TextBlock>
                                            <Button Grid.Column="3" Content="x" FontSize="14" Background="Transparent" BorderThickness="0"
                                                    Foreground="{StaticResource TextHintBrush}" Cursor="Hand" Padding="4,0" VerticalAlignment="Center"
                                                    Command="{Binding DataContext.ConfirmDeleteCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                    CommandParameter="{Binding Id}"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <!-- Add Dialog -->
                <Border Background="#80000000" Visibility="{Binding IsAddDialogOpen, Converter={StaticResource BoolToVis}}" Panel.ZIndex="100">
                    <Border Background="White" CornerRadius="20" Padding="32" Width="480" VerticalAlignment="Center" HorizontalAlignment="Center">
                        <StackPanel>
                            <TextBlock FontSize="22" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,24">
                                <TextBlock.Text><Binding Source="{DynamicResource Transactions.AddTitle}"/></TextBlock.Text>
                            </TextBlock>
                            <TextBlock FontSize="13" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,6">
                                <TextBlock.Text><Binding Source="{DynamicResource Transactions.Type}"/></TextBlock.Text>
                            </TextBlock>
                            <ComboBox ItemsSource="{Binding Source={StaticResource TransactionTypes}}" SelectedItem="{Binding NewType}" Margin="0,0,0,16"/>
                            <TextBlock FontSize="13" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,6">
                                <TextBlock.Text><Binding Source="{DynamicResource Transactions.Account}"/></TextBlock.Text>
                            </TextBlock>
                            <ComboBox ItemsSource="{Binding Accounts}" SelectedItem="{Binding SelectedAccount}" DisplayMemberPath="Name" Margin="0,0,0,16"/>
                            <TextBlock FontSize="13" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,6">
                                <TextBlock.Text><Binding Source="{DynamicResource Transactions.Amount}"/></TextBlock.Text>
                            </TextBlock>
                            <TextBox Text="{Binding NewAmount, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource InputStyle}" Margin="0,0,0,16"/>
                            <TextBlock FontSize="13" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,6">
                                <TextBlock.Text><Binding Source="{DynamicResource Transactions.Date}"/></TextBlock.Text>
                            </TextBlock>
                            <DatePicker SelectedDate="{Binding NewDate}" Margin="0,0,0,16"/>
                            <TextBlock FontSize="13" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,6">
                                <TextBlock.Text><Binding Source="{DynamicResource Transactions.Note}"/></TextBlock.Text>
                            </TextBlock>
                            <TextBox Text="{Binding NewNote, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource InputStyle}" Margin="0,0,0,24"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <Button Style="{StaticResource SecondaryButton}" Command="{Binding CancelAddCommand}" Margin="0,0,12,0">
                                    <Button.Content><Binding Source="{DynamicResource Common.Cancel}"/></Button.Content>
                                </Button>
                                <Button Style="{StaticResource PrimaryButton}" Command="{Binding ConfirmAddCommand}">
                                    <Button.Content><Binding Source="{DynamicResource Common.Add}"/></Button.Content>
                                </Button>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Border>

                <!-- Delete Confirmation -->
                <Border Background="#80000000" Visibility="{Binding IsConfirmDeleteOpen, Converter={StaticResource BoolToVis}}" Panel.ZIndex="100">
                    <Border Background="White" CornerRadius="20" Padding="32" Width="400" VerticalAlignment="Center" HorizontalAlignment="Center">
                        <StackPanel>
                            <TextBlock FontSize="22" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,12">
                                <TextBlock.Text><Binding Source="{DynamicResource Transactions.DeleteTitle}"/></TextBlock.Text>
                            </TextBlock>
                            <TextBlock FontSize="14" Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap" Margin="0,0,0,24">
                                <TextBlock.Text><Binding Source="{DynamicResource Transactions.DeleteMessage}"/></TextBlock.Text>
                            </TextBlock>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <Button Style="{StaticResource SecondaryButton}" Command="{Binding CancelDeleteCommand}" Margin="0,0,12,0">
                                    <Button.Content><Binding Source="{DynamicResource Common.Cancel}"/></Button.Content>
                                </Button>
                                <Button Style="{StaticResource PrimaryButton}" Command="{Binding ExecuteDeleteCommand}" Background="{StaticResource ExpenseBrush}">
                                    <Button.Content><Binding Source="{DynamicResource Common.Delete}"/></Button.Content>
                                </Button>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
