<UserControl x:Class="WealthOS.Presentation.Views.TransactionsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:WealthOS.Presentation.Converters"
             xmlns:enums="clr-namespace:WealthOS.Domain.Enums;assembly=WealthOS.Domain"
             xmlns:views="clr-namespace:WealthOS.Presentation.Views">

    <UserControl.Resources>
        <conv:CurrencyConverter x:Key="CurrencyConv"/>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <conv:TransactionSignMultiConverter x:Key="SignConv"/>
        <ObjectDataProvider x:Key="TransactionTypes" MethodName="GetValues" ObjectType="{x:Type enums:TransactionType}">
            <ObjectDataProvider.MethodParameters><x:Type TypeName="enums:TransactionType"/></ObjectDataProvider.MethodParameters>
        </ObjectDataProvider>
    </UserControl.Resources>

    <Grid>
        <views:ErrorBanner DataContext="{Binding}"/>

        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="28,24">
            <StackPanel MaxWidth="1200">
                <Grid Margin="0,0,0,24">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Style="{StaticResource PageTitleStyle}">
                        <TextBlock.Text><Binding Source="{StaticResource Transactions.Title}"/></TextBlock.Text>
                    </TextBlock>
                    <Button Grid.Column="1" Style="{StaticResource PrimaryButton}" Command="{Binding ShowAddDialogCommand}" VerticalAlignment="Center">
                        <Button.Content><Binding Source="{StaticResource Transactions.Add}"/></Button.Content>
                    </Button>
                </Grid>

                <Border Background="{StaticResource PrimaryBrush}" 
                        Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}"
                        Height="3" CornerRadius="2" Margin="0,0,0,16" HorizontalAlignment="Left" Width="120"/>

                <!-- 搜索框 -->
                <Border CornerRadius="12" Padding="0" Margin="0,0,0,16"
                        BorderThickness="1" BorderBrush="{StaticResource BorderBrush}"
                        Background="{StaticResource CardBackgroundBrush}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Padding="14,10">
                            <TextBlock Text="&#x1F50D;" FontSize="14" VerticalAlignment="Center" Opacity="0.5"/>
                        </Border>
                        <TextBox Grid.Column="1" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource InputStyle}" BorderThickness="0"
                                 Tag="{DynamicResource Transactions.Search}"/>
                    </Grid>
                </Border>

                <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                    <Button Margin="0,0,8,0" Padding="12,6" FontSize="12" Cursor="Hand"
                            Command="{Binding FilterByTypeCommand}" CommandParameter="{x:Null}">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource SecondaryButton}">
                                <Setter Property="Padding" Value="12,6"/>
                                <Setter Property="FontSize" Value="12"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedFilter}" Value="All">
                                        <Setter Property="Background" Value="{StaticResource PrimaryBrush}"/>
                                        <Setter Property="Foreground" Value="White"/>
                                        <Setter Property="BorderThickness" Value="0"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <Button.Content><Binding Source="{StaticResource Transactions.Filter.All}"/></Button.Content>
                    </Button>
                    <Button Margin="0,0,8,0" Padding="12,6" FontSize="12" Cursor="Hand"
                            Command="{Binding FilterByTypeCommand}" CommandParameter="Income">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource SecondaryButton}">
                                <Setter Property="Padding" Value="12,6"/>
                                <Setter Property="FontSize" Value="12"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedFilter}" Value="Income">
                                        <Setter Property="Background" Value="{StaticResource IncomeBrush}"/>
                                        <Setter Property="Foreground" Value="White"/>
                                        <Setter Property="BorderThickness" Value="0"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <Button.Content><Binding Source="{StaticResource Transactions.Filter.Income}"/></Button.Content>
                    </Button>
                    <Button Margin="0,0,8,0" Padding="12,6" FontSize="12" Cursor="Hand"
                            Command="{Binding FilterByTypeCommand}" CommandParameter="Expense">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource SecondaryButton}">
                                <Setter Property="Padding" Value="12,6"/>
                                <Setter Property="FontSize" Value="12"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedFilter}" Value="Expense">
                                        <Setter Property="Background" Value="{StaticResource ExpenseBrush}"/>
                                        <Setter Property="Foreground" Value="White"/>
                                        <Setter Property="BorderThickness" Value="0"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <Button.Content><Binding Source="{StaticResource Transactions.Filter.Expense}"/></Button.Content>
                    </Button>
                    <Button Margin="0,0,8,0" Padding="12,6" FontSize="12" Cursor="Hand"
                            Command="{Binding FilterByTypeCommand}" CommandParameter="Transfer">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource SecondaryButton}">
                                <Setter Property="Padding" Value="12,6"/>
                                <Setter Property="FontSize" Value="12"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedFilter}" Value="Transfer">
                                        <Setter Property="Background" Value="{StaticResource TransferBrush}"/>
                                        <Setter Property="Foreground" Value="White"/>
                                        <Setter Property="BorderThickness" Value="0"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <Button.Content><Binding Source="{StaticResource Transactions.Filter.Transfer}"/></Button.Content>
                    </Button>
                </StackPanel>

                <Border Style="{StaticResource CardStyle}" Padding="0">
                    <StackPanel>
                        <!-- 空状态 -->
                        <Border Padding="40">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <MultiDataTrigger>
                                            <MultiDataTrigger.Conditions>
                                                <Condition Binding="{Binding IsLoading}" Value="False"/>
                                                <Condition Binding="{Binding Transactions.Count}" Value="0"/>
                                            </MultiDataTrigger.Conditions>
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </MultiDataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock Style="{StaticResource EmptyStateIconStyle}" Text="&#x1F4CB;"/>
                                <TextBlock Style="{StaticResource EmptyStateTitleStyle}">
                                    <TextBlock.Text><Binding Source="{StaticResource Transactions.NoTransactions}"/></TextBlock.Text>
                                </TextBlock>
                                <TextBlock Style="{StaticResource EmptyStateHintStyle}">
                                    <TextBlock.Text><Binding Source="{StaticResource Transactions.NoTransactionsHint}"/></TextBlock.Text>
                                </TextBlock>
                            </StackPanel>
                        </Border>

                        <!-- 交易列表 -->
                        <ListView ItemsSource="{Binding Transactions}"
                                  VirtualizingStackPanel.IsVirtualizing="True"
                                  VirtualizingStackPanel.VirtualizationMode="Recycling"
                                  ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                  BorderThickness="0" Background="Transparent"
                                  MaxHeight="600">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="16,12" BorderThickness="0,0,0,1" BorderBrush="{StaticResource BorderLightBrush}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <!-- 类型指示器 -->
                                            <Border Grid.Column="0" Width="40" Height="40" CornerRadius="{StaticResource IconCornerRadius}" Margin="0,0,14,0">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Type}" Value="Income">
                                                                <Setter Property="Background" Value="{StaticResource IncomeLightBrush}"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Type}" Value="Expense">
                                                                <Setter Property="Background" Value="{StaticResource ExpenseLightBrush}"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Type}" Value="Transfer">
                                                                <Setter Property="Background" Value="{StaticResource TransferLightBrush}"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="16">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Type}" Value="Income">
                                                                    <Setter Property="Text" Value="&#x2191;"/>
                                                                    <Setter Property="Foreground" Value="{StaticResource IncomeBrush}"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Type}" Value="Expense">
                                                                    <Setter Property="Text" Value="&#x2193;"/>
                                                                    <Setter Property="Foreground" Value="{StaticResource ExpenseBrush}"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Type}" Value="Transfer">
                                                                    <Setter Property="Text" Value="&#x2194;"/>
                                                                    <Setter Property="Foreground" Value="{StaticResource TransferBrush}"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </Border>
                                            <!-- 交易信息 -->
                                            <StackPanel Grid.Column="1">
                                                <TextBlock Text="{Binding Note, FallbackValue='Transaction'}" 
                                                           FontSize="14" FontWeight="Medium" Foreground="{StaticResource TextPrimaryBrush}"/>
                                                <TextBlock FontSize="12" Foreground="{StaticResource TextTertiaryBrush}" Margin="0,4,0,0">
                                                    <Run Text="{Binding AccountName, FallbackValue=''}"/>
                                                    <Run Text=" · "/>
                                                    <Run Text="{Binding OccurredAt, StringFormat='yyyy-MM-dd'}"/>
                                                </TextBlock>
                                            </StackPanel>
                                            <!-- 分类标签 -->
                                            <Border Grid.Column="2" CornerRadius="6" Padding="8,4" Margin="0,0,12,0"
                                                    VerticalAlignment="Center">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Type}" Value="Income">
                                                                <Setter Property="Background" Value="{StaticResource IncomeLightBrush}"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Type}" Value="Expense">
                                                                <Setter Property="Background" Value="{StaticResource ExpenseLightBrush}"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Type}" Value="Transfer">
                                                                <Setter Property="Background" Value="{StaticResource TransferLightBrush}"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <TextBlock FontSize="11" FontWeight="Medium">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Type}" Value="Income">
                                                                    <Setter Property="Foreground" Value="{StaticResource IncomeBrush}"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Type}" Value="Expense">
                                                                    <Setter Property="Foreground" Value="{StaticResource ExpenseBrush}"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Type}" Value="Transfer">
                                                                    <Setter Property="Foreground" Value="{StaticResource TransferBrush}"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                    <TextBlock.Text>
                                                        <MultiBinding Converter="{StaticResource SignConv}">
                                                            <Binding Path="Type"/>
                                                            <Binding Path="Amount"/>
                                                        </MultiBinding>
                                                    </TextBlock.Text>
                                                </TextBlock>
                                            </Border>
                                            <!-- 操作按钮 -->
                                            <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center">
                                                <Button Content="&#x270E;" FontSize="14" Background="Transparent" BorderThickness="0" 
                                                        Foreground="{StaticResource TextTertiaryBrush}" Cursor="Hand" Padding="6,2"
                                                        ToolTip="{DynamicResource Tooltip.Edit}"
                                                        Command="{Binding DataContext.ShowEditDialogCommand, RelativeSource={RelativeSource AncestorType=ListView}}"
                                                        CommandParameter="{Binding}"/>
                                                <Button Content="&#x2716;" FontSize="12" Background="Transparent" BorderThickness="0" 
                                                        Foreground="{StaticResource TextHintBrush}" Cursor="Hand" Padding="6,2"
                                                        ToolTip="{DynamicResource Tooltip.Delete}"
                                                        Command="{Binding DataContext.ConfirmDeleteCommand, RelativeSource={RelativeSource AncestorType=ListView}}"
                                                        CommandParameter="{Binding Id}"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </StackPanel>
                </Border>

                <!-- Add Dialog -->
                <Border Background="{StaticResource DialogOverlayBrush}" Visibility="{Binding IsAddDialogOpen, Converter={StaticResource BoolToVis}}" Panel.ZIndex="100">
                    <Border.InputBindings>
                        <KeyBinding Key="Escape" Command="{Binding CancelAddCommand}"/>
                        <KeyBinding Key="Enter" Command="{Binding ConfirmAddCommand}"/>
                    </Border.InputBindings>
                    <Border Background="{StaticResource DialogBackgroundBrush}" CornerRadius="{StaticResource DialogCornerRadius}" Padding="32" Width="480" VerticalAlignment="Center" HorizontalAlignment="Center">
                        <StackPanel>
                            <TextBlock Style="{StaticResource DialogTitleStyle}">
                                <TextBlock.Text><Binding Source="{StaticResource Transactions.AddTitle}"/></TextBlock.Text>
                            </TextBlock>
                            <TextBlock Style="{StaticResource LabelStyle}">
                                <TextBlock.Text><Binding Source="{StaticResource Transactions.Type}"/></TextBlock.Text>
                            </TextBlock>
                            <ComboBox ItemsSource="{Binding Source={StaticResource TransactionTypes}}" SelectedItem="{Binding NewType}" Margin="0,0,0,16"/>
                            <TextBlock Style="{StaticResource LabelStyle}">
                                <TextBlock.Text><Binding Source="{StaticResource Transactions.Account}"/></TextBlock.Text>
                            </TextBlock>
                            <ComboBox ItemsSource="{Binding Accounts}" SelectedItem="{Binding SelectedAccount}" DisplayMemberPath="Name" Margin="0,0,0,16"/>
                            <TextBlock Style="{StaticResource LabelStyle}">
                                <TextBlock.Text><Binding Source="{StaticResource Transactions.Category}"/></TextBlock.Text>
                            </TextBlock>
                            <ComboBox ItemsSource="{Binding Categories}" SelectedItem="{Binding SelectedCategory}" DisplayMemberPath="Name" Margin="0,0,0,16"/>
                            <TextBlock Style="{StaticResource LabelStyle}">
                                <TextBlock.Text><Binding Source="{StaticResource Transactions.Amount}"/></TextBlock.Text>
                            </TextBlock>
                            <TextBox Text="{Binding NewAmount, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource InputStyle}" Margin="0,0,0,16"/>
                            <TextBlock Style="{StaticResource LabelStyle}">
                                <TextBlock.Text><Binding Source="{StaticResource Transactions.Date}"/></TextBlock.Text>
                            </TextBlock>
                            <DatePicker SelectedDate="{Binding NewDate}" Margin="0,0,0,16"/>
                            <TextBlock Style="{StaticResource LabelStyle}">
                                <TextBlock.Text><Binding Source="{StaticResource Transactions.Note}"/></TextBlock.Text>
                            </TextBlock>
                            <TextBox Text="{Binding NewNote, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource InputStyle}" Margin="0,0,0,24"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <Button Style="{StaticResource SecondaryButton}" Command="{Binding CancelAddCommand}" Margin="0,0,12,0">
                                    <Button.Content><Binding Source="{StaticResource Common.Cancel}"/></Button.Content>
                                </Button>
                                <Button Style="{StaticResource PrimaryButton}" Command="{Binding ConfirmAddCommand}">
                                    <Button.Content><Binding Source="{StaticResource Common.Add}"/></Button.Content>
                                </Button>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Border>

                <!-- Delete Confirmation -->
                <Border Background="{StaticResource DialogOverlayBrush}" Visibility="{Binding IsConfirmDeleteOpen, Converter={StaticResource BoolToVis}}" Panel.ZIndex="100">
                    <Border.InputBindings>
                        <KeyBinding Key="Escape" Command="{Binding CancelDeleteCommand}"/>
                        <KeyBinding Key="Enter" Command="{Binding ExecuteDeleteCommand}"/>
                    </Border.InputBindings>
                    <Border Background="{StaticResource DialogBackgroundBrush}" CornerRadius="{StaticResource DialogCornerRadius}" Padding="32" Width="400" VerticalAlignment="Center" HorizontalAlignment="Center">
                        <StackPanel>
                            <TextBlock Style="{StaticResource DialogTitleStyle}">
                                <TextBlock.Text><Binding Source="{StaticResource Transactions.DeleteTitle}"/></TextBlock.Text>
                            </TextBlock>
                            <TextBlock FontSize="14" Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap" Margin="0,0,0,24">
                                <TextBlock.Text><Binding Source="{StaticResource Transactions.DeleteMessage}"/></TextBlock.Text>
                            </TextBlock>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <Button Style="{StaticResource SecondaryButton}" Command="{Binding CancelDeleteCommand}" Margin="0,0,12,0">
                                    <Button.Content><Binding Source="{StaticResource Common.Cancel}"/></Button.Content>
                                </Button>
                                <Button Style="{StaticResource DangerButton}" Command="{Binding ExecuteDeleteCommand}">
                                    <Button.Content><Binding Source="{StaticResource Common.Delete}"/></Button.Content>
                                </Button>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Border>

                <!-- Edit Dialog -->
                <Border Background="{StaticResource DialogOverlayBrush}" Visibility="{Binding IsEditDialogOpen, Converter={StaticResource BoolToVis}}" Panel.ZIndex="100">
                    <Border.InputBindings>
                        <KeyBinding Key="Escape" Command="{Binding CancelEditCommand}"/>
                        <KeyBinding Key="Enter" Command="{Binding ConfirmEditCommand}"/>
                    </Border.InputBindings>
                    <Border Background="{StaticResource DialogBackgroundBrush}" CornerRadius="{StaticResource DialogCornerRadius}" Padding="32" Width="480" VerticalAlignment="Center" HorizontalAlignment="Center">
                        <StackPanel>
                            <TextBlock Style="{StaticResource DialogTitleStyle}">
                                <TextBlock.Text><Binding Source="{StaticResource Transactions.EditTitle}"/></TextBlock.Text>
                            </TextBlock>
                            <TextBlock Style="{StaticResource LabelStyle}">
                                <TextBlock.Text><Binding Source="{StaticResource Transactions.Type}"/></TextBlock.Text>
                            </TextBlock>
                            <ComboBox ItemsSource="{Binding Source={StaticResource TransactionTypes}}" SelectedItem="{Binding NewType}" Margin="0,0,0,16"/>
                            <TextBlock Style="{StaticResource LabelStyle}">
                                <TextBlock.Text><Binding Source="{StaticResource Transactions.Account}"/></TextBlock.Text>
                            </TextBlock>
                            <ComboBox ItemsSource="{Binding Accounts}" SelectedItem="{Binding SelectedAccount}" DisplayMemberPath="Name" Margin="0,0,0,16"/>
                            <TextBlock Style="{StaticResource LabelStyle}">
                                <TextBlock.Text><Binding Source="{StaticResource Transactions.Category}"/></TextBlock.Text>
                            </TextBlock>
                            <ComboBox ItemsSource="{Binding Categories}" SelectedItem="{Binding SelectedCategory}" DisplayMemberPath="Name" Margin="0,0,0,16"/>
                            <TextBlock Style="{StaticResource LabelStyle}">
                                <TextBlock.Text><Binding Source="{StaticResource Transactions.Amount}"/></TextBlock.Text>
                            </TextBlock>
                            <TextBox Text="{Binding NewAmount, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource InputStyle}" Margin="0,0,0,16"/>
                            <TextBlock Style="{StaticResource LabelStyle}">
                                <TextBlock.Text><Binding Source="{StaticResource Transactions.Date}"/></TextBlock.Text>
                            </TextBlock>
                            <DatePicker SelectedDate="{Binding NewDate}" Margin="0,0,0,16"/>
                            <TextBlock Style="{StaticResource LabelStyle}">
                                <TextBlock.Text><Binding Source="{StaticResource Transactions.Note}"/></TextBlock.Text>
                            </TextBlock>
                            <TextBox Text="{Binding NewNote, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource InputStyle}" Margin="0,0,0,24"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <Button Style="{StaticResource SecondaryButton}" Command="{Binding CancelEditCommand}" Margin="0,0,12,0">
                                    <Button.Content><Binding Source="{StaticResource Common.Cancel}"/></Button.Content>
                                </Button>
                                <Button Style="{StaticResource PrimaryButton}" Command="{Binding ConfirmEditCommand}">
                                    <Button.Content><Binding Source="{StaticResource Common.Save}"/></Button.Content>
                                </Button>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
