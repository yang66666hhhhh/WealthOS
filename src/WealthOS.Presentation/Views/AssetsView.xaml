<UserControl x:Class="WealthOS.Presentation.Views.AssetsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:WealthOS.Presentation.Converters"
             xmlns:enums="clr-namespace:WealthOS.Domain.Enums;assembly=WealthOS.Domain">

    <UserControl.Resources>
        <conv:CurrencyConverter x:Key="CurrencyConv"/>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <ObjectDataProvider x:Key="AssetTypes" MethodName="GetValues"
                            ObjectType="{x:Type enums:AssetType}">
            <ObjectDataProvider.MethodParameters>
                <x:Type TypeName="enums:AssetType"/>
            </ObjectDataProvider.MethodParameters>
        </ObjectDataProvider>
    </UserControl.Resources>

    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="32,24">
            <StackPanel MaxWidth="1200">
                <!-- Header -->
                <Grid Margin="0,0,0,24">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Assets" Style="{StaticResource PageTitleStyle}"/>
                    <Button Grid.Column="1" Content="+ Add Asset" Style="{StaticResource PrimaryButton}"
                            Command="{Binding ShowAddCommand}" VerticalAlignment="Center"/>
                </Grid>

                <!-- Filter -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                    <Button Content="All" Margin="0,0,8,0" Padding="12,6" FontSize="12"
                            Background="Transparent" BorderThickness="1"
                            BorderBrush="{StaticResource BorderBrush}" Cursor="Hand"/>
                    <Button Content="Cash" Margin="0,0,8,0" Padding="12,6" FontSize="12"
                            Background="Transparent" BorderThickness="1"
                            BorderBrush="{StaticResource BorderBrush}" Cursor="Hand"/>
                    <Button Content="Bank" Margin="0,0,8,0" Padding="12,6" FontSize="12"
                            Background="Transparent" BorderThickness="1"
                            BorderBrush="{StaticResource BorderBrush}" Cursor="Hand"/>
                    <Button Content="Investment" Margin="0,0,8,0" Padding="12,6" FontSize="12"
                            Background="Transparent" BorderThickness="1"
                            BorderBrush="{StaticResource BorderBrush}" Cursor="Hand"/>
                </StackPanel>

                <!-- Asset Cards -->
                <ItemsControl ItemsSource="{Binding Assets}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Style="{StaticResource CardStyle}" Margin="0,0,16,16" Width="260">
                                <StackPanel>
                                    <Grid Margin="0,0,0,12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding Institution}"
                                                   FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"/>
                                        <Button Grid.Column="1" Content="×" FontSize="14"
                                                Background="Transparent" BorderThickness="0"
                                                Foreground="{StaticResource TextHintBrush}" Cursor="Hand"
                                                Padding="4,0"/>
                                    </Grid>
                                    <TextBlock Text="{Binding Name}" FontSize="16" FontWeight="SemiBold"
                                               Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,8"/>
                                    <TextBlock FontSize="26" FontWeight="Bold"
                                               Foreground="{StaticResource TextPrimaryBrush}">
                                        <TextBlock.Text>
                                            <Binding Path="CurrentValue" Converter="{StaticResource CurrencyConv}"/>
                                        </TextBlock.Text>
                                    </TextBlock>
                                    <TextBlock Margin="0,8,0,0" FontSize="13">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding ChangeAmount}" Value="0">
                                                        <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                        <TextBlock.Text>
                                            <Binding Path="ChangePercentage" StringFormat="{}{0:+0.0;-0.0}%"/>
                                        </TextBlock.Text>
                                    </TextBlock>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Add Dialog Overlay -->
                <Border Background="#80000000" Visibility="{Binding IsAddDialogOpen, Converter={StaticResource BoolToVis}}"
                        Panel.ZIndex="100">
                    <Border Background="White" CornerRadius="20" Padding="32" Width="480"
                            VerticalAlignment="Center" HorizontalAlignment="Center">
                        <StackPanel>
                            <TextBlock Text="Add Asset" FontSize="22" FontWeight="Bold"
                                       Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,24"/>

                            <TextBlock Text="Name" FontSize="13" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,6"/>
                            <TextBox Text="{Binding NewName, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource InputStyle}" Margin="0,0,0,16"/>

                            <TextBlock Text="Type" FontSize="13" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,6"/>
                            <ComboBox ItemsSource="{Binding Source={StaticResource AssetTypes}}"
                                      SelectedItem="{Binding NewType}" Margin="0,0,0,16"/>

                            <TextBlock Text="Institution" FontSize="13" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,6"/>
                            <TextBox Text="{Binding NewInstitution, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource InputStyle}" Margin="0,0,0,16"/>

                            <Grid Margin="0,0,0,16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="16"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Current Value" FontSize="13" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,6"/>
                                    <TextBox Text="{Binding NewCurrentValue, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource InputStyle}"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Initial Value" FontSize="13" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,6"/>
                                    <TextBox Text="{Binding NewInitialValue, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource InputStyle}"/>
                                </StackPanel>
                            </Grid>

                            <TextBlock Text="Note" FontSize="13" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,6"/>
                            <TextBox Text="{Binding NewNote, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource InputStyle}" Margin="0,0,0,24"/>

                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <Button Content="Cancel" Style="{StaticResource SecondaryButton}"
                                        Command="{Binding CancelAddCommand}" Margin="0,0,12,0"/>
                                <Button Content="Add" Style="{StaticResource PrimaryButton}"
                                        Command="{Binding ConfirmAddCommand}"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
