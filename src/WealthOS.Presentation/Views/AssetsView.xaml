<UserControl x:Class="WealthOS.Presentation.Views.AssetsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:WealthOS.Presentation.Converters"
             xmlns:enums="clr-namespace:WealthOS.Domain.Enums;assembly=WealthOS.Domain"
             xmlns:views="clr-namespace:WealthOS.Presentation.Views">

    <UserControl.Resources>
        <conv:CurrencyConverter x:Key="CurrencyConv"/>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <ObjectDataProvider x:Key="AssetTypes" MethodName="GetValues" ObjectType="{x:Type enums:AssetType}">
            <ObjectDataProvider.MethodParameters><x:Type TypeName="enums:AssetType"/></ObjectDataProvider.MethodParameters>
        </ObjectDataProvider>
    </UserControl.Resources>

    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="28,24">
            <StackPanel MaxWidth="1200">
                <Grid Margin="0,0,0,24">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Style="{StaticResource PageTitleStyle}">
                        <TextBlock.Text><Binding Source="{StaticResource Assets.Title}"/></TextBlock.Text>
                    </TextBlock>
                    <Button Grid.Column="1" Style="{StaticResource PrimaryButton}" Command="{Binding ShowAddDialogCommand}" VerticalAlignment="Center">
                        <Button.Content><Binding Source="{StaticResource Assets.Add}"/></Button.Content>
                    </Button>
                </Grid>

                <!-- 加载指示器 -->
                <Border Background="{StaticResource PrimaryBrush}" 
                        Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}"
                        Height="3" CornerRadius="2" Margin="0,0,0,16" HorizontalAlignment="Left" Width="120"/>

                <views:ErrorBanner DataContext="{Binding}"/>

                <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                    <Button Margin="0,0,8,0" Padding="12,6" FontSize="12" Cursor="Hand"
                            Command="{Binding FilterByTypeCommand}" CommandParameter="{x:Null}">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource SecondaryButton}">
                                <Setter Property="Padding" Value="12,6"/>
                                <Setter Property="FontSize" Value="12"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedFilter}" Value="All">
                                        <Setter Property="Background" Value="{StaticResource PrimaryBrush}"/>
                                        <Setter Property="Foreground" Value="White"/>
                                        <Setter Property="BorderThickness" Value="0"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <Button.Content><Binding Source="{StaticResource Assets.Filter.All}"/></Button.Content>
                    </Button>
                    <Button Margin="0,0,8,0" Padding="12,6" FontSize="12" Cursor="Hand"
                            Command="{Binding FilterByTypeCommand}" CommandParameter="Cash">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource SecondaryButton}">
                                <Setter Property="Padding" Value="12,6"/>
                                <Setter Property="FontSize" Value="12"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedFilter}" Value="Cash">
                                        <Setter Property="Background" Value="{StaticResource PrimaryBrush}"/>
                                        <Setter Property="Foreground" Value="White"/>
                                        <Setter Property="BorderThickness" Value="0"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <Button.Content><Binding Source="{StaticResource Assets.Filter.Cash}"/></Button.Content>
                    </Button>
                    <Button Margin="0,0,8,0" Padding="12,6" FontSize="12" Cursor="Hand"
                            Command="{Binding FilterByTypeCommand}" CommandParameter="Bank">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource SecondaryButton}">
                                <Setter Property="Padding" Value="12,6"/>
                                <Setter Property="FontSize" Value="12"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedFilter}" Value="Bank">
                                        <Setter Property="Background" Value="{StaticResource PrimaryBrush}"/>
                                        <Setter Property="Foreground" Value="White"/>
                                        <Setter Property="BorderThickness" Value="0"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <Button.Content><Binding Source="{StaticResource Assets.Filter.Bank}"/></Button.Content>
                    </Button>
                    <Button Margin="0,0,8,0" Padding="12,6" FontSize="12" Cursor="Hand"
                            Command="{Binding FilterByTypeCommand}" CommandParameter="Fund">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource SecondaryButton}">
                                <Setter Property="Padding" Value="12,6"/>
                                <Setter Property="FontSize" Value="12"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedFilter}" Value="Fund">
                                        <Setter Property="Background" Value="{StaticResource PrimaryBrush}"/>
                                        <Setter Property="Foreground" Value="White"/>
                                        <Setter Property="BorderThickness" Value="0"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <Button.Content><Binding Source="{StaticResource Assets.Filter.Investment}"/></Button.Content>
                    </Button>
                </StackPanel>

                <Border Padding="60">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Assets.Count}" Value="0"><Setter Property="Visibility" Value="Visible"/></DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Style="{StaticResource EmptyStateIconStyle}" Text="&#x1F4B0;"/>
                        <TextBlock Style="{StaticResource EmptyStateTitleStyle}">
                            <TextBlock.Text><Binding Source="{StaticResource Assets.NoAssets}"/></TextBlock.Text>
                        </TextBlock>
                        <TextBlock Style="{StaticResource EmptyStateHintStyle}">
                            <TextBlock.Text><Binding Source="{StaticResource Assets.NoAssetsHint}"/></TextBlock.Text>
                        </TextBlock>
                    </StackPanel>
                </Border>

                <ItemsControl ItemsSource="{Binding Assets}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border CornerRadius="{StaticResource CardCornerRadius}" Padding="20" Margin="0,0,16,16" Width="260"
                                    BorderThickness="1" BorderBrush="{StaticResource BorderBrush}"
                                    Background="{StaticResource CardBackgroundBrush}">
                                <StackPanel>
                                    <Grid Margin="0,0,0,16">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <!-- 机构标签 -->
                                        <Border Grid.Column="0" CornerRadius="6" Padding="8,4" 
                                                Background="{StaticResource SurfaceBrush}" HorizontalAlignment="Left">
                                            <TextBlock Text="{Binding Institution}" FontSize="11" 
                                                       Foreground="{StaticResource TextTertiaryBrush}" FontWeight="Medium"/>
                                        </Border>
                                        <!-- 操作按钮 -->
                                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                                            <Button Content="&#x270E;" FontSize="14" Background="Transparent" BorderThickness="0" 
                                                    Foreground="{StaticResource TextTertiaryBrush}" Cursor="Hand" Padding="6,2"
                                                    ToolTip="{DynamicResource Tooltip.Edit}"
                                                    Command="{Binding DataContext.ShowEditDialogCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}" 
                                                    CommandParameter="{Binding Id}"/>
                                            <Button Content="&#x2716;" FontSize="12" Background="Transparent" BorderThickness="0" 
                                                    Foreground="{StaticResource TextHintBrush}" Cursor="Hand" Padding="6,2"
                                                    ToolTip="{DynamicResource Tooltip.Delete}"
                                                    Command="{Binding DataContext.ConfirmDeleteCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                    CommandParameter="{Binding Id}"/>
                                        </StackPanel>
                                    </Grid>
                                    <!-- 资产名称 -->
                                    <TextBlock Text="{Binding Name}" FontSize="15" FontWeight="SemiBold" 
                                               Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,12"/>
                                    <!-- 金额 -->
                                    <TextBlock FontSize="24" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}">
                                        <TextBlock.Text><Binding Path="CurrentValue" Converter="{StaticResource CurrencyConv}"/></TextBlock.Text>
                                    </TextBlock>
                                    <!-- 变化率 -->
                                    <Border CornerRadius="6" Padding="8,4" Margin="0,12,0,0" HorizontalAlignment="Left">
                                        <Border.Background>
                                            <SolidColorBrush Color="{StaticResource AccentLightColor}"/>
                                        </Border.Background>
                                        <TextBlock FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource AccentBrush}">
                                            <TextBlock.Text><Binding Path="ChangePercentage" StringFormat="{}{0:+0.0;-0.0}%"/></TextBlock.Text>
                                        </TextBlock>
                                    </Border>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Add Dialog -->
                <Border Background="{StaticResource DialogOverlayBrush}" Visibility="{Binding IsAddDialogOpen, Converter={StaticResource BoolToVis}}" Panel.ZIndex="100">
                    <Border.InputBindings>
                        <KeyBinding Key="Escape" Command="{Binding CancelAddCommand}"/>
                        <KeyBinding Key="Enter" Command="{Binding ConfirmAddCommand}"/>
                    </Border.InputBindings>
                    <Border Background="{StaticResource DialogBackgroundBrush}" CornerRadius="{StaticResource DialogCornerRadius}" Padding="32" Width="480" VerticalAlignment="Center" HorizontalAlignment="Center">
                        <StackPanel>
                            <TextBlock Style="{StaticResource DialogTitleStyle}">
                                <TextBlock.Text><Binding Source="{StaticResource Assets.AddTitle}"/></TextBlock.Text>
                            </TextBlock>
                            <TextBlock Style="{StaticResource LabelStyle}">
                                <TextBlock.Text><Binding Source="{StaticResource Assets.Name}"/></TextBlock.Text>
                            </TextBlock>
                            <TextBox Text="{Binding NewName, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource InputStyle}" Margin="0,0,0,16"/>
                            <TextBlock Style="{StaticResource LabelStyle}">
                                <TextBlock.Text><Binding Source="{StaticResource Assets.Type}"/></TextBlock.Text>
                            </TextBlock>
                            <ComboBox ItemsSource="{Binding Source={StaticResource AssetTypes}}" SelectedItem="{Binding NewType}" Margin="0,0,0,16"/>
                            <TextBlock Style="{StaticResource LabelStyle}">
                                <TextBlock.Text><Binding Source="{StaticResource Assets.Institution}"/></TextBlock.Text>
                            </TextBlock>
                            <TextBox Text="{Binding NewInstitution, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource InputStyle}" Margin="0,0,0,16"/>
                            <Grid Margin="0,0,0,16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="16"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Style="{StaticResource LabelStyle}">
                                        <TextBlock.Text><Binding Source="{StaticResource Assets.CurrentValue}"/></TextBlock.Text>
                                    </TextBlock>
                                    <TextBox Text="{Binding NewCurrentValue, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource InputStyle}"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Style="{StaticResource LabelStyle}">
                                        <TextBlock.Text><Binding Source="{StaticResource Assets.InitialValue}"/></TextBlock.Text>
                                    </TextBlock>
                                    <TextBox Text="{Binding NewInitialValue, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource InputStyle}"/>
                                </StackPanel>
                            </Grid>
                            <TextBlock Style="{StaticResource LabelStyle}">
                                <TextBlock.Text><Binding Source="{StaticResource Assets.Note}"/></TextBlock.Text>
                            </TextBlock>
                            <TextBox Text="{Binding NewNote, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource InputStyle}" Margin="0,0,0,24"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <Button Style="{StaticResource SecondaryButton}" Command="{Binding CancelAddCommand}" Margin="0,0,12,0">
                                    <Button.Content><Binding Source="{StaticResource Common.Cancel}"/></Button.Content>
                                </Button>
                                <Button Style="{StaticResource PrimaryButton}" Command="{Binding ConfirmAddCommand}">
                                    <Button.Content><Binding Source="{StaticResource Common.Add}"/></Button.Content>
                                </Button>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Border>

                <!-- Delete Confirmation -->
                <Border Background="{StaticResource DialogOverlayBrush}" Visibility="{Binding IsConfirmDeleteOpen, Converter={StaticResource BoolToVis}}" Panel.ZIndex="100">
                    <Border.InputBindings>
                        <KeyBinding Key="Escape" Command="{Binding CancelDeleteCommand}"/>
                        <KeyBinding Key="Enter" Command="{Binding ExecuteDeleteCommand}"/>
                    </Border.InputBindings>
                    <Border Background="{StaticResource DialogBackgroundBrush}" CornerRadius="{StaticResource DialogCornerRadius}" Padding="32" Width="400" VerticalAlignment="Center" HorizontalAlignment="Center">
                        <StackPanel>
                            <TextBlock Style="{StaticResource DialogTitleStyle}">
                                <TextBlock.Text><Binding Source="{StaticResource Assets.DeleteTitle}"/></TextBlock.Text>
                            </TextBlock>
                            <TextBlock FontSize="14" Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap" Margin="0,0,0,24">
                                <TextBlock.Text><Binding Source="{StaticResource Assets.DeleteMessage}"/></TextBlock.Text>
                            </TextBlock>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <Button Style="{StaticResource SecondaryButton}" Command="{Binding CancelDeleteCommand}" Margin="0,0,12,0">
                                    <Button.Content><Binding Source="{StaticResource Common.Cancel}"/></Button.Content>
                                </Button>
                                <Button Style="{StaticResource DangerButton}" Command="{Binding ExecuteDeleteCommand}">
                                    <Button.Content><Binding Source="{StaticResource Common.Delete}"/></Button.Content>
                                </Button>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Border>

                <!-- Edit Dialog -->
                <Border Background="{StaticResource DialogOverlayBrush}" Visibility="{Binding IsEditDialogOpen, Converter={StaticResource BoolToVis}}" Panel.ZIndex="100">
                    <Border.InputBindings>
                        <KeyBinding Key="Escape" Command="{Binding CancelEditCommand}"/>
                        <KeyBinding Key="Enter" Command="{Binding ConfirmEditCommand}"/>
                    </Border.InputBindings>
                    <Border Background="{StaticResource DialogBackgroundBrush}" CornerRadius="{StaticResource DialogCornerRadius}" Padding="32" Width="480" VerticalAlignment="Center" HorizontalAlignment="Center">
                        <StackPanel>
                            <TextBlock Style="{StaticResource DialogTitleStyle}">
                                <TextBlock.Text><Binding Source="{StaticResource Assets.EditTitle}"/></TextBlock.Text>
                            </TextBlock>
                            <TextBlock Style="{StaticResource LabelStyle}">
                                <TextBlock.Text><Binding Source="{StaticResource Assets.Name}"/></TextBlock.Text>
                            </TextBlock>
                            <TextBox Text="{Binding NewName, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource InputStyle}" Margin="0,0,0,16"/>
                            <TextBlock Style="{StaticResource LabelStyle}">
                                <TextBlock.Text><Binding Source="{StaticResource Assets.Type}"/></TextBlock.Text>
                            </TextBlock>
                            <ComboBox ItemsSource="{Binding Source={StaticResource AssetTypes}}" SelectedItem="{Binding NewType}" Margin="0,0,0,16"/>
                            <TextBlock Style="{StaticResource LabelStyle}">
                                <TextBlock.Text><Binding Source="{StaticResource Assets.Institution}"/></TextBlock.Text>
                            </TextBlock>
                            <TextBox Text="{Binding NewInstitution, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource InputStyle}" Margin="0,0,0,16"/>
                            <Grid Margin="0,0,0,16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="16"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Style="{StaticResource LabelStyle}">
                                        <TextBlock.Text><Binding Source="{StaticResource Assets.CurrentValue}"/></TextBlock.Text>
                                    </TextBlock>
                                    <TextBox Text="{Binding NewCurrentValue, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource InputStyle}"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Style="{StaticResource LabelStyle}">
                                        <TextBlock.Text><Binding Source="{StaticResource Assets.InitialValue}"/></TextBlock.Text>
                                    </TextBlock>
                                    <TextBox Text="{Binding NewInitialValue, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource InputStyle}"/>
                                </StackPanel>
                            </Grid>
                            <TextBlock Style="{StaticResource LabelStyle}">
                                <TextBlock.Text><Binding Source="{StaticResource Assets.Note}"/></TextBlock.Text>
                            </TextBlock>
                            <TextBox Text="{Binding NewNote, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource InputStyle}" Margin="0,0,0,24"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <Button Style="{StaticResource SecondaryButton}" Command="{Binding CancelEditCommand}" Margin="0,0,12,0">
                                    <Button.Content><Binding Source="{StaticResource Common.Cancel}"/></Button.Content>
                                </Button>
                                <Button Style="{StaticResource PrimaryButton}" Command="{Binding ConfirmEditCommand}">
                                    <Button.Content><Binding Source="{StaticResource Common.Save}"/></Button.Content>
                                </Button>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
