<UserControl x:Class="WealthOS.Presentation.Views.BudgetsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:WealthOS.Presentation.Converters">

    <UserControl.Resources>
        <conv:CurrencyConverter x:Key="CurrencyConv"/>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>

    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="32,24">
            <StackPanel MaxWidth="1200">
                <!-- Header -->
                <Grid Margin="0,0,0,24">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Style="{StaticResource PageTitleStyle}">
                        <TextBlock.Text><Binding Source="{StaticResource Budgets.Title}"/></TextBlock.Text>
                    </TextBlock>
                    <Button Grid.Column="1" Style="{StaticResource PrimaryButton}" Command="{Binding ShowAddCommand}" VerticalAlignment="Center">
                        <Button.Content><Binding Source="{StaticResource Budgets.Add}"/></Button.Content>
                    </Button>
                </Grid>

                <!-- Month Selector -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                    <Button Content="&lt;" Padding="10,6" FontSize="14" Background="Transparent" BorderThickness="1"
                            BorderBrush="{StaticResource BorderBrush}" Cursor="Hand"
                            Command="{Binding ChangeMonthCommand}" CommandParameter="-1"/>
                    <TextBlock Text="{Binding SelectedYear, StringFormat='{}{0}'}" FontSize="16" FontWeight="SemiBold"
                               VerticalAlignment="Center" Margin="12,0"/>
                    <TextBlock Text="{Binding SelectedMonth, StringFormat='{}{0}月'}" FontSize="16" FontWeight="SemiBold"
                               VerticalAlignment="Center" Margin="0,0,12,0"/>
                    <Button Content="&gt;" Padding="10,6" FontSize="14" Background="Transparent" BorderThickness="1"
                            BorderBrush="{StaticResource BorderBrush}" Cursor="Hand"
                            Command="{Binding ChangeMonthCommand}" CommandParameter="1"/>
                </StackPanel>

                <ProgressBar IsIndeterminate="True" Height="3" Margin="0,0,0,16"
                             Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}"
                             Background="Transparent" Foreground="{StaticResource PrimaryBrush}"/>

                <!-- Summary -->
                <Grid Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock FontSize="13" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,8">
                                <TextBlock.Text><Binding Source="{StaticResource Budgets.TotalBudget}"/></TextBlock.Text>
                            </TextBlock>
                            <TextBlock FontSize="28" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}">
                                <TextBlock.Text><Binding Path="TotalBudget" Converter="{StaticResource CurrencyConv}"/></TextBlock.Text>
                            </TextBlock>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="2" Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock FontSize="13" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,8">
                                <TextBlock.Text><Binding Source="{StaticResource Budgets.TotalSpent}"/></TextBlock.Text>
                            </TextBlock>
                            <TextBlock FontSize="28" FontWeight="Bold" Foreground="{StaticResource ExpenseBrush}">
                                <TextBlock.Text><Binding Path="TotalSpent" Converter="{StaticResource CurrencyConv}"/></TextBlock.Text>
                            </TextBlock>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- Empty State -->
                <Border Padding="60" Visibility="{Binding Budgets.Count, Converter={StaticResource BoolToVis}}">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Budgets.Count}" Value="0"><Setter Property="Visibility" Value="Visible"/></DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock FontSize="20" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Center">
                            <TextBlock.Text><Binding Source="{StaticResource Budgets.NoBudgets}"/></TextBlock.Text>
                        </TextBlock>
                    </StackPanel>
                </Border>

                <!-- Budget Cards -->
                <ItemsControl ItemsSource="{Binding Budgets}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Style="{StaticResource CardStyle}" Margin="0,0,16,16" Width="300">
                                <StackPanel>
                                    <Grid Margin="0,0,0,12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding Name}" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}"/>
                                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                                            <Button Content="e" FontSize="14" Background="Transparent" BorderThickness="0"
                                                    Foreground="{StaticResource TextHintBrush}" Cursor="Hand" Padding="4,0"
                                                    Command="{Binding DataContext.ShowEditDialogCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                    CommandParameter="{Binding Id}"/>
                                            <Button Content="x" FontSize="14" Background="Transparent" BorderThickness="0"
                                                    Foreground="{StaticResource TextHintBrush}" Cursor="Hand" Padding="4,0"
                                                    Command="{Binding DataContext.ConfirmDeleteCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                    CommandParameter="{Binding Id}"/>
                                        </StackPanel>
                                    </Grid>

                                    <!-- Progress Bar -->
                                    <Grid Margin="0,0,0,12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <ProgressBar Grid.Column="0" Value="{Binding Progress}" Maximum="100" Height="8"
                                                     Background="{StaticResource SurfaceBrush}" Margin="0,0,12,0">
                                            <ProgressBar.Style>
                                                <Style TargetType="ProgressBar">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsOverBudget}" Value="True">
                                                            <Setter Property="Foreground" Value="{StaticResource ExpenseBrush}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                    <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
                                                </Style>
                                            </ProgressBar.Style>
                                        </ProgressBar>
                                        <TextBlock Grid.Column="1" Text="{Binding Progress, StringFormat='{}{0:F0}%'}" FontSize="13" FontWeight="SemiBold"/>
                                    </Grid>

                                    <!-- Amounts -->
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock FontSize="11" Foreground="{StaticResource TextSecondaryBrush}">
                                                <TextBlock.Text><Binding Source="{StaticResource Budgets.Spent}"/></TextBlock.Text>
                                            </TextBlock>
                                            <TextBlock FontSize="16" FontWeight="Bold">
                                                <TextBlock.Text><Binding Path="Spent" Converter="{StaticResource CurrencyConv}"/></TextBlock.Text>
                                            </TextBlock>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                                            <TextBlock FontSize="11" Foreground="{StaticResource TextSecondaryBrush}">
                                                <TextBlock.Text><Binding Source="{StaticResource Budgets.Remaining}"/></TextBlock.Text>
                                            </TextBlock>
                                            <TextBlock FontSize="16" FontWeight="Bold">
                                                <TextBlock.Text><Binding Path="Remaining" Converter="{StaticResource CurrencyConv}"/></TextBlock.Text>
                                            </TextBlock>
                                        </StackPanel>
                                    </Grid>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Add Dialog -->
                <Border Background="{StaticResource DialogOverlayBrush}" Visibility="{Binding IsAddDialogOpen, Converter={StaticResource BoolToVis}}" Panel.ZIndex="100">
                    <Border Background="{StaticResource DialogBackgroundBrush}" CornerRadius="20" Padding="32" Width="480" VerticalAlignment="Center" HorizontalAlignment="Center">
                        <StackPanel>
                            <TextBlock FontSize="22" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,24">
                                <TextBlock.Text><Binding Source="{StaticResource Budgets.AddTitle}"/></TextBlock.Text>
                            </TextBlock>
                            <TextBlock FontSize="13" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,6">
                                <TextBlock.Text><Binding Source="{StaticResource Budgets.Name}"/></TextBlock.Text>
                            </TextBlock>
                            <TextBox Text="{Binding NewName, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource InputStyle}" Margin="0,0,0,16"/>
                            <Grid Margin="0,0,0,16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="16"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock FontSize="13" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,6">
                                        <TextBlock.Text><Binding Source="{StaticResource Budgets.Amount}"/></TextBlock.Text>
                                    </TextBlock>
                                    <TextBox Text="{Binding NewAmount, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource InputStyle}"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock FontSize="13" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,6">
                                        <TextBlock.Text><Binding Source="{StaticResource Budgets.Spent}"/></TextBlock.Text>
                                    </TextBlock>
                                    <TextBox Text="{Binding NewSpent, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource InputStyle}"/>
                                </StackPanel>
                            </Grid>
                            <TextBlock FontSize="13" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,6">
                                <TextBlock.Text><Binding Source="{StaticResource Budgets.Note}"/></TextBlock.Text>
                            </TextBlock>
                            <TextBox Text="{Binding NewNote, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource InputStyle}" Margin="0,0,0,24"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <Button Style="{StaticResource SecondaryButton}" Command="{Binding CancelAddCommand}" Margin="0,0,12,0">
                                    <Button.Content><Binding Source="{StaticResource Common.Cancel}"/></Button.Content>
                                </Button>
                                <Button Style="{StaticResource PrimaryButton}" Command="{Binding ConfirmAddCommand}">
                                    <Button.Content><Binding Source="{StaticResource Common.Add}"/></Button.Content>
                                </Button>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Border>

                <!-- Edit Dialog -->
                <Border Background="{StaticResource DialogOverlayBrush}" Visibility="{Binding IsEditDialogOpen, Converter={StaticResource BoolToVis}}" Panel.ZIndex="100">
                    <Border Background="{StaticResource DialogBackgroundBrush}" CornerRadius="20" Padding="32" Width="480" VerticalAlignment="Center" HorizontalAlignment="Center">
                        <StackPanel>
                            <TextBlock FontSize="22" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,24">
                                <TextBlock.Text><Binding Source="{StaticResource Budgets.EditTitle}"/></TextBlock.Text>
                            </TextBlock>
                            <TextBlock FontSize="13" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,6">
                                <TextBlock.Text><Binding Source="{StaticResource Budgets.Name}"/></TextBlock.Text>
                            </TextBlock>
                            <TextBox Text="{Binding NewName, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource InputStyle}" Margin="0,0,0,16"/>
                            <Grid Margin="0,0,0,16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="16"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock FontSize="13" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,6">
                                        <TextBlock.Text><Binding Source="{StaticResource Budgets.Amount}"/></TextBlock.Text>
                                    </TextBlock>
                                    <TextBox Text="{Binding NewAmount, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource InputStyle}"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock FontSize="13" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,6">
                                        <TextBlock.Text><Binding Source="{StaticResource Budgets.Spent}"/></TextBlock.Text>
                                    </TextBlock>
                                    <TextBox Text="{Binding NewSpent, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource InputStyle}"/>
                                </StackPanel>
                            </Grid>
                            <TextBlock FontSize="13" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,6">
                                <TextBlock.Text><Binding Source="{StaticResource Budgets.Note}"/></TextBlock.Text>
                            </TextBlock>
                            <TextBox Text="{Binding NewNote, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource InputStyle}" Margin="0,0,0,24"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <Button Style="{StaticResource SecondaryButton}" Command="{Binding CancelEditCommand}" Margin="0,0,12,0">
                                    <Button.Content><Binding Source="{StaticResource Common.Cancel}"/></Button.Content>
                                </Button>
                                <Button Style="{StaticResource PrimaryButton}" Command="{Binding ConfirmEditCommand}">
                                    <Button.Content><Binding Source="{StaticResource Common.Save}"/></Button.Content>
                                </Button>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Border>

                <!-- Delete Confirmation -->
                <Border Background="{StaticResource DialogOverlayBrush}" Visibility="{Binding IsConfirmDeleteOpen, Converter={StaticResource BoolToVis}}" Panel.ZIndex="100">
                    <Border Background="{StaticResource DialogBackgroundBrush}" CornerRadius="20" Padding="32" Width="400" VerticalAlignment="Center" HorizontalAlignment="Center">
                        <StackPanel>
                            <TextBlock FontSize="22" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,12">
                                <TextBlock.Text><Binding Source="{StaticResource Budgets.DeleteTitle}"/></TextBlock.Text>
                            </TextBlock>
                            <TextBlock FontSize="14" Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap" Margin="0,0,0,24">
                                <TextBlock.Text><Binding Source="{StaticResource Budgets.DeleteMessage}"/></TextBlock.Text>
                            </TextBlock>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <Button Style="{StaticResource SecondaryButton}" Command="{Binding CancelDeleteCommand}" Margin="0,0,12,0">
                                    <Button.Content><Binding Source="{StaticResource Common.Cancel}"/></Button.Content>
                                </Button>
                                <Button Style="{StaticResource PrimaryButton}" Command="{Binding ExecuteDeleteCommand}" Background="{StaticResource ExpenseBrush}">
                                    <Button.Content><Binding Source="{StaticResource Common.Delete}"/></Button.Content>
                                </Button>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
