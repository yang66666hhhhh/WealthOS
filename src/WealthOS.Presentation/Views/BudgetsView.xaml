<UserControl x:Class="WealthOS.Presentation.Views.BudgetsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:WealthOS.Presentation.Converters">

    <UserControl.Resources>
        <conv:CurrencyConverter x:Key="CurrencyConv"/>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>

    <Grid>
        <Border Background="{StaticResource PrimaryBrush}" 
                Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}"
                Panel.ZIndex="50" HorizontalAlignment="Stretch" VerticalAlignment="Top" Height="3"/>

        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="28,24">
            <StackPanel MaxWidth="1200">
                <!-- 页面标题 -->
                <Grid Margin="0,0,0,24">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="{DynamicResource Budgets.Title}" FontSize="24" FontWeight="Bold" 
                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                        <!-- 月份选择器 -->
                        <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                            <Button Content="&#x276E;" Padding="8,4" FontSize="12" Cursor="Hand"
                                    Style="{StaticResource GhostButton}"
                                    Command="{Binding ChangeMonthCommand}" CommandParameter="-1"/>
                            <TextBlock FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}"
                                       VerticalAlignment="Center" Margin="8,0">
                                <Run Text="{Binding SelectedYear, Mode=OneWay}"/>
                                <Run Text="年"/>
                                <Run Text="{Binding SelectedMonth, Mode=OneWay}"/>
                                <Run Text="月"/>
                            </TextBlock>
                            <Button Content="&#x276F;" Padding="8,4" FontSize="12" Cursor="Hand"
                                    Style="{StaticResource GhostButton}"
                                    Command="{Binding ChangeMonthCommand}" CommandParameter="1"/>
                        </StackPanel>
                    </StackPanel>
                    <Button Grid.Column="1" Style="{StaticResource PrimaryButton}" Command="{Binding ShowAddDialogCommand}" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#x2795;" FontSize="14" Margin="0,0,8,0"/>
                            <TextBlock Text="{DynamicResource Budgets.Add}"/>
                        </StackPanel>
                    </Button>
                </Grid>

                <!-- KPI 统计卡片 -->
                <Grid Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- 预算总额 -->
                    <Border Grid.Column="0" CornerRadius="14" Padding="20,16"
                            BorderThickness="1" BorderBrush="{StaticResource BorderBrush}"
                            Background="{StaticResource CardBackgroundBrush}">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                <Border Width="36" Height="36" CornerRadius="10" Margin="0,0,12,0">
                                    <Border.Background>
                                        <SolidColorBrush Color="#EFF6FF"/>
                                    </Border.Background>
                                    <TextBlock Text="&#x1F4CB;" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="{DynamicResource Budgets.TotalBudget}" FontSize="12" 
                                           Foreground="{StaticResource TextTertiaryBrush}" VerticalAlignment="Center"/>
                            </StackPanel>
                            <TextBlock FontSize="22" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}">
                                <TextBlock.Text><Binding Path="TotalBudget" Converter="{StaticResource CurrencyConv}"/></TextBlock.Text>
                            </TextBlock>
                        </StackPanel>
                    </Border>

                    <!-- 已花费 -->
                    <Border Grid.Column="2" CornerRadius="14" Padding="20,16"
                            BorderThickness="1" BorderBrush="{StaticResource BorderBrush}"
                            Background="{StaticResource CardBackgroundBrush}">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                <Border Width="36" Height="36" CornerRadius="10" Margin="0,0,12,0">
                                    <Border.Background>
                                        <SolidColorBrush Color="#FEF2F2"/>
                                    </Border.Background>
                                    <TextBlock Text="&#x1F4B8;" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="{DynamicResource Budgets.TotalSpent}" FontSize="12" 
                                           Foreground="{StaticResource TextTertiaryBrush}" VerticalAlignment="Center"/>
                            </StackPanel>
                            <TextBlock FontSize="22" FontWeight="Bold" Foreground="{StaticResource ExpenseBrush}">
                                <TextBlock.Text><Binding Path="TotalSpent" Converter="{StaticResource CurrencyConv}"/></TextBlock.Text>
                            </TextBlock>
                        </StackPanel>
                    </Border>

                    <!-- 剩余预算 -->
                    <Border Grid.Column="4" CornerRadius="14" Padding="20,16"
                            BorderThickness="1" BorderBrush="{StaticResource BorderBrush}"
                            Background="{StaticResource CardBackgroundBrush}">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                <Border Width="36" Height="36" CornerRadius="10" Margin="0,0,12,0">
                                    <Border.Background>
                                        <SolidColorBrush Color="#ECFDF5"/>
                                    </Border.Background>
                                    <TextBlock Text="&#x1F4B0;" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="{DynamicResource Budgets.Remaining}" FontSize="12" 
                                           Foreground="{StaticResource TextTertiaryBrush}" VerticalAlignment="Center"/>
                            </StackPanel>
                            <TextBlock FontSize="22" FontWeight="Bold" Foreground="{StaticResource AccentBrush}">
                                <TextBlock.Text><Binding Path="TotalRemaining" Converter="{StaticResource CurrencyConv}"/></TextBlock.Text>
                            </TextBlock>
                        </StackPanel>
                    </Border>

                    <!-- 执行率 -->
                    <Border Grid.Column="6" CornerRadius="14" Padding="20,16"
                            BorderThickness="1" BorderBrush="{StaticResource BorderBrush}"
                            Background="{StaticResource CardBackgroundBrush}">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                <Border Width="36" Height="36" CornerRadius="10" Margin="0,0,12,0">
                                    <Border.Background>
                                        <SolidColorBrush Color="#EEF2FF"/>
                                    </Border.Background>
                                    <TextBlock Text="&#x1F3AF;" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="{DynamicResource Budgets.ExecutionRate}" FontSize="12" 
                                           Foreground="{StaticResource TextTertiaryBrush}" VerticalAlignment="Center"/>
                            </StackPanel>
                            <TextBlock FontSize="22" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}">
                                <TextBlock.Text><Binding Path="ExecutionRate" StringFormat="{}{0:F1}%"/></TextBlock.Text>
                            </TextBlock>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- 总体进度条 -->
                <Border CornerRadius="14" Padding="20" Margin="0,0,0,20"
                        BorderThickness="1" BorderBrush="{StaticResource BorderBrush}"
                        Background="{StaticResource CardBackgroundBrush}">
                    <StackPanel>
                        <Grid Margin="0,0,0,12">
                            <TextBlock Text="{DynamicResource Budgets.OverallProgress}" FontSize="14" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}"/>
                            <TextBlock HorizontalAlignment="Right" FontSize="14" FontWeight="Bold">
                                <Run Text="{Binding TotalSpent, Mode=OneWay, Converter={StaticResource CurrencyConv}}"/>
                                <Run Text=" / " Foreground="{StaticResource TextTertiaryBrush}"/>
                                <Run Text="{Binding TotalBudget, Mode=OneWay, Converter={StaticResource CurrencyConv}}"/>
                            </TextBlock>
                        </Grid>
                        <ProgressBar Value="{Binding TotalProgress}" Maximum="100" Height="10"
                                     Background="{StaticResource SurfaceBrush}" Foreground="{StaticResource PrimaryBrush}"/>
                    </StackPanel>
                </Border>

                <!-- 空状态 -->
                <Border Padding="60" Visibility="{Binding Budgets.Count, Converter={StaticResource BoolToVis}}">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Budgets.Count}" Value="0"><Setter Property="Visibility" Value="Visible"/></DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Style="{StaticResource EmptyStateIconStyle}" Text="&#x1F4CB;"/>
                        <TextBlock Style="{StaticResource EmptyStateTitleStyle}">
                            <TextBlock.Text><Binding Source="{StaticResource Budgets.NoBudgets}"/></TextBlock.Text>
                        </TextBlock>
                    </StackPanel>
                </Border>

                <!-- 分类预算列表 -->
                <ItemsControl ItemsSource="{Binding Budgets}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border CornerRadius="14" Padding="20" Margin="0,0,16,16" Width="350"
                                    BorderThickness="1" BorderBrush="{StaticResource BorderBrush}"
                                    Background="{StaticResource CardBackgroundBrush}">
                                <StackPanel>
                                    <!-- 标题行 -->
                                    <Grid Margin="0,0,0,16">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" Orientation="Horizontal">
                                            <Border Width="32" Height="32" CornerRadius="8" Margin="0,0,10,0">
                                                <Border.Background>
                                                    <SolidColorBrush Color="#EEF2FF"/>
                                                </Border.Background>
                                                <TextBlock Text="&#x1F4CB;" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <TextBlock Text="{Binding Name}" FontSize="15" FontWeight="SemiBold" 
                                                       Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                                            <Button Content="&#x270E;" FontSize="14" Background="Transparent" BorderThickness="0" 
                                                    Foreground="{StaticResource TextTertiaryBrush}" Cursor="Hand" Padding="6,2"
                                                    Command="{Binding DataContext.ShowEditDialogCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                    CommandParameter="{Binding Id}"/>
                                            <Button Content="&#x2716;" FontSize="12" Background="Transparent" BorderThickness="0" 
                                                    Foreground="{StaticResource TextHintBrush}" Cursor="Hand" Padding="6,2"
                                                    Command="{Binding DataContext.ConfirmDeleteCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                    CommandParameter="{Binding Id}"/>
                                        </StackPanel>
                                    </Grid>

                                    <!-- 进度条 -->
                                    <Grid Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <ProgressBar Grid.Column="0" Value="{Binding Progress}" Maximum="100" Height="8"
                                                     Background="{StaticResource SurfaceBrush}" Margin="0,0,12,0">
                                            <ProgressBar.Style>
                                                <Style TargetType="ProgressBar">
                                                    <Setter Property="Foreground" Value="{StaticResource PrimaryBrush}"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsOverBudget}" Value="True">
                                                            <Setter Property="Foreground" Value="{StaticResource ExpenseBrush}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </ProgressBar.Style>
                                        </ProgressBar>
                                        <TextBlock Grid.Column="1" Text="{Binding Progress, StringFormat='{}{0:F0}%'}" 
                                                   FontSize="13" FontWeight="Bold" VerticalAlignment="Center">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="{StaticResource PrimaryBrush}"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsOverBudget}" Value="True">
                                                            <Setter Property="Foreground" Value="{StaticResource ExpenseBrush}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Grid>

                                    <!-- 金额详情 -->
                                    <Grid Margin="0,8,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock FontSize="11" Foreground="{StaticResource TextTertiaryBrush}">
                                                <TextBlock.Text><Binding Source="{StaticResource Budgets.Spent}"/></TextBlock.Text>
                                            </TextBlock>
                                            <TextBlock FontSize="16" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}">
                                                <TextBlock.Text><Binding Path="Spent" Converter="{StaticResource CurrencyConv}"/></TextBlock.Text>
                                            </TextBlock>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                                            <TextBlock FontSize="11" Foreground="{StaticResource TextTertiaryBrush}">
                                                <TextBlock.Text><Binding Source="{StaticResource Budgets.Remaining}"/></TextBlock.Text>
                                            </TextBlock>
                                            <TextBlock FontSize="16" FontWeight="Bold">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsOverBudget}" Value="True">
                                                                <Setter Property="Foreground" Value="{StaticResource ExpenseBrush}"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                        <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
                                                    </Style>
                                                </TextBlock.Style>
                                                <TextBlock.Text><Binding Path="Remaining" Converter="{StaticResource CurrencyConv}"/></TextBlock.Text>
                                            </TextBlock>
                                        </StackPanel>
                                    </Grid>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Add Dialog -->
                <Border Background="{StaticResource DialogOverlayBrush}" Visibility="{Binding IsAddDialogOpen, Converter={StaticResource BoolToVis}}" Panel.ZIndex="100">
                    <Border Background="{StaticResource DialogBackgroundBrush}" CornerRadius="16" Padding="28" Width="440" VerticalAlignment="Center" HorizontalAlignment="Center">
                        <StackPanel>
                            <TextBlock Style="{StaticResource DialogTitleStyle}">
                                <TextBlock.Text><Binding Source="{StaticResource Budgets.AddTitle}"/></TextBlock.Text>
                            </TextBlock>
                            <TextBlock Style="{StaticResource LabelStyle}">
                                <TextBlock.Text><Binding Source="{StaticResource Budgets.Name}"/></TextBlock.Text>
                            </TextBlock>
                            <TextBox Text="{Binding NewName, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource InputStyle}" Margin="0,0,0,16"/>
                            <Grid Margin="0,0,0,16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="12"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Style="{StaticResource LabelStyle}">
                                        <TextBlock.Text><Binding Source="{StaticResource Budgets.Amount}"/></TextBlock.Text>
                                    </TextBlock>
                                    <TextBox Text="{Binding NewAmount, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource InputStyle}"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Style="{StaticResource LabelStyle}">
                                        <TextBlock.Text><Binding Source="{StaticResource Budgets.Spent}"/></TextBlock.Text>
                                    </TextBlock>
                                    <TextBox Text="{Binding NewSpent, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource InputStyle}"/>
                                </StackPanel>
                            </Grid>
                            <TextBlock Style="{StaticResource LabelStyle}">
                                <TextBlock.Text><Binding Source="{StaticResource Budgets.Note}"/></TextBlock.Text>
                            </TextBlock>
                            <TextBox Text="{Binding NewNote, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource InputStyle}" Margin="0,0,0,24"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <Button Style="{StaticResource SecondaryButton}" Command="{Binding CancelAddCommand}" Margin="0,0,12,0">
                                    <Button.Content><Binding Source="{StaticResource Common.Cancel}"/></Button.Content>
                                </Button>
                                <Button Style="{StaticResource PrimaryButton}" Command="{Binding ConfirmAddCommand}">
                                    <Button.Content><Binding Source="{StaticResource Common.Add}"/></Button.Content>
                                </Button>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Border>

                <!-- Edit Dialog -->
                <Border Background="{StaticResource DialogOverlayBrush}" Visibility="{Binding IsEditDialogOpen, Converter={StaticResource BoolToVis}}" Panel.ZIndex="100">
                    <Border Background="{StaticResource DialogBackgroundBrush}" CornerRadius="16" Padding="28" Width="440" VerticalAlignment="Center" HorizontalAlignment="Center">
                        <StackPanel>
                            <TextBlock Style="{StaticResource DialogTitleStyle}">
                                <TextBlock.Text><Binding Source="{StaticResource Budgets.EditTitle}"/></TextBlock.Text>
                            </TextBlock>
                            <TextBlock Style="{StaticResource LabelStyle}">
                                <TextBlock.Text><Binding Source="{StaticResource Budgets.Name}"/></TextBlock.Text>
                            </TextBlock>
                            <TextBox Text="{Binding NewName, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource InputStyle}" Margin="0,0,0,16"/>
                            <Grid Margin="0,0,0,16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="12"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Style="{StaticResource LabelStyle}">
                                        <TextBlock.Text><Binding Source="{StaticResource Budgets.Amount}"/></TextBlock.Text>
                                    </TextBlock>
                                    <TextBox Text="{Binding NewAmount, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource InputStyle}"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Style="{StaticResource LabelStyle}">
                                        <TextBlock.Text><Binding Source="{StaticResource Budgets.Spent}"/></TextBlock.Text>
                                    </TextBlock>
                                    <TextBox Text="{Binding NewSpent, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource InputStyle}"/>
                                </StackPanel>
                            </Grid>
                            <TextBlock Style="{StaticResource LabelStyle}">
                                <TextBlock.Text><Binding Source="{StaticResource Budgets.Note}"/></TextBlock.Text>
                            </TextBlock>
                            <TextBox Text="{Binding NewNote, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource InputStyle}" Margin="0,0,0,24"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <Button Style="{StaticResource SecondaryButton}" Command="{Binding CancelEditCommand}" Margin="0,0,12,0">
                                    <Button.Content><Binding Source="{StaticResource Common.Cancel}"/></Button.Content>
                                </Button>
                                <Button Style="{StaticResource PrimaryButton}" Command="{Binding ConfirmEditCommand}">
                                    <Button.Content><Binding Source="{StaticResource Common.Save}"/></Button.Content>
                                </Button>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Border>

                <!-- Delete Confirmation -->
                <Border Background="{StaticResource DialogOverlayBrush}" Visibility="{Binding IsConfirmDeleteOpen, Converter={StaticResource BoolToVis}}" Panel.ZIndex="100">
                    <Border Background="{StaticResource DialogBackgroundBrush}" CornerRadius="16" Padding="28" Width="400" VerticalAlignment="Center" HorizontalAlignment="Center">
                        <StackPanel>
                            <TextBlock Style="{StaticResource DialogTitleStyle}">
                                <TextBlock.Text><Binding Source="{StaticResource Budgets.DeleteTitle}"/></TextBlock.Text>
                            </TextBlock>
                            <TextBlock FontSize="13" Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap" Margin="0,0,0,24">
                                <TextBlock.Text><Binding Source="{StaticResource Budgets.DeleteMessage}"/></TextBlock.Text>
                            </TextBlock>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <Button Style="{StaticResource SecondaryButton}" Command="{Binding CancelDeleteCommand}" Margin="0,0,12,0">
                                    <Button.Content><Binding Source="{StaticResource Common.Cancel}"/></Button.Content>
                                </Button>
                                <Button Style="{StaticResource DangerButton}" Command="{Binding ExecuteDeleteCommand}">
                                    <Button.Content><Binding Source="{StaticResource Common.Delete}"/></Button.Content>
                                </Button>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Border>

                <Border Height="20"/>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
