<UserControl x:Class="WealthOS.Presentation.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
             xmlns:conv="clr-namespace:WealthOS.Presentation.Converters"
             xmlns:views="clr-namespace:WealthOS.Presentation.Views">

    <UserControl.Resources>
        <conv:CurrencyConverter x:Key="CurrencyConv"/>
        <conv:TransactionSignMultiConverter x:Key="SignConv"/>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>

    <Grid>
        <Border Background="{StaticResource PrimaryBrush}" 
                Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}"
                Panel.ZIndex="50" HorizontalAlignment="Stretch" VerticalAlignment="Top" Height="3"/>

        <views:ErrorBanner DataContext="{Binding}"/>

        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="28,24">
            <StackPanel MaxWidth="1200">

                <!-- 页面标题 -->
                <Grid Margin="0,0,0,24">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Style="{StaticResource PageTitleStyle}">
                            <TextBlock.Text><Binding Source="{StaticResource Dashboard.Title}"/></TextBlock.Text>
                        </TextBlock>
                        <TextBlock FontSize="13" Foreground="{StaticResource TextTertiaryBrush}" Margin="0,4,0,0">
                            <Run Text="&#x1F44B; "/>
                            <Run Text="{DynamicResource Dashboard.Welcome}"/>
                        </TextBlock>
                    </StackPanel>
                    <TextBlock Grid.Column="1" FontSize="13" Foreground="{StaticResource TextTertiaryBrush}" 
                               VerticalAlignment="Bottom" Text="{Binding CurrentDate}"/>
                </Grid>

                <!-- KPI 指标卡 - 四个横排 -->
                <Grid Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- 总资产 -->
                    <Border Grid.Column="0" CornerRadius="14" Padding="20,16"
                            BorderThickness="1" BorderBrush="{StaticResource BorderBrush}"
                            Background="{StaticResource CardBackgroundBrush}">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                <Border Width="36" Height="36" CornerRadius="{StaticResource IconCornerRadius}" Margin="0,0,12,0">
                                    <Border.Background>
                                        <SolidColorBrush Color="{StaticResource IconBgBlueColor}"/>
                                    </Border.Background>
                                    <TextBlock Text="&#x1F4BC;" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="{DynamicResource Dashboard.TotalAssets}" FontSize="13" 
                                           Foreground="{StaticResource TextTertiaryBrush}" VerticalAlignment="Center"/>
                            </StackPanel>
                            <TextBlock FontSize="24" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}">
                                <TextBlock.Text>
                                    <Binding Path="Dashboard.TotalAssets" Converter="{StaticResource CurrencyConv}"/>
                                </TextBlock.Text>
                            </TextBlock>
                        </StackPanel>
                    </Border>

                    <!-- 净资产 -->
                    <Border Grid.Column="2" CornerRadius="14" Padding="20,16"
                            BorderThickness="1" BorderBrush="{StaticResource BorderBrush}"
                            Background="{StaticResource CardBackgroundBrush}">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                <Border Width="36" Height="36" CornerRadius="{StaticResource IconCornerRadius}" Margin="0,0,12,0">
                                    <Border.Background>
                                        <SolidColorBrush Color="{StaticResource IconBgGreenColor}"/>
                                    </Border.Background>
                                    <TextBlock Text="&#x1F4B0;" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="{DynamicResource Dashboard.NetWorth}" FontSize="13" 
                                           Foreground="{StaticResource TextTertiaryBrush}" VerticalAlignment="Center"/>
                            </StackPanel>
                            <TextBlock FontSize="24" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}">
                                <TextBlock.Text>
                                    <Binding Path="Dashboard.NetWorth" Converter="{StaticResource CurrencyConv}"/>
                                </TextBlock.Text>
                            </TextBlock>
                            <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                <Border CornerRadius="4" Padding="6,2" Margin="0,0,8,0">
                                    <Border.Background>
                                        <SolidColorBrush Color="{StaticResource IconBgGreenColor}"/>
                                    </Border.Background>
                                    <TextBlock FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource AccentBrush}">
                                        <TextBlock.Text>
                                            <Binding Path="Dashboard.NetWorthChange" Converter="{StaticResource CurrencyConv}"/>
                                        </TextBlock.Text>
                                    </TextBlock>
                                </Border>
                                <TextBlock Text="{DynamicResource Dashboard.ThisMonth}" FontSize="11" 
                                           Foreground="{StaticResource TextTertiaryBrush}" VerticalAlignment="Center"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- 本月收入 -->
                    <Border Grid.Column="4" CornerRadius="14" Padding="20,16"
                            BorderThickness="1" BorderBrush="{StaticResource BorderBrush}"
                            Background="{StaticResource CardBackgroundBrush}">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                <Border Width="36" Height="36" CornerRadius="{StaticResource IconCornerRadius}" Margin="0,0,12,0">
                                    <Border.Background>
                                        <SolidColorBrush Color="{StaticResource IconBgGreenColor}"/>
                                    </Border.Background>
                                    <TextBlock Text="&#x2191;" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center"
                                               Foreground="{StaticResource IncomeBrush}"/>
                                </Border>
                                <TextBlock Text="{DynamicResource Dashboard.MonthIncome}" FontSize="13" 
                                           Foreground="{StaticResource TextTertiaryBrush}" VerticalAlignment="Center"/>
                            </StackPanel>
                            <TextBlock FontSize="24" FontWeight="Bold" Foreground="{StaticResource IncomeBrush}">
                                <TextBlock.Text>
                                    <Binding Path="Dashboard.MonthIncome" Converter="{StaticResource CurrencyConv}"/>
                                </TextBlock.Text>
                            </TextBlock>
                        </StackPanel>
                    </Border>

                    <!-- 本月支出 -->
                    <Border Grid.Column="6" CornerRadius="14" Padding="20,16"
                            BorderThickness="1" BorderBrush="{StaticResource BorderBrush}"
                            Background="{StaticResource CardBackgroundBrush}">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                <Border Width="36" Height="36" CornerRadius="{StaticResource IconCornerRadius}" Margin="0,0,12,0">
                                    <Border.Background>
                                        <SolidColorBrush Color="{StaticResource IconBgRedColor}"/>
                                    </Border.Background>
                                    <TextBlock Text="&#x2193;" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center"
                                               Foreground="{StaticResource ExpenseBrush}"/>
                                </Border>
                                <TextBlock Text="{DynamicResource Dashboard.MonthExpense}" FontSize="13" 
                                           Foreground="{StaticResource TextTertiaryBrush}" VerticalAlignment="Center"/>
                            </StackPanel>
                            <TextBlock FontSize="24" FontWeight="Bold" Foreground="{StaticResource ExpenseBrush}">
                                <TextBlock.Text>
                                    <Binding Path="Dashboard.MonthExpense" Converter="{StaticResource CurrencyConv}"/>
                                </TextBlock.Text>
                            </TextBlock>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- 中部：图表区域 -->
                <Grid Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- 资产趋势图 -->
                    <Border Grid.Column="0" CornerRadius="14" Padding="20"
                            BorderThickness="1" BorderBrush="{StaticResource BorderBrush}"
                            Background="{StaticResource CardBackgroundBrush}">
                        <StackPanel>
                            <Grid Margin="0,0,0,16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{DynamicResource Dashboard.NetWorthTrend}" 
                                           FontSize="15" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}"/>
                                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                    <Button Content="30d" Margin="4,0" Padding="10,4" FontSize="11" Cursor="Hand"
                                            Command="{Binding SetTimeRangeCommand}" CommandParameter="30d">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource SecondaryButton}">
                                                <Setter Property="Padding" Value="10,4"/>
                                                <Setter Property="FontSize" Value="11"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding SelectedTimeRange}" Value="0">
                                                        <Setter Property="Background" Value="{StaticResource PrimaryBrush}"/>
                                                        <Setter Property="Foreground" Value="White"/>
                                                        <Setter Property="BorderThickness" Value="0"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                    <Button Content="90d" Margin="4,0" Padding="10,4" FontSize="11" Cursor="Hand"
                                            Command="{Binding SetTimeRangeCommand}" CommandParameter="90d">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource SecondaryButton}">
                                                <Setter Property="Padding" Value="10,4"/>
                                                <Setter Property="FontSize" Value="11"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding SelectedTimeRange}" Value="1">
                                                        <Setter Property="Background" Value="{StaticResource PrimaryBrush}"/>
                                                        <Setter Property="Foreground" Value="White"/>
                                                        <Setter Property="BorderThickness" Value="0"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                    <Button Content="1y" Margin="4,0" Padding="10,4" FontSize="11" Cursor="Hand"
                                            Command="{Binding SetTimeRangeCommand}" CommandParameter="1y">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource SecondaryButton}">
                                                <Setter Property="Padding" Value="10,4"/>
                                                <Setter Property="FontSize" Value="11"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding SelectedTimeRange}" Value="2">
                                                        <Setter Property="Background" Value="{StaticResource PrimaryBrush}"/>
                                                        <Setter Property="Foreground" Value="White"/>
                                                        <Setter Property="BorderThickness" Value="0"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                </StackPanel>
                            </Grid>
                            <lvc:CartesianChart Series="{Binding NetWorthSeries}"
                                                XAxes="{Binding NetWorthXAxes}"
                                                YAxes="{Binding NetWorthYAxes}"
                                                Height="240"/>
                        </StackPanel>
                    </Border>

                    <!-- 资产配置饼图 -->
                    <Border Grid.Column="2" CornerRadius="14" Padding="20"
                            BorderThickness="1" BorderBrush="{StaticResource BorderBrush}"
                            Background="{StaticResource CardBackgroundBrush}">
                        <StackPanel>
                            <Grid Margin="0,0,0,16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{DynamicResource Dashboard.AssetAllocation}" 
                                           FontSize="15" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                                <Button Grid.Column="1" Content="{DynamicResource Dashboard.ViewAll}" FontSize="12" 
                                           Foreground="{StaticResource PrimaryBrush}" VerticalAlignment="Center" Cursor="Hand"
                                           Command="{Binding NavigateToAssetsCommand}"
                                           Background="Transparent" BorderThickness="0" Padding="0"/>
                            </Grid>
                            <lvc:PieChart Series="{Binding AssetSeries}" Height="240" LegendPosition="Bottom"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- 底部：最近交易 + 快捷操作 -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- 最近交易 -->
                    <Border Grid.Column="0" CornerRadius="14" Padding="0"
                            BorderThickness="1" BorderBrush="{StaticResource BorderBrush}"
                            Background="{StaticResource CardBackgroundBrush}">
                        <StackPanel>
                            <Grid Margin="20,16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{DynamicResource Dashboard.RecentTransactions}" 
                                           FontSize="15" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}"/>
                                <Button Grid.Column="1" Content="{DynamicResource Dashboard.ViewAll}" FontSize="12" 
                                           Foreground="{StaticResource PrimaryBrush}" VerticalAlignment="Center" Cursor="Hand"
                                           Command="{Binding NavigateToTransactionsCommand}"
                                           Background="Transparent" BorderThickness="0" Padding="0"/>
                            </Grid>

                            <Border Padding="40,20">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Dashboard.RecentTransactions.Count}" Value="0">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock Text="&#x1F4CB;" FontSize="32" HorizontalAlignment="Center" Opacity="0.3" Margin="0,0,0,8"/>
                                    <TextBlock Text="{DynamicResource Dashboard.NoTransactions}" FontSize="14" 
                                               Foreground="{StaticResource TextTertiaryBrush}" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Border>

                            <ItemsControl ItemsSource="{Binding Dashboard.RecentTransactions}" MaxHeight="300">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Padding="16,10" BorderThickness="0,0,0,1" BorderBrush="{StaticResource BorderLightBrush}">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <Border Grid.Column="0" Width="36" Height="36" CornerRadius="8" Margin="0,0,12,0">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Type}" Value="Income">
                                                                    <Setter Property="Background" Value="{StaticResource IncomeLightBrush}"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Type}" Value="Expense">
                                                                    <Setter Property="Background" Value="{StaticResource ExpenseLightBrush}"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Type}" Value="Transfer">
                                                                    <Setter Property="Background" Value="{StaticResource TransferLightBrush}"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="14">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding Type}" Value="Income">
                                                                        <Setter Property="Text" Value="&#x2191;"/>
                                                                        <Setter Property="Foreground" Value="{StaticResource IncomeBrush}"/>
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding Type}" Value="Expense">
                                                                        <Setter Property="Text" Value="&#x2193;"/>
                                                                        <Setter Property="Foreground" Value="{StaticResource ExpenseBrush}"/>
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding Type}" Value="Transfer">
                                                                        <Setter Property="Text" Value="&#x2194;"/>
                                                                        <Setter Property="Foreground" Value="{StaticResource TransferBrush}"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </Border>
                                                <StackPanel Grid.Column="1">
                                                    <TextBlock Text="{Binding Note, FallbackValue='Transaction'}"
                                                               FontSize="13" FontWeight="Medium" Foreground="{StaticResource TextPrimaryBrush}"/>
                                                    <TextBlock FontSize="11" Foreground="{StaticResource TextTertiaryBrush}" Margin="0,2,0,0">
                                                        <Run Text="{Binding AccountName}"/>
                                                        <Run Text=" · "/>
                                                        <Run Text="{Binding OccurredAt, StringFormat='MM/dd'}"/>
                                                    </TextBlock>
                                                </StackPanel>
                                                <TextBlock Grid.Column="2" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Type}" Value="Income">
                                                                    <Setter Property="Foreground" Value="{StaticResource IncomeBrush}"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Type}" Value="Expense">
                                                                    <Setter Property="Foreground" Value="{StaticResource ExpenseBrush}"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Type}" Value="Transfer">
                                                                    <Setter Property="Foreground" Value="{StaticResource TransferBrush}"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                    <TextBlock.Text>
                                                        <MultiBinding Converter="{StaticResource SignConv}">
                                                            <Binding Path="Type"/>
                                                            <Binding Path="Amount"/>
                                                        </MultiBinding>
                                                    </TextBlock.Text>
                                                </TextBlock>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <!-- 右侧：财务健康度 + 快捷操作 -->
                    <StackPanel Grid.Column="2">
                        <!-- 财务健康度 -->
                        <Border CornerRadius="14" Padding="20" Margin="0,0,0,16"
                                BorderThickness="1" BorderBrush="{StaticResource BorderBrush}"
                                Background="{StaticResource CardBackgroundBrush}">
                            <StackPanel>
                                <Grid Margin="0,0,0,16">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{DynamicResource Dashboard.FinancialHealth}" 
                                               FontSize="15" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                                    <Button Grid.Column="1" Content="{DynamicResource Dashboard.ViewAll}" FontSize="12" 
                                               Foreground="{StaticResource PrimaryBrush}" VerticalAlignment="Center" Cursor="Hand"
                                               Command="{Binding NavigateToAnalyticsCommand}"
                                               Background="Transparent" BorderThickness="0" Padding="0"/>
                                </Grid>
                                <!-- 储蓄率 -->
                                <StackPanel Margin="0,0,0,16">
                                    <Grid Margin="0,0,0,6">
                                        <TextBlock Text="{DynamicResource Dashboard.SavingsRate}" FontSize="12" 
                                                   Foreground="{StaticResource TextTertiaryBrush}"/>
                                        <TextBlock HorizontalAlignment="Right" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource AccentBrush}">
                                            <TextBlock.Text>
                                                <Binding Path="Dashboard.SavingsRate" StringFormat="{}{0:F1}%"/>
                                            </TextBlock.Text>
                                        </TextBlock>
                                    </Grid>
                                    <ProgressBar Value="{Binding Dashboard.SavingsRate}" Maximum="100" Height="6"
                                                 Background="{StaticResource SurfaceBrush}" Foreground="{StaticResource AccentBrush}"/>
                                </StackPanel>
                                <!-- 负债率 -->
                                <StackPanel>
                                    <Grid Margin="0,0,0,6">
                                        <TextBlock Text="{DynamicResource Dashboard.DebtRatio}" FontSize="12" 
                                                   Foreground="{StaticResource TextTertiaryBrush}"/>
                                        <TextBlock HorizontalAlignment="Right" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource ExpenseBrush}">
                                            <TextBlock.Text>
                                                <Binding Path="Dashboard.DebtRatio" StringFormat="{}{0:F1}%"/>
                                            </TextBlock.Text>
                                        </TextBlock>
                                    </Grid>
                                    <ProgressBar Value="{Binding Dashboard.DebtRatio}" Maximum="100" Height="6"
                                                 Background="{StaticResource SurfaceBrush}" Foreground="{StaticResource ExpenseBrush}"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- 快捷操作 -->
                        <Border CornerRadius="14" Padding="20"
                                BorderThickness="1" BorderBrush="{StaticResource BorderBrush}"
                                Background="{StaticResource CardBackgroundBrush}">
                            <StackPanel>
                                <TextBlock Text="{DynamicResource Dashboard.QuickActions}" 
                                           FontSize="15" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,12"/>
                                <Button Style="{StaticResource PrimaryButton}" HorizontalAlignment="Stretch" Margin="0,0,0,8"
                                        Command="{Binding AddTransactionCommand}">
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                        <TextBlock Text="&#x2795;" FontSize="14" Margin="0,0,8,0"/>
                                        <TextBlock Text="{DynamicResource Dashboard.AddTransaction}"/>
                                    </StackPanel>
                                </Button>
                                <Button Style="{StaticResource SecondaryButton}" HorizontalAlignment="Stretch"
                                        Command="{Binding NavigateToReportsCommand}">
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                        <TextBlock Text="&#x1F4CA;" FontSize="14" Margin="0,0,8,0"/>
                                        <TextBlock Text="{DynamicResource Dashboard.ViewReports}"/>
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>

                <Border Height="20"/>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
