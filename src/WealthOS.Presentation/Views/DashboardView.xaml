<UserControl x:Class="WealthOS.Presentation.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
             xmlns:conv="clr-namespace:WealthOS.Presentation.Converters">

    <UserControl.Resources>
        <conv:CurrencyConverter x:Key="CurrencyConv"/>
        <conv:TransactionSignMultiConverter x:Key="SignConv"/>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>

    <Grid>
        <!-- Loading -->
        <Border Background="#40FFFFFF" Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}"
                Panel.ZIndex="50" HorizontalAlignment="Stretch" VerticalAlignment="Top" Height="4">
        </Border>

        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="32,24">
            <StackPanel MaxWidth="1200">
                <TextBlock Text="Dashboard" Style="{StaticResource PageTitleStyle}"/>

                <!-- Net Worth Card -->
                <Border Style="{StaticResource CardStyle}" Margin="0,0,0,20">
                    <StackPanel>
                        <TextBlock Text="Net Worth" FontSize="14"
                                   Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,8"/>
                        <TextBlock FontSize="42" FontWeight="Bold"
                                   Foreground="{StaticResource TextPrimaryBrush}">
                            <TextBlock.Text>
                                <Binding Path="Dashboard.NetWorth" Converter="{StaticResource CurrencyConv}"/>
                            </TextBlock.Text>
                        </TextBlock>
                        <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                            <TextBlock Text="This month" FontSize="13"
                                       Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,8,0"/>
                            <TextBlock FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource AccentBrush}">
                                <TextBlock.Text>
                                    <Binding Path="Dashboard.NetWorthChange" Converter="{StaticResource CurrencyConv}"/>
                                </TextBlock.Text>
                            </TextBlock>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Metric Cards Row -->
                <Grid Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock Text="Cash" Style="{StaticResource MetricLabelStyle}"/>
                            <TextBlock Style="{StaticResource MetricValueStyle}">
                                <TextBlock.Text>
                                    <Binding Path="Dashboard.CashTotal" Converter="{StaticResource CurrencyConv}"/>
                                </TextBlock.Text>
                            </TextBlock>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="2" Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock Text="Investment" Style="{StaticResource MetricLabelStyle}"/>
                            <TextBlock Style="{StaticResource MetricValueStyle}">
                                <TextBlock.Text>
                                    <Binding Path="Dashboard.InvestmentTotal" Converter="{StaticResource CurrencyConv}"/>
                                </TextBlock.Text>
                            </TextBlock>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="4" Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock Text="Liabilities" Style="{StaticResource MetricLabelStyle}"/>
                            <TextBlock Style="{StaticResource MetricValueStyle}" Foreground="{StaticResource ExpenseBrush}">
                                <TextBlock.Text>
                                    <Binding Path="Dashboard.TotalLiabilities" Converter="{StaticResource CurrencyConv}"/>
                                </TextBlock.Text>
                            </TextBlock>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="6" Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock Text="Savings Rate" Style="{StaticResource MetricLabelStyle}"/>
                            <TextBlock Style="{StaticResource MetricValueStyle}">
                                <TextBlock.Text>
                                    <Binding Path="Dashboard.SavingsRate" StringFormat="{}{0:F1}%"/>
                                </TextBlock.Text>
                            </TextBlock>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- Charts Row -->
                <Grid Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="2*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Asset Allocation -->
                    <Border Grid.Column="0" Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock Text="Asset Allocation" Style="{StaticResource SectionTitleStyle}"/>
                            <lvc:PieChart Series="{Binding AssetSeries}"
                                          Height="280" LegendPosition="Right"/>
                        </StackPanel>
                    </Border>

                    <!-- Net Worth Trend -->
                    <Border Grid.Column="2" Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Net Worth Trend"
                                           Style="{StaticResource SectionTitleStyle}"/>
                                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                    <Button Content="30d" Margin="4,0" Padding="8,4" FontSize="11"
                                            Background="Transparent" BorderThickness="1"
                                            BorderBrush="{StaticResource BorderBrush}" Cursor="Hand"
                                            Command="{Binding SetTimeRangeCommand}" CommandParameter="30d"/>
                                    <Button Content="90d" Margin="4,0" Padding="8,4" FontSize="11"
                                            Background="{StaticResource PrimaryBrush}" Foreground="White"
                                            BorderThickness="0" Cursor="Hand"
                                            Command="{Binding SetTimeRangeCommand}" CommandParameter="90d"/>
                                    <Button Content="1y" Margin="4,0" Padding="8,4" FontSize="11"
                                            Background="Transparent" BorderThickness="1"
                                            BorderBrush="{StaticResource BorderBrush}" Cursor="Hand"
                                            Command="{Binding SetTimeRangeCommand}" CommandParameter="1y"/>
                                </StackPanel>
                            </Grid>
                            <lvc:CartesianChart Series="{Binding NetWorthSeries}"
                                                XAxes="{Binding NetWorthXAxes}"
                                                YAxes="{Binding NetWorthYAxes}"
                                                Height="280"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- Recent Transactions -->
                <Border Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Text="Recent Transactions" Style="{StaticResource SectionTitleStyle}"/>

                        <!-- Empty State -->
                        <Border Visibility="{Binding Dashboard.RecentTransactions.Count, Converter={StaticResource BoolToVis}}"
                                Padding="40" HorizontalAlignment="Stretch">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Dashboard.RecentTransactions.Count}" Value="0">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock Text="No transactions yet" FontSize="16"
                                           Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Center"/>
                                <TextBlock Text="Add your first transaction to get started"
                                           FontSize="13" Foreground="{StaticResource TextHintBrush}"
                                           HorizontalAlignment="Center" Margin="0,8,0,0"/>
                            </StackPanel>
                        </Border>

                        <ItemsControl ItemsSource="{Binding Dashboard.RecentTransactions}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="0,12" BorderThickness="0,0,0,1"
                                            BorderBrush="{StaticResource BorderBrush}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <Ellipse Grid.Column="0" Width="8" Height="8" Margin="0,0,12,0">
                                                <Ellipse.Style>
                                                    <Style TargetType="Ellipse">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Type}" Value="Income">
                                                                <Setter Property="Fill" Value="{StaticResource IncomeBrush}"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Type}" Value="Expense">
                                                                <Setter Property="Fill" Value="{StaticResource ExpenseBrush}"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Type}" Value="Transfer">
                                                                <Setter Property="Fill" Value="{StaticResource TransferBrush}"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Ellipse.Style>
                                            </Ellipse>
                                            <StackPanel Grid.Column="1">
                                                <TextBlock Text="{Binding Note, FallbackValue='Transaction'}"
                                                           FontSize="14" Foreground="{StaticResource TextPrimaryBrush}"/>
                                                <TextBlock FontSize="12" Foreground="{StaticResource TextSecondaryBrush}">
                                                    <Run Text="{Binding AccountName}"/>
                                                    <Run Text=" · "/>
                                                    <Run Text="{Binding OccurredAt, StringFormat='MM/dd'}"/>
                                                </TextBlock>
                                            </StackPanel>
                                            <TextBlock Grid.Column="2" FontSize="14" FontWeight="SemiBold"
                                                       VerticalAlignment="Center">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Type}" Value="Income">
                                                                <Setter Property="Foreground" Value="{StaticResource IncomeBrush}"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Type}" Value="Expense">
                                                                <Setter Property="Foreground" Value="{StaticResource ExpenseBrush}"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Type}" Value="Transfer">
                                                                <Setter Property="Foreground" Value="{StaticResource TransferBrush}"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                                <TextBlock.Text>
                                                    <MultiBinding Converter="{StaticResource SignConv}">
                                                        <Binding Path="Type"/>
                                                        <Binding Path="Amount"/>
                                                    </MultiBinding>
                                                </TextBlock.Text>
                                            </TextBlock>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
