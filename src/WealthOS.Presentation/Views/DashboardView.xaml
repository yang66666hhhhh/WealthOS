<UserControl x:Class="WealthOS.Presentation.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
             xmlns:conv="clr-namespace:WealthOS.Presentation.Converters"
             xmlns:views="clr-namespace:WealthOS.Presentation.Views">

    <UserControl.Resources>
        <conv:CurrencyConverter x:Key="CurrencyConv"/>
        <conv:TransactionSignMultiConverter x:Key="SignConv"/>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>

    <Grid>
        <!-- 顶部加载进度条 -->
        <Border Background="{StaticResource PrimaryBrush}" 
                Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}"
                Panel.ZIndex="50" HorizontalAlignment="Stretch" VerticalAlignment="Top" Height="3"/>

        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="28,24">
            <StackPanel MaxWidth="1200">
                <views:ErrorBanner DataContext="{Binding}"/>

                <!-- 欢迎区域 -->
                <Grid Margin="0,0,0,24">
                    <StackPanel>
                        <TextBlock Text="{DynamicResource Dashboard.Title}" FontSize="28" FontWeight="Bold" 
                                   Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,4"/>
                        <TextBlock FontSize="14" Foreground="{StaticResource TextSecondaryBrush}">
                            <Run Text="&#x1F44B; "/>
                            <Run Text="{DynamicResource Dashboard.Welcome}"/>
                        </TextBlock>
                    </StackPanel>
                </Grid>

                <!-- 净资产主卡片 - 更丰富的信息 -->
                <Border CornerRadius="20" Padding="28,24" Margin="0,0,0,20"
                        BorderThickness="1" BorderBrush="{StaticResource BorderBrush}">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#F8FAFC" Offset="0"/>
                            <GradientStop Color="#EEF2FF" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="1"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- 左侧：净资产 -->
                        <StackPanel Grid.Column="0" Margin="0,0,24,0">
                            <TextBlock FontSize="13" Foreground="{StaticResource TextTertiaryBrush}" Margin="0,0,0,8" FontWeight="Medium">
                                <TextBlock.Text><Binding Source="{StaticResource Dashboard.NetWorth}"/></TextBlock.Text>
                            </TextBlock>
                            <TextBlock FontSize="42" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,12">
                                <TextBlock.Text>
                                    <Binding Path="Dashboard.NetWorth" Converter="{StaticResource CurrencyConv}"/>
                                </TextBlock.Text>
                            </TextBlock>
                            <StackPanel Orientation="Horizontal">
                                <Border CornerRadius="8" Padding="10,6" Margin="0,0,12,0">
                                    <Border.Background>
                                        <SolidColorBrush Color="{StaticResource AccentLightColor}"/>
                                    </Border.Background>
                                    <TextBlock FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource AccentBrush}">
                                        <TextBlock.Text>
                                            <Binding Path="Dashboard.NetWorthChange" Converter="{StaticResource CurrencyConv}"/>
                                        </TextBlock.Text>
                                    </TextBlock>
                                </Border>
                                <TextBlock FontSize="13" Foreground="{StaticResource TextTertiaryBrush}" VerticalAlignment="Center">
                                    <TextBlock.Text><Binding Source="{StaticResource Dashboard.ThisMonth}"/></TextBlock.Text>
                                </TextBlock>
                            </StackPanel>
                        </StackPanel>

                        <!-- 分隔线 -->
                        <Border Grid.Column="1" Background="{StaticResource BorderBrush}" VerticalAlignment="Stretch" Margin="0,8"/>

                        <!-- 右侧：资产/负债对比 -->
                        <StackPanel Grid.Column="2" Margin="24,0,0,0" VerticalAlignment="Center">
                            <StackPanel Margin="0,0,0,16">
                                <TextBlock FontSize="12" Foreground="{StaticResource TextTertiaryBrush}" Margin="0,0,0,4">
                                    <TextBlock.Text><Binding Source="{StaticResource Dashboard.TotalAssets}"/></TextBlock.Text>
                                </TextBlock>
                                <TextBlock FontSize="20" FontWeight="Bold" Foreground="{StaticResource IncomeBrush}">
                                    <TextBlock.Text>
                                        <Binding Path="Dashboard.TotalAssets" Converter="{StaticResource CurrencyConv}"/>
                                    </TextBlock.Text>
                                </TextBlock>
                            </StackPanel>
                            <Border Height="1" Background="{StaticResource BorderBrush}" Margin="0,0,0,16"/>
                            <StackPanel>
                                <TextBlock FontSize="12" Foreground="{StaticResource TextTertiaryBrush}" Margin="0,0,0,4">
                                    <TextBlock.Text><Binding Source="{StaticResource Dashboard.Liabilities}"/></TextBlock.Text>
                                </TextBlock>
                                <TextBlock FontSize="20" FontWeight="Bold" Foreground="{StaticResource ExpenseBrush}">
                                    <TextBlock.Text>
                                        <Binding Path="Dashboard.TotalLiabilities" Converter="{StaticResource CurrencyConv}"/>
                                    </TextBlock.Text>
                                </TextBlock>
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- 指标卡片网格 - 2x2 布局 -->
                <Grid Margin="0,0,0,20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="12"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- 现金 -->
                    <Border Grid.Row="0" Grid.Column="0" CornerRadius="16" Padding="20" 
                            Background="{StaticResource CardBackgroundBrush}" BorderThickness="1" BorderBrush="{StaticResource BorderBrush}">
                        <Grid>
                            <StackPanel>
                                <TextBlock Style="{StaticResource StatLabelStyle}">
                                    <TextBlock.Text><Binding Source="{StaticResource Dashboard.Cash}"/></TextBlock.Text>
                                </TextBlock>
                                <TextBlock Style="{StaticResource StatValueStyle}" Margin="0,8,0,0">
                                    <TextBlock.Text>
                                        <Binding Path="Dashboard.CashTotal" Converter="{StaticResource CurrencyConv}"/>
                                    </TextBlock.Text>
                                </TextBlock>
                            </StackPanel>
                            <Border Width="40" Height="40" CornerRadius="10" HorizontalAlignment="Right" VerticalAlignment="Top">
                                <Border.Background>
                                    <SolidColorBrush Color="{StaticResource IncomeLightColor}"/>
                                </Border.Background>
                                <TextBlock Text="&#x1F4B5;" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </Grid>
                    </Border>

                    <!-- 投资 -->
                    <Border Grid.Row="0" Grid.Column="2" CornerRadius="16" Padding="20"
                            Background="{StaticResource CardBackgroundBrush}" BorderThickness="1" BorderBrush="{StaticResource BorderBrush}">
                        <Grid>
                            <StackPanel>
                                <TextBlock Style="{StaticResource StatLabelStyle}">
                                    <TextBlock.Text><Binding Source="{StaticResource Dashboard.Investment}"/></TextBlock.Text>
                                </TextBlock>
                                <TextBlock Style="{StaticResource StatValueStyle}" Margin="0,8,0,0">
                                    <TextBlock.Text>
                                        <Binding Path="Dashboard.InvestmentTotal" Converter="{StaticResource CurrencyConv}"/>
                                    </TextBlock.Text>
                                </TextBlock>
                            </StackPanel>
                            <Border Width="40" Height="40" CornerRadius="10" HorizontalAlignment="Right" VerticalAlignment="Top">
                                <Border.Background>
                                    <SolidColorBrush Color="{StaticResource PrimaryLightColor}"/>
                                </Border.Background>
                                <TextBlock Text="&#x1F4C8;" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </Grid>
                    </Border>

                    <!-- 负债 -->
                    <Border Grid.Row="2" Grid.Column="0" CornerRadius="16" Padding="20"
                            Background="{StaticResource CardBackgroundBrush}" BorderThickness="1" BorderBrush="{StaticResource BorderBrush}">
                        <Grid>
                            <StackPanel>
                                <TextBlock Style="{StaticResource StatLabelStyle}">
                                    <TextBlock.Text><Binding Source="{StaticResource Dashboard.Liabilities}"/></TextBlock.Text>
                                </TextBlock>
                                <TextBlock Style="{StaticResource StatValueStyle}" Margin="0,8,0,0" Foreground="{StaticResource ExpenseBrush}">
                                    <TextBlock.Text>
                                        <Binding Path="Dashboard.TotalLiabilities" Converter="{StaticResource CurrencyConv}"/>
                                    </TextBlock.Text>
                                </TextBlock>
                            </StackPanel>
                            <Border Width="40" Height="40" CornerRadius="10" HorizontalAlignment="Right" VerticalAlignment="Top">
                                <Border.Background>
                                    <SolidColorBrush Color="{StaticResource ExpenseLightColor}"/>
                                </Border.Background>
                                <TextBlock Text="&#x1F4B8;" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </Grid>
                    </Border>

                    <!-- 储蓄率 -->
                    <Border Grid.Row="2" Grid.Column="2" CornerRadius="16" Padding="20"
                            Background="{StaticResource CardBackgroundBrush}" BorderThickness="1" BorderBrush="{StaticResource BorderBrush}">
                        <Grid>
                            <StackPanel>
                                <TextBlock Style="{StaticResource StatLabelStyle}">
                                    <TextBlock.Text><Binding Source="{StaticResource Dashboard.SavingsRate}"/></TextBlock.Text>
                                </TextBlock>
                                <TextBlock Style="{StaticResource StatValueStyle}" Margin="0,8,0,0">
                                    <TextBlock.Text>
                                        <Binding Path="Dashboard.SavingsRate" StringFormat="{}{0:F1}%"/>
                                    </TextBlock.Text>
                                </TextBlock>
                            </StackPanel>
                            <Border Width="40" Height="40" CornerRadius="10" HorizontalAlignment="Right" VerticalAlignment="Top">
                                <Border.Background>
                                    <SolidColorBrush Color="{StaticResource TransferLightColor}"/>
                                </Border.Background>
                                <TextBlock Text="&#x1F3AF;" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </Grid>
                    </Border>
                </Grid>

                <!-- 图表区域 -->
                <Grid Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="2*"/>
                    </Grid.ColumnDefinitions>

                    <!-- 资产配置饼图 -->
                    <Border Grid.Column="0" Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock Style="{StaticResource SectionTitleStyle}">
                                <TextBlock.Text><Binding Source="{StaticResource Dashboard.AssetAllocation}"/></TextBlock.Text>
                            </TextBlock>
                            <lvc:PieChart Series="{Binding AssetSeries}" Height="260" LegendPosition="Right"/>
                        </StackPanel>
                    </Border>

                    <!-- 净资产趋势折线图 -->
                    <Border Grid.Column="2" Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <Grid Margin="0,0,0,16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Style="{StaticResource SectionTitleStyle}" Margin="0">
                                    <TextBlock.Text><Binding Source="{StaticResource Dashboard.NetWorthTrend}"/></TextBlock.Text>
                                </TextBlock>
                                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                    <Button Content="30d" Margin="4,0" Padding="12,6" FontSize="12" Cursor="Hand"
                                            Command="{Binding SetTimeRangeAsyncCommand}" CommandParameter="30d">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource SecondaryButton}">
                                                <Setter Property="Padding" Value="12,6"/>
                                                <Setter Property="FontSize" Value="12"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding SelectedTimeRange}" Value="0">
                                                        <Setter Property="Background" Value="{StaticResource PrimaryBrush}"/>
                                                        <Setter Property="Foreground" Value="White"/>
                                                        <Setter Property="BorderThickness" Value="0"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                    <Button Content="90d" Margin="4,0" Padding="12,6" FontSize="12" Cursor="Hand"
                                            Command="{Binding SetTimeRangeAsyncCommand}" CommandParameter="90d">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource SecondaryButton}">
                                                <Setter Property="Padding" Value="12,6"/>
                                                <Setter Property="FontSize" Value="12"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding SelectedTimeRange}" Value="1">
                                                        <Setter Property="Background" Value="{StaticResource PrimaryBrush}"/>
                                                        <Setter Property="Foreground" Value="White"/>
                                                        <Setter Property="BorderThickness" Value="0"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                    <Button Content="1y" Margin="4,0" Padding="12,6" FontSize="12" Cursor="Hand"
                                            Command="{Binding SetTimeRangeAsyncCommand}" CommandParameter="1y">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource SecondaryButton}">
                                                <Setter Property="Padding" Value="12,6"/>
                                                <Setter Property="FontSize" Value="12"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding SelectedTimeRange}" Value="2">
                                                        <Setter Property="Background" Value="{StaticResource PrimaryBrush}"/>
                                                        <Setter Property="Foreground" Value="White"/>
                                                        <Setter Property="BorderThickness" Value="0"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                </StackPanel>
                            </Grid>
                            <lvc:CartesianChart Series="{Binding NetWorthSeries}"
                                                XAxes="{Binding NetWorthXAxes}"
                                                YAxes="{Binding NetWorthYAxes}"
                                                Height="260"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- 最近交易 -->
                <Border Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Style="{StaticResource SectionTitleStyle}" Margin="0">
                                <TextBlock.Text><Binding Source="{StaticResource Dashboard.RecentTransactions}"/></TextBlock.Text>
                            </TextBlock>
                            <TextBlock Grid.Column="1" FontSize="13" Foreground="{StaticResource PrimaryBrush}" 
                                       VerticalAlignment="Center" Cursor="Hand">
                                <TextBlock.Text><Binding Source="{StaticResource Dashboard.ViewAll}"/></TextBlock.Text>
                            </TextBlock>
                        </Grid>

                        <!-- 空状态 -->
                        <Border Padding="40" HorizontalAlignment="Stretch">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Dashboard.RecentTransactions.Count}" Value="0">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock Style="{StaticResource EmptyStateIconStyle}" Text="&#x1F4CB;"/>
                                <TextBlock Style="{StaticResource EmptyStateTitleStyle}">
                                    <TextBlock.Text><Binding Source="{StaticResource Dashboard.NoTransactions}"/></TextBlock.Text>
                                </TextBlock>
                                <TextBlock Style="{StaticResource EmptyStateHintStyle}">
                                    <TextBlock.Text><Binding Source="{StaticResource Dashboard.NoTransactionsHint}"/></TextBlock.Text>
                                </TextBlock>
                            </StackPanel>
                        </Border>

                        <!-- 交易列表 -->
                        <ItemsControl ItemsSource="{Binding Dashboard.RecentTransactions}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="0,12" BorderThickness="0,0,0,1"
                                            BorderBrush="{StaticResource BorderLightBrush}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <!-- 类型指示器 -->
                                            <Border Grid.Column="0" Width="40" Height="40" CornerRadius="10" Margin="0,0,14,0">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Type}" Value="Income">
                                                                <Setter Property="Background" Value="{StaticResource IncomeLightBrush}"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Type}" Value="Expense">
                                                                <Setter Property="Background" Value="{StaticResource ExpenseLightBrush}"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Type}" Value="Transfer">
                                                                <Setter Property="Background" Value="{StaticResource TransferLightBrush}"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="16">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Type}" Value="Income">
                                                                    <Setter Property="Text" Value="&#x2191;"/>
                                                                    <Setter Property="Foreground" Value="{StaticResource IncomeBrush}"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Type}" Value="Expense">
                                                                    <Setter Property="Text" Value="&#x2193;"/>
                                                                    <Setter Property="Foreground" Value="{StaticResource ExpenseBrush}"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Type}" Value="Transfer">
                                                                    <Setter Property="Text" Value="&#x2194;"/>
                                                                    <Setter Property="Foreground" Value="{StaticResource TransferBrush}"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </Border>
                                            <!-- 交易信息 -->
                                            <StackPanel Grid.Column="1">
                                                <TextBlock Text="{Binding Note, FallbackValue='Transaction'}"
                                                           FontSize="14" FontWeight="Medium" Foreground="{StaticResource TextPrimaryBrush}"/>
                                                <TextBlock FontSize="12" Foreground="{StaticResource TextTertiaryBrush}" Margin="0,4,0,0">
                                                    <Run Text="{Binding AccountName}"/>
                                                    <Run Text=" · "/>
                                                    <Run Text="{Binding OccurredAt, StringFormat='MM/dd'}"/>
                                                </TextBlock>
                                            </StackPanel>
                                            <!-- 金额 -->
                                            <TextBlock Grid.Column="2" FontSize="15" FontWeight="Bold" VerticalAlignment="Center">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Type}" Value="Income">
                                                                <Setter Property="Foreground" Value="{StaticResource IncomeBrush}"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Type}" Value="Expense">
                                                                <Setter Property="Foreground" Value="{StaticResource ExpenseBrush}"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Type}" Value="Transfer">
                                                                <Setter Property="Foreground" Value="{StaticResource TransferBrush}"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                                <TextBlock.Text>
                                                    <MultiBinding Converter="{StaticResource SignConv}">
                                                        <Binding Path="Type"/>
                                                        <Binding Path="Amount"/>
                                                    </MultiBinding>
                                                </TextBlock.Text>
                                            </TextBlock>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <!-- 底部间距 -->
                <Border Height="20"/>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
