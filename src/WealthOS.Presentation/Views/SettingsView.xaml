<UserControl x:Class="WealthOS.Presentation.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:WealthOS.Presentation.Converters">

    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>

    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="32,24">
            <StackPanel MaxWidth="800">
                <TextBlock Style="{StaticResource PageTitleStyle}">
                    <TextBlock.Text><Binding Source="{DynamicResource Settings.Title}"/></TextBlock.Text>
                </TextBlock>

                <!-- Language -->
                <Border Style="{StaticResource CardStyle}" Margin="0,0,0,20">
                    <StackPanel>
                        <TextBlock Style="{StaticResource SectionTitleStyle}">
                            <TextBlock.Text><Binding Source="{DynamicResource Settings.Language}"/></TextBlock.Text>
                        </TextBlock>
                        <TextBlock FontSize="14" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,16">
                            <TextBlock.Text><Binding Source="{DynamicResource Settings.LanguageDesc}"/></TextBlock.Text>
                        </TextBlock>
                        <Button Style="{StaticResource PrimaryButton}" Command="{Binding ToggleLanguageCommand}" HorizontalAlignment="Left">
                            <Button.Content><Binding Source="{DynamicResource Settings.ToggleLang}"/></Button.Content>
                        </Button>
                    </StackPanel>
                </Border>

                <!-- Theme -->
                <Border Style="{StaticResource CardStyle}" Margin="0,0,0,20">
                    <StackPanel>
                        <TextBlock Style="{StaticResource SectionTitleStyle}">
                            <TextBlock.Text><Binding Source="{DynamicResource Settings.Theme}"/></TextBlock.Text>
                        </TextBlock>
                        <TextBlock FontSize="14" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,16">
                            <TextBlock.Text><Binding Source="{DynamicResource Settings.ThemeDesc}"/></TextBlock.Text>
                        </TextBlock>
                        <Button Style="{StaticResource PrimaryButton}" Command="{Binding ToggleThemeCommand}" HorizontalAlignment="Left">
                            <Button.Content><Binding Source="{DynamicResource Settings.ToggleTheme}"/></Button.Content>
                        </Button>
                    </StackPanel>
                </Border>

                <!-- Database Info -->
                <Border Style="{StaticResource CardStyle}" Margin="0,0,0,20">
                    <StackPanel>
                        <TextBlock Style="{StaticResource SectionTitleStyle}">
                            <TextBlock.Text><Binding Source="{DynamicResource Settings.Database}"/></TextBlock.Text>
                        </TextBlock>
                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="8"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="8"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="{DynamicResource Settings.DbPath}" FontSize="13" Foreground="{StaticResource TextSecondaryBrush}"/>
                            <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding DbPath}" FontSize="13" Foreground="{StaticResource TextPrimaryBrush}" TextWrapping="Wrap"/>
                            <TextBlock Grid.Row="2" Grid.Column="0" Text="{DynamicResource Settings.DbSize}" FontSize="13" Foreground="{StaticResource TextSecondaryBrush}"/>
                            <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding DbSize}" FontSize="13" Foreground="{StaticResource TextPrimaryBrush}"/>
                            <TextBlock Grid.Row="4" Grid.Column="0" Text="{DynamicResource Settings.LastBackup}" FontSize="13" Foreground="{StaticResource TextSecondaryBrush}"/>
                            <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding LastBackupTime}" FontSize="13" Foreground="{StaticResource TextPrimaryBrush}"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Backup & Restore -->
                <Border Style="{StaticResource CardStyle}" Margin="0,0,0,20">
                    <StackPanel>
                        <TextBlock Style="{StaticResource SectionTitleStyle}">
                            <TextBlock.Text><Binding Source="{DynamicResource Settings.Backup}"/></TextBlock.Text>
                        </TextBlock>
                        <TextBlock FontSize="14" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,16">
                            <TextBlock.Text><Binding Source="{DynamicResource Settings.BackupDesc}"/></TextBlock.Text>
                        </TextBlock>
                        <StackPanel Orientation="Horizontal">
                            <Button Style="{StaticResource PrimaryButton}" Command="{Binding BackupCommand}" Margin="0,0,12,0">
                                <Button.Content><Binding Source="{DynamicResource Settings.BackupBtn}"/></Button.Content>
                            </Button>
                            <Button Style="{StaticResource SecondaryButton}" Command="{Binding RestoreCommand}">
                                <Button.Content><Binding Source="{DynamicResource Settings.RestoreBtn}"/></Button.Content>
                            </Button>
                        </StackPanel>

                        <TextBlock Text="{Binding StatusMessage}" FontSize="13" Foreground="{StaticResource AccentBrush}"
                                   Margin="0,16,0,0" Visibility="{Binding StatusMessage, Converter={StaticResource BoolToVis}}"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
