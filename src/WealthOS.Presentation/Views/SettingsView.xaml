<UserControl x:Class="WealthOS.Presentation.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:WealthOS.Presentation.Converters"
             xmlns:views="clr-namespace:WealthOS.Presentation.Views">

    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>

    <Grid>
        <Border Background="{StaticResource PrimaryBrush}" 
                Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}"
                Panel.ZIndex="50" HorizontalAlignment="Stretch" VerticalAlignment="Top" Height="3"/>
        <views:ErrorBanner DataContext="{Binding}"/>

        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="28,24">
            <StackPanel MaxWidth="800">
                <!-- 页面标题 -->
                <Grid Margin="0,0,0,24">
                    <StackPanel>
                        <TextBlock Style="{StaticResource PageTitleStyle}">
                            <TextBlock.Text><Binding Source="{StaticResource Settings.Title}"/></TextBlock.Text>
                        </TextBlock>
                        <TextBlock FontSize="13" Foreground="{StaticResource TextTertiaryBrush}" Margin="0,4,0,0">
                            <Run Text="&#x2699; "/>
                            <Run Text="{DynamicResource Settings.Subtitle}"/>
                        </TextBlock>
                    </StackPanel>
                </Grid>

                <!-- 语言设置 -->
                <Border CornerRadius="14" Padding="20" Margin="0,0,0,16"
                        BorderThickness="1" BorderBrush="{StaticResource BorderBrush}"
                        Background="{StaticResource CardBackgroundBrush}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Width="44" Height="44" CornerRadius="12" Margin="0,0,16,0">
                            <Border.Background>
                                <SolidColorBrush Color="{StaticResource IconBgBlueColor}"/>
                            </Border.Background>
                            <TextBlock Text="&#x1F310;" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="{DynamicResource Settings.Language}" FontSize="15" FontWeight="SemiBold" 
                                       Foreground="{StaticResource TextPrimaryBrush}"/>
                            <TextBlock Text="{DynamicResource Settings.LanguageDesc}" FontSize="12" 
                                       Foreground="{StaticResource TextTertiaryBrush}" Margin="0,4,0,0"/>
                        </StackPanel>
                        <Button Grid.Column="2" Style="{StaticResource SecondaryButton}" 
                                Command="{Binding ToggleLanguageCommand}" VerticalAlignment="Center">
                            <Button.Content><Binding Source="{StaticResource Settings.ToggleLang}"/></Button.Content>
                        </Button>
                    </Grid>
                </Border>

                <!-- 主题设置 -->
                <Border CornerRadius="14" Padding="20" Margin="0,0,0,16"
                        BorderThickness="1" BorderBrush="{StaticResource BorderBrush}"
                        Background="{StaticResource CardBackgroundBrush}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Width="44" Height="44" CornerRadius="12" Margin="0,0,16,0">
                            <Border.Background>
                                <SolidColorBrush Color="{StaticResource IconBgYellowColor}"/>
                            </Border.Background>
                            <TextBlock Text="&#x2600;" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="{DynamicResource Settings.Theme}" FontSize="15" FontWeight="SemiBold" 
                                       Foreground="{StaticResource TextPrimaryBrush}"/>
                            <TextBlock Text="{DynamicResource Settings.ThemeDesc}" FontSize="12" 
                                       Foreground="{StaticResource TextTertiaryBrush}" Margin="0,4,0,0"/>
                        </StackPanel>
                        <Button Grid.Column="2" Style="{StaticResource SecondaryButton}" 
                                Command="{Binding ToggleThemeCommand}" VerticalAlignment="Center">
                            <Button.Content><Binding Source="{StaticResource Settings.ToggleTheme}"/></Button.Content>
                        </Button>
                    </Grid>
                </Border>

                <!-- 数据库信息 -->
                <Border CornerRadius="14" Padding="20" Margin="0,0,0,16"
                        BorderThickness="1" BorderBrush="{StaticResource BorderBrush}"
                        Background="{StaticResource CardBackgroundBrush}">
                    <StackPanel>
                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Width="44" Height="44" CornerRadius="12" Margin="0,0,16,0">
                                <Border.Background>
                                    <SolidColorBrush Color="{StaticResource IconBgGreenColor}"/>
                                </Border.Background>
                                <TextBlock Text="&#x1F4BE;" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="{DynamicResource Settings.Database}" FontSize="15" FontWeight="SemiBold" 
                                           Foreground="{StaticResource TextPrimaryBrush}"/>
                            </StackPanel>
                        </Grid>
                        <Border CornerRadius="{StaticResource IconCornerRadius}" Padding="16" Background="{StaticResource SurfaceBrush}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="12"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="12"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="{DynamicResource Settings.DbPath}" 
                                           FontSize="12" Foreground="{StaticResource TextTertiaryBrush}"/>
                                <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding DbPath}" 
                                           FontSize="12" Foreground="{StaticResource TextPrimaryBrush}" TextWrapping="Wrap"/>
                                <TextBlock Grid.Row="2" Grid.Column="0" Text="{DynamicResource Settings.DbSize}" 
                                           FontSize="12" Foreground="{StaticResource TextTertiaryBrush}"/>
                                <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding DbSize}" 
                                           FontSize="12" Foreground="{StaticResource TextPrimaryBrush}"/>
                                <TextBlock Grid.Row="4" Grid.Column="0" Text="{DynamicResource Settings.LastBackup}" 
                                           FontSize="12" Foreground="{StaticResource TextTertiaryBrush}"/>
                                <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding LastBackupTime}" 
                                           FontSize="12" Foreground="{StaticResource TextPrimaryBrush}"/>
                            </Grid>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- 备份与恢复 -->
                <Border CornerRadius="14" Padding="20" Margin="0,0,0,16"
                        BorderThickness="1" BorderBrush="{StaticResource BorderBrush}"
                        Background="{StaticResource CardBackgroundBrush}">
                    <StackPanel>
                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Width="44" Height="44" CornerRadius="12" Margin="0,0,16,0">
                                <Border.Background>
                                    <SolidColorBrush Color="{StaticResource IconBgRedColor}"/>
                                </Border.Background>
                                <TextBlock Text="&#x1F4E6;" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="{DynamicResource Settings.Backup}" FontSize="15" FontWeight="SemiBold" 
                                           Foreground="{StaticResource TextPrimaryBrush}"/>
                                <TextBlock Text="{DynamicResource Settings.BackupDesc}" FontSize="12" 
                                           Foreground="{StaticResource TextTertiaryBrush}" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Grid>
                        <StackPanel Orientation="Horizontal">
                            <Button Style="{StaticResource PrimaryButton}" Command="{Binding BackupCommand}" Margin="0,0,12,0">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#x1F4E5;" FontSize="14" Margin="0,0,8,0"/>
                                    <TextBlock Text="{DynamicResource Settings.BackupBtn}"/>
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource SecondaryButton}" Command="{Binding RestoreCommand}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#x1F4E4;" FontSize="14" Margin="0,0,8,0"/>
                                    <TextBlock Text="{DynamicResource Settings.RestoreBtn}"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                        <Border CornerRadius="8" Padding="12" Margin="0,16,0,0"
                                Visibility="{Binding StatusMessage, Converter={StaticResource BoolToVis}}">
                            <Border.Background>
                                <SolidColorBrush Color="{StaticResource IconBgGreenColor}"/>
                            </Border.Background>
                            <TextBlock Text="{Binding StatusMessage}" FontSize="13" Foreground="{StaticResource AccentBrush}"/>
                        </Border>
                    </StackPanel>
                </Border>

                <Border Height="20"/>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
