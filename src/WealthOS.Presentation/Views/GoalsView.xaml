<UserControl x:Class="WealthOS.Presentation.Views.GoalsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:WealthOS.Presentation.Converters">

    <UserControl.Resources>
        <conv:CurrencyConverter x:Key="CurrencyConv"/>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>

    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="32,24">
            <StackPanel MaxWidth="1200">
                <!-- Header -->
                <Grid Margin="0,0,0,24">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Goals" Style="{StaticResource PageTitleStyle}"/>
                    <Button Grid.Column="1" Content="+ Add Goal" Style="{StaticResource PrimaryButton}"
                            Command="{Binding ShowAddCommand}" VerticalAlignment="Center"/>
                </Grid>

                <!-- Loading -->
                <ProgressBar IsIndeterminate="True" Height="3" Margin="0,0,0,16"
                             Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}"
                             Background="Transparent" Foreground="{StaticResource PrimaryBrush}"/>

                <!-- Empty State -->
                <Border Padding="60" Visibility="{Binding Goals.Count, Converter={StaticResource BoolToVis}}">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Goals.Count}" Value="0">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="No goals yet" FontSize="20" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Center"/>
                        <TextBlock Text="Click '+ Add Goal' to set your first financial goal"
                                   FontSize="14" Foreground="{StaticResource TextHintBrush}"
                                   HorizontalAlignment="Center" Margin="0,12,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Goal Cards -->
                <ItemsControl ItemsSource="{Binding Goals}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Style="{StaticResource CardStyle}" Margin="0,0,16,16" Width="340">
                                <StackPanel>
                                    <Grid Margin="0,0,0,16">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding Name}" FontSize="18"
                                                   FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}"/>
                                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                                            <Button Content="+" FontSize="16" FontWeight="Bold"
                                                    Background="Transparent" BorderThickness="1"
                                                    BorderBrush="{StaticResource AccentBrush}"
                                                    Foreground="{StaticResource AccentBrush}" Cursor="Hand"
                                                    Padding="8,2" Margin="0,0,8,0"
                                                    ToolTip="Add money to this goal"
                                                    Command="{Binding DataContext.ShowProgressDialogCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                    CommandParameter="{Binding}"/>
                                            <Button Content="x" FontSize="14"
                                                    Background="Transparent" BorderThickness="0"
                                                    Foreground="{StaticResource TextHintBrush}" Cursor="Hand"
                                                    Padding="4,0"
                                                    Command="{Binding DataContext.ConfirmDeleteCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                    CommandParameter="{Binding Id}"/>
                                        </StackPanel>
                                    </Grid>

                                    <!-- Progress Bar -->
                                    <Grid Margin="0,0,0,12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <ProgressBar Grid.Column="0" Value="{Binding Progress}"
                                                     Maximum="100" Height="8"
                                                     Background="{StaticResource SurfaceBrush}"
                                                     Foreground="{StaticResource AccentBrush}" Margin="0,0,12,0"/>
                                        <TextBlock Grid.Column="1" Text="{Binding Progress, StringFormat='{}{0:F1}%'}"
                                                   FontSize="13" FontWeight="SemiBold"
                                                   Foreground="{StaticResource AccentBrush}"/>
                                    </Grid>

                                    <!-- Amounts -->
                                    <Grid Margin="0,0,0,12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="Current" FontSize="11"
                                                       Foreground="{StaticResource TextSecondaryBrush}"/>
                                            <TextBlock FontSize="18" FontWeight="Bold">
                                                <TextBlock.Text>
                                                    <Binding Path="CurrentAmount" Converter="{StaticResource CurrencyConv}"/>
                                                </TextBlock.Text>
                                            </TextBlock>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                                            <TextBlock Text="Target" FontSize="11"
                                                       Foreground="{StaticResource TextSecondaryBrush}"/>
                                            <TextBlock FontSize="18" FontWeight="Bold"
                                                       Foreground="{StaticResource TextSecondaryBrush}">
                                                <TextBlock.Text>
                                                    <Binding Path="TargetAmount" Converter="{StaticResource CurrencyConv}"/>
                                                </TextBlock.Text>
                                            </TextBlock>
                                        </StackPanel>
                                    </Grid>

                                    <!-- Target Date -->
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="Target date: " FontSize="12"
                                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                                        <TextBlock Text="{Binding TargetDate, StringFormat='yyyy-MM-dd'}"
                                                   FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                        <TextBlock Text="Remaining: " FontSize="12"
                                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                                        <TextBlock Text="{Binding EstimatedMonthsRemaining, StringFormat='{}{0} months'}"
                                                   FontSize="12" FontWeight="SemiBold"
                                                   Foreground="{StaticResource AccentBrush}"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Add Dialog -->
                <Border Background="#80000000" Visibility="{Binding IsAddDialogOpen, Converter={StaticResource BoolToVis}}"
                        Panel.ZIndex="100">
                    <Border Background="White" CornerRadius="20" Padding="32" Width="480"
                            VerticalAlignment="Center" HorizontalAlignment="Center">
                        <StackPanel>
                            <TextBlock Text="Add Goal" FontSize="22" FontWeight="Bold"
                                       Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,24"/>

                            <TextBlock Text="Name" FontSize="13" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,6"/>
                            <TextBox Text="{Binding NewName, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource InputStyle}" Margin="0,0,0,16"/>

                            <Grid Margin="0,0,0,16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="16"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Target Amount" FontSize="13" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,6"/>
                                    <TextBox Text="{Binding NewTargetAmount, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource InputStyle}"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Current Amount" FontSize="13" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,6"/>
                                    <TextBox Text="{Binding NewCurrentAmount, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource InputStyle}"/>
                                </StackPanel>
                            </Grid>

                            <TextBlock Text="Target Date" FontSize="13" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,6"/>
                            <DatePicker SelectedDate="{Binding NewTargetDate}" Margin="0,0,0,16"/>

                            <TextBlock Text="Note" FontSize="13" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,6"/>
                            <TextBox Text="{Binding NewNote, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource InputStyle}" Margin="0,0,0,24"/>

                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <Button Content="Cancel" Style="{StaticResource SecondaryButton}"
                                        Command="{Binding CancelAddCommand}" Margin="0,0,12,0"/>
                                <Button Content="Add" Style="{StaticResource PrimaryButton}"
                                        Command="{Binding ConfirmAddCommand}"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Border>

                <!-- Delete Confirmation Dialog -->
                <Border Background="#80000000" Visibility="{Binding IsConfirmDeleteOpen, Converter={StaticResource BoolToVis}}"
                        Panel.ZIndex="100">
                    <Border Background="White" CornerRadius="20" Padding="32" Width="400"
                            VerticalAlignment="Center" HorizontalAlignment="Center">
                        <StackPanel>
                            <TextBlock Text="Delete Goal" FontSize="22" FontWeight="Bold"
                                       Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,12"/>
                            <TextBlock Text="Are you sure you want to delete this goal? This action cannot be undone."
                                       FontSize="14" Foreground="{StaticResource TextSecondaryBrush}"
                                       TextWrapping="Wrap" Margin="0,0,0,24"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <Button Content="Cancel" Style="{StaticResource SecondaryButton}"
                                        Command="{Binding CancelDeleteCommand}" Margin="0,0,12,0"/>
                                <Button Content="Delete" Style="{StaticResource PrimaryButton}"
                                        Command="{Binding ExecuteDeleteCommand}"
                                        Background="{StaticResource ExpenseBrush}"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Border>

                <!-- Progress Update Dialog -->
                <Border Background="#80000000" Visibility="{Binding IsProgressDialogOpen, Converter={StaticResource BoolToVis}}"
                        Panel.ZIndex="100">
                    <Border Background="White" CornerRadius="20" Padding="32" Width="400"
                            VerticalAlignment="Center" HorizontalAlignment="Center">
                        <StackPanel>
                            <TextBlock Text="Add Progress" FontSize="22" FontWeight="Bold"
                                       Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,8"/>
                            <TextBlock FontSize="14" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,20">
                                <Run Text="Add money to: "/>
                                <Run Text="{Binding ProgressGoalName, Mode=OneWay}" FontWeight="SemiBold"/>
                            </TextBlock>

                            <TextBlock Text="Amount to Add" FontSize="13" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,6"/>
                            <TextBox Text="{Binding ProgressAddAmount, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource InputStyle}" Margin="0,0,0,24"/>

                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <Button Content="Cancel" Style="{StaticResource SecondaryButton}"
                                        Command="{Binding CancelProgressCommand}" Margin="0,0,12,0"/>
                                <Button Content="Add" Style="{StaticResource PrimaryButton}"
                                        Command="{Binding ConfirmProgressCommand}"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
