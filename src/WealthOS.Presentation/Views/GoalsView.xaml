<UserControl x:Class="WealthOS.Presentation.Views.GoalsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:WealthOS.Presentation.Converters">

    <UserControl.Resources>
        <conv:CurrencyConverter x:Key="CurrencyConv"/>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>

    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="32,24">
            <StackPanel MaxWidth="1200">
                <!-- Header -->
                <Grid Margin="0,0,0,24">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Goals" Style="{StaticResource PageTitleStyle}"/>
                    <Button Grid.Column="1" Content="+ Add Goal" Style="{StaticResource PrimaryButton}"
                            Command="{Binding ShowAddCommand}" VerticalAlignment="Center"/>
                </Grid>

                <!-- Goal Cards -->
                <ItemsControl ItemsSource="{Binding Goals}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Style="{StaticResource CardStyle}" Margin="0,0,16,16" Width="340">
                                <StackPanel>
                                    <Grid Margin="0,0,0,16">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding Name}" FontSize="18"
                                                   FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}"/>
                                        <Button Grid.Column="1" Content="×" FontSize="14"
                                                Background="Transparent" BorderThickness="0"
                                                Foreground="{StaticResource TextHintBrush}" Cursor="Hand"
                                                Padding="4,0"/>
                                    </Grid>

                                    <!-- Progress Bar -->
                                    <Grid Margin="0,0,0,12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <ProgressBar Grid.Column="0" Value="{Binding Progress}"
                                                     Maximum="100" Height="8"
                                                     Background="{StaticResource SurfaceBrush}"
                                                     Foreground="{StaticResource AccentBrush}" Margin="0,0,12,0"/>
                                        <TextBlock Grid.Column="1" Text="{Binding Progress, StringFormat='{}{0:F1}%'}"
                                                   FontSize="13" FontWeight="SemiBold"
                                                   Foreground="{StaticResource AccentBrush}"/>
                                    </Grid>

                                    <!-- Amounts -->
                                    <Grid Margin="0,0,0,12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="Current" FontSize="11"
                                                       Foreground="{StaticResource TextSecondaryBrush}"/>
                                            <TextBlock FontSize="18" FontWeight="Bold">
                                                <TextBlock.Text>
                                                    <Binding Path="CurrentAmount" Converter="{StaticResource CurrencyConv}"/>
                                                </TextBlock.Text>
                                            </TextBlock>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                                            <TextBlock Text="Target" FontSize="11"
                                                       Foreground="{StaticResource TextSecondaryBrush}"/>
                                            <TextBlock FontSize="18" FontWeight="Bold"
                                                       Foreground="{StaticResource TextSecondaryBrush}">
                                                <TextBlock.Text>
                                                    <Binding Path="TargetAmount" Converter="{StaticResource CurrencyConv}"/>
                                                </TextBlock.Text>
                                            </TextBlock>
                                        </StackPanel>
                                    </Grid>

                                    <!-- Target Date -->
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="Target date: " FontSize="12"
                                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                                        <TextBlock Text="{Binding TargetDate, StringFormat='yyyy-MM-dd'}"
                                                   FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                        <TextBlock Text="Estimated: " FontSize="12"
                                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                                        <TextBlock Text="{Binding EstimatedMonthsRemaining, StringFormat='{}{0} months'}"
                                                   FontSize="12" FontWeight="SemiBold"
                                                   Foreground="{StaticResource AccentBrush}"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Add Dialog -->
                <Border Background="#80000000" Visibility="{Binding IsAddDialogOpen, Converter={StaticResource BoolToVis}}"
                        Panel.ZIndex="100">
                    <Border Background="White" CornerRadius="20" Padding="32" Width="480"
                            VerticalAlignment="Center" HorizontalAlignment="Center">
                        <StackPanel>
                            <TextBlock Text="Add Goal" FontSize="22" FontWeight="Bold"
                                       Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,24"/>

                            <TextBlock Text="Name" FontSize="13" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,6"/>
                            <TextBox Text="{Binding NewName, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource InputStyle}" Margin="0,0,0,16"/>

                            <Grid Margin="0,0,0,16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="16"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Target Amount" FontSize="13" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,6"/>
                                    <TextBox Text="{Binding NewTargetAmount, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource InputStyle}"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Current Amount" FontSize="13" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,6"/>
                                    <TextBox Text="{Binding NewCurrentAmount, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource InputStyle}"/>
                                </StackPanel>
                            </Grid>

                            <TextBlock Text="Target Date" FontSize="13" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,6"/>
                            <DatePicker SelectedDate="{Binding NewTargetDate}" Margin="0,0,0,16"/>

                            <TextBlock Text="Note" FontSize="13" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,6"/>
                            <TextBox Text="{Binding NewNote, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource InputStyle}" Margin="0,0,0,24"/>

                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <Button Content="Cancel" Style="{StaticResource SecondaryButton}"
                                        Command="{Binding CancelAddCommand}" Margin="0,0,12,0"/>
                                <Button Content="Add" Style="{StaticResource PrimaryButton}"
                                        Command="{Binding ConfirmAddCommand}"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
