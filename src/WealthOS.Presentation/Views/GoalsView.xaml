<UserControl x:Class="WealthOS.Presentation.Views.GoalsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:WealthOS.Presentation.Converters">

    <UserControl.Resources>
        <conv:CurrencyConverter x:Key="CurrencyConv"/>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>

    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="32,24">
            <StackPanel MaxWidth="1200">
                <Grid Margin="0,0,0,24">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Style="{StaticResource PageTitleStyle}">
                        <TextBlock.Text><Binding Source="{StaticResource Goals.Title}"/></TextBlock.Text>
                    </TextBlock>
                    <Button Grid.Column="1" Style="{StaticResource PrimaryButton}" Command="{Binding ShowAddCommand}" VerticalAlignment="Center">
                        <Button.Content><Binding Source="{StaticResource Goals.Add}"/></Button.Content>
                    </Button>
                </Grid>

                <ProgressBar IsIndeterminate="True" Height="3" Margin="0,0,0,16"
                             Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}"
                             Background="Transparent" Foreground="{StaticResource PrimaryBrush}"/>

                <Border Padding="60" Visibility="{Binding Goals.Count, Converter={StaticResource BoolToVis}}">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Goals.Count}" Value="0"><Setter Property="Visibility" Value="Visible"/></DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock FontSize="20" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Center">
                            <TextBlock.Text><Binding Source="{StaticResource Goals.NoGoals}"/></TextBlock.Text>
                        </TextBlock>
                        <TextBlock FontSize="14" Foreground="{StaticResource TextHintBrush}" HorizontalAlignment="Center" Margin="0,12,0,0">
                            <TextBlock.Text><Binding Source="{StaticResource Goals.NoGoalsHint}"/></TextBlock.Text>
                        </TextBlock>
                    </StackPanel>
                </Border>

                <ItemsControl ItemsSource="{Binding Goals}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Style="{StaticResource CardStyle}" Margin="0,0,16,16" Width="340">
                                <StackPanel>
                                    <Grid Margin="0,0,0,16">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding Name}" FontSize="18" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}"/>
                                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                                            <Button FontSize="16" FontWeight="Bold" Background="Transparent" BorderThickness="1"
                                                    BorderBrush="{StaticResource AccentBrush}" Foreground="{StaticResource AccentBrush}" Cursor="Hand"
                                                    Padding="8,2" Margin="0,0,8,0"
                                                    Command="{Binding DataContext.ShowProgressDialogCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                    CommandParameter="{Binding}">
                                                <Button.ToolTip><Binding Source="{StaticResource Goals.AddMoney}"/></Button.ToolTip>
                                                <Button.Content>+</Button.Content>
                                            </Button>
                                            <Button Content="x" FontSize="14" Background="Transparent" BorderThickness="0"
                                                    Foreground="{StaticResource TextHintBrush}" Cursor="Hand" Padding="4,0"
                                                    Command="{Binding DataContext.ConfirmDeleteCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                    CommandParameter="{Binding Id}"/>
                                        </StackPanel>
                                    </Grid>
                                    <Grid Margin="0,0,0,12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <ProgressBar Grid.Column="0" Value="{Binding Progress}" Maximum="100" Height="8"
                                                     Background="{StaticResource SurfaceBrush}" Foreground="{StaticResource AccentBrush}" Margin="0,0,12,0"/>
                                        <TextBlock Grid.Column="1" Text="{Binding Progress, StringFormat='{}{0:F1}%'}" FontSize="13" FontWeight="SemiBold"
                                                   Foreground="{StaticResource AccentBrush}"/>
                                    </Grid>
                                    <Grid Margin="0,0,0,12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="{DynamicResource Goals.CurrentAmount}" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"/>
                                            <TextBlock FontSize="18" FontWeight="Bold">
                                                <TextBlock.Text><Binding Path="CurrentAmount" Converter="{StaticResource CurrencyConv}"/></TextBlock.Text>
                                            </TextBlock>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                                            <TextBlock Text="{DynamicResource Goals.TargetAmount}" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"/>
                                            <TextBlock FontSize="18" FontWeight="Bold" Foreground="{StaticResource TextSecondaryBrush}">
                                                <TextBlock.Text><Binding Path="TargetAmount" Converter="{StaticResource CurrencyConv}"/></TextBlock.Text>
                                            </TextBlock>
                                        </StackPanel>
                                    </Grid>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock FontSize="12" Foreground="{StaticResource TextSecondaryBrush}">
                                            <TextBlock.Text><Binding Source="{StaticResource Goals.TargetDateLabel}"/></TextBlock.Text>
                                        </TextBlock>
                                        <TextBlock Text="{Binding TargetDate, StringFormat='yyyy-MM-dd'}" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                        <TextBlock FontSize="12" Foreground="{StaticResource TextSecondaryBrush}">
                                            <TextBlock.Text><Binding Source="{StaticResource Goals.RemainingLabel}"/></TextBlock.Text>
                                        </TextBlock>
                                        <TextBlock FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource AccentBrush}">
                                            <TextBlock.Text>
                                                <Binding Path="EstimatedMonthsRemaining" StringFormat="{DynamicResource Goals.MonthsFormat}"/>
                                            </TextBlock.Text>
                                        </TextBlock>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Add Dialog -->
                <Border Background="#80000000" Visibility="{Binding IsAddDialogOpen, Converter={StaticResource BoolToVis}}" Panel.ZIndex="100">
                    <Border Background="White" CornerRadius="20" Padding="32" Width="480" VerticalAlignment="Center" HorizontalAlignment="Center">
                        <StackPanel>
                            <TextBlock FontSize="22" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,24">
                                <TextBlock.Text><Binding Source="{StaticResource Goals.AddTitle}"/></TextBlock.Text>
                            </TextBlock>
                            <TextBlock FontSize="13" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,6">
                                <TextBlock.Text><Binding Source="{StaticResource Goals.Name}"/></TextBlock.Text>
                            </TextBlock>
                            <TextBox Text="{Binding NewName, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource InputStyle}" Margin="0,0,0,16"/>
                            <Grid Margin="0,0,0,16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="16"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock FontSize="13" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,6">
                                        <TextBlock.Text><Binding Source="{StaticResource Goals.TargetAmount}"/></TextBlock.Text>
                                    </TextBlock>
                                    <TextBox Text="{Binding NewTargetAmount, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource InputStyle}"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock FontSize="13" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,6">
                                        <TextBlock.Text><Binding Source="{StaticResource Goals.CurrentAmount}"/></TextBlock.Text>
                                    </TextBlock>
                                    <TextBox Text="{Binding NewCurrentAmount, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource InputStyle}"/>
                                </StackPanel>
                            </Grid>
                            <TextBlock FontSize="13" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,6">
                                <TextBlock.Text><Binding Source="{StaticResource Goals.TargetDate}"/></TextBlock.Text>
                            </TextBlock>
                            <DatePicker SelectedDate="{Binding NewTargetDate}" Margin="0,0,0,16"/>
                            <TextBlock FontSize="13" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,6">
                                <TextBlock.Text><Binding Source="{StaticResource Goals.Note}"/></TextBlock.Text>
                            </TextBlock>
                            <TextBox Text="{Binding NewNote, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource InputStyle}" Margin="0,0,0,24"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <Button Style="{StaticResource SecondaryButton}" Command="{Binding CancelAddCommand}" Margin="0,0,12,0">
                                    <Button.Content><Binding Source="{StaticResource Common.Cancel}"/></Button.Content>
                                </Button>
                                <Button Style="{StaticResource PrimaryButton}" Command="{Binding ConfirmAddCommand}">
                                    <Button.Content><Binding Source="{StaticResource Common.Add}"/></Button.Content>
                                </Button>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Border>

                <!-- Delete Confirmation -->
                <Border Background="#80000000" Visibility="{Binding IsConfirmDeleteOpen, Converter={StaticResource BoolToVis}}" Panel.ZIndex="100">
                    <Border Background="White" CornerRadius="20" Padding="32" Width="400" VerticalAlignment="Center" HorizontalAlignment="Center">
                        <StackPanel>
                            <TextBlock FontSize="22" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,12">
                                <TextBlock.Text><Binding Source="{StaticResource Goals.DeleteTitle}"/></TextBlock.Text>
                            </TextBlock>
                            <TextBlock FontSize="14" Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap" Margin="0,0,0,24">
                                <TextBlock.Text><Binding Source="{StaticResource Goals.DeleteMessage}"/></TextBlock.Text>
                            </TextBlock>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <Button Style="{StaticResource SecondaryButton}" Command="{Binding CancelDeleteCommand}" Margin="0,0,12,0">
                                    <Button.Content><Binding Source="{StaticResource Common.Cancel}"/></Button.Content>
                                </Button>
                                <Button Style="{StaticResource PrimaryButton}" Command="{Binding ExecuteDeleteCommand}" Background="{StaticResource ExpenseBrush}">
                                    <Button.Content><Binding Source="{StaticResource Common.Delete}"/></Button.Content>
                                </Button>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Border>

                <!-- Progress Dialog -->
                <Border Background="#80000000" Visibility="{Binding IsProgressDialogOpen, Converter={StaticResource BoolToVis}}" Panel.ZIndex="100">
                    <Border Background="White" CornerRadius="20" Padding="32" Width="400" VerticalAlignment="Center" HorizontalAlignment="Center">
                        <StackPanel>
                            <TextBlock FontSize="22" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,8">
                                <TextBlock.Text><Binding Source="{StaticResource Goals.ProgressTitle}"/></TextBlock.Text>
                            </TextBlock>
                            <TextBlock FontSize="14" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,20">
                                <Run><Run.Text><Binding Source="{StaticResource Goals.ProgressLabel}" Mode="OneWay"/></Run.Text></Run>
                                <Run Text="{Binding ProgressGoalName, Mode=OneWay}" FontWeight="SemiBold"/>
                            </TextBlock>
                            <TextBlock FontSize="13" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,6">
                                <TextBlock.Text><Binding Source="{StaticResource Goals.ProgressAmount}"/></TextBlock.Text>
                            </TextBlock>
                            <TextBox Text="{Binding ProgressAddAmount, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource InputStyle}" Margin="0,0,0,24"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <Button Style="{StaticResource SecondaryButton}" Command="{Binding CancelProgressCommand}" Margin="0,0,12,0">
                                    <Button.Content><Binding Source="{StaticResource Common.Cancel}"/></Button.Content>
                                </Button>
                                <Button Style="{StaticResource PrimaryButton}" Command="{Binding ConfirmProgressCommand}">
                                    <Button.Content><Binding Source="{StaticResource Common.Add}"/></Button.Content>
                                </Button>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
