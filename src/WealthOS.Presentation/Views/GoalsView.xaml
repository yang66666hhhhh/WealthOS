<UserControl x:Class="WealthOS.Presentation.Views.GoalsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:WealthOS.Presentation.Converters"
             xmlns:views="clr-namespace:WealthOS.Presentation.Views">

    <UserControl.Resources>
        <conv:CurrencyConverter x:Key="CurrencyConv"/>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>

    <Grid>
        <Border Background="{StaticResource PrimaryBrush}" 
                Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}"
                Panel.ZIndex="50" HorizontalAlignment="Stretch" VerticalAlignment="Top" Height="3"/>
        <views:ErrorBanner DataContext="{Binding}"/>

        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="28,24">
            <StackPanel MaxWidth="1200">
                <Grid Margin="0,0,0,24">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Style="{StaticResource PageTitleStyle}">
                        <TextBlock.Text><Binding Source="{StaticResource Goals.Title}"/></TextBlock.Text>
                    </TextBlock>
                    <Button Grid.Column="1" Style="{StaticResource PrimaryButton}" Command="{Binding ShowAddDialogCommand}" VerticalAlignment="Center">
                        <Button.Content><Binding Source="{StaticResource Goals.Add}"/></Button.Content>
                    </Button>
                </Grid>

                <!-- 空状态 -->
                <Border Padding="60">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <MultiDataTrigger>
                                    <MultiDataTrigger.Conditions>
                                        <Condition Binding="{Binding IsLoading}" Value="False"/>
                                        <Condition Binding="{Binding Goals.Count}" Value="0"/>
                                    </MultiDataTrigger.Conditions>
                                    <Setter Property="Visibility" Value="Visible"/>
                                </MultiDataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Style="{StaticResource EmptyStateIconStyle}" Text="&#x1F3AF;"/>
                        <TextBlock Style="{StaticResource EmptyStateTitleStyle}">
                            <TextBlock.Text><Binding Source="{StaticResource Goals.NoGoals}"/></TextBlock.Text>
                        </TextBlock>
                        <TextBlock Style="{StaticResource EmptyStateHintStyle}">
                            <TextBlock.Text><Binding Source="{StaticResource Goals.NoGoalsHint}"/></TextBlock.Text>
                        </TextBlock>
                    </StackPanel>
                </Border>

                <ItemsControl ItemsSource="{Binding Goals}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border CornerRadius="14" Padding="20" Margin="0,0,16,16" Width="340"
                                    BorderThickness="1" BorderBrush="{StaticResource BorderBrush}"
                                    Background="{StaticResource CardBackgroundBrush}">
                                <StackPanel>
                                    <!-- 标题行 -->
                                    <Grid Margin="0,0,0,16">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" Orientation="Horizontal">
                                            <Border Width="36" Height="36" CornerRadius="{StaticResource IconCornerRadius}" Margin="0,0,10,0">
                                                <Border.Background>
                                                    <SolidColorBrush Color="{StaticResource IconBgPurpleColor}"/>
                                                </Border.Background>
                                                <TextBlock Text="&#x1F3AF;" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <TextBlock Text="{Binding Name}" FontSize="15" FontWeight="SemiBold" 
                                                       Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                                            <Button FontSize="14" Background="Transparent" BorderThickness="0"
                                                    Foreground="{StaticResource AccentBrush}" Cursor="Hand" Padding="6,2"
                                                    ToolTip="{DynamicResource Tooltip.AddProgress}"
                                                    Command="{Binding DataContext.ShowProgressDialogCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                    CommandParameter="{Binding}">
                                                <Button.Content>&#x2795;</Button.Content>
                                            </Button>
                                            <Button Content="&#x270E;" FontSize="14" Background="Transparent" BorderThickness="0" 
                                                    Foreground="{StaticResource TextTertiaryBrush}" Cursor="Hand" Padding="6,2"
                                                    ToolTip="{DynamicResource Tooltip.Edit}"
                                                    Command="{Binding DataContext.ShowEditDialogCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}" CommandParameter="{Binding Id}"/>
                                            <Button Content="&#x2716;" FontSize="12" Background="Transparent" BorderThickness="0" 
                                                    Foreground="{StaticResource TextHintBrush}" Cursor="Hand" Padding="6,2"
                                                    ToolTip="{DynamicResource Tooltip.Delete}"
                                                    Command="{Binding DataContext.ConfirmDeleteCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                    CommandParameter="{Binding Id}"/>
                                        </StackPanel>
                                    </Grid>

                                    <!-- 进度条 -->
                                    <Grid Margin="0,0,0,12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <ProgressBar Grid.Column="0" Value="{Binding Progress, Mode=OneWay}" Maximum="100" Height="8"
                                                     Background="{StaticResource SurfaceBrush}" Foreground="{StaticResource AccentBrush}" Margin="0,0,12,0"/>
                                        <TextBlock Grid.Column="1" Text="{Binding Progress, StringFormat='{}{0:F1}%'}" FontSize="13" FontWeight="SemiBold"
                                                   Foreground="{StaticResource AccentBrush}"/>
                                    </Grid>

                                    <!-- 金额 -->
                                    <Grid Margin="0,0,0,12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock FontSize="11" Foreground="{StaticResource TextTertiaryBrush}">
                                                <TextBlock.Text><Binding Source="{StaticResource Goals.CurrentAmount}"/></TextBlock.Text>
                                            </TextBlock>
                                            <TextBlock FontSize="16" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}">
                                                <TextBlock.Text><Binding Path="CurrentAmount" Converter="{StaticResource CurrencyConv}"/></TextBlock.Text>
                                            </TextBlock>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                                            <TextBlock FontSize="11" Foreground="{StaticResource TextTertiaryBrush}">
                                                <TextBlock.Text><Binding Source="{StaticResource Goals.TargetAmount}"/></TextBlock.Text>
                                            </TextBlock>
                                            <TextBlock FontSize="16" FontWeight="Bold" Foreground="{StaticResource TextSecondaryBrush}">
                                                <TextBlock.Text><Binding Path="TargetAmount" Converter="{StaticResource CurrencyConv}"/></TextBlock.Text>
                                            </TextBlock>
                                        </StackPanel>
                                    </Grid>

                                    <!-- 详细信息 -->
                                    <Border CornerRadius="8" Padding="12" Background="{StaticResource SurfaceBrush}">
                                        <StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                                <TextBlock FontSize="12" Foreground="{StaticResource TextTertiaryBrush}">
                                                    <TextBlock.Text><Binding Source="{StaticResource Goals.TargetDateLabel}"/></TextBlock.Text>
                                                </TextBlock>
                                                <TextBlock Text="{Binding TargetDate, StringFormat='yyyy-MM-dd'}" FontSize="12" 
                                                           Foreground="{StaticResource TextPrimaryBrush}" Margin="8,0,0,0"/>
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock FontSize="12" Foreground="{StaticResource TextTertiaryBrush}">
                                                    <TextBlock.Text><Binding Source="{StaticResource Goals.RemainingLabel}"/></TextBlock.Text>
                                                </TextBlock>
                                                <TextBlock FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource AccentBrush}" Margin="8,0,0,0">
                                                    <TextBlock.Text>
                                                        <Binding Path="EstimatedMonthsRemaining" StringFormat="{StaticResource Goals.MonthsFormat}"/>
                                                    </TextBlock.Text>
                                                </TextBlock>
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Add Dialog -->
                <Border Background="{StaticResource DialogOverlayBrush}" Visibility="{Binding IsAddDialogOpen, Converter={StaticResource BoolToVis}}" Panel.ZIndex="100">
                    <Border.InputBindings>
                        <KeyBinding Key="Escape" Command="{Binding CancelAddCommand}"/>
                        <KeyBinding Key="Enter" Command="{Binding ConfirmAddCommand}"/>
                    </Border.InputBindings>
                    <Border Background="{StaticResource DialogBackgroundBrush}" CornerRadius="{StaticResource DialogCornerRadius}" Padding="32" Width="480" VerticalAlignment="Center" HorizontalAlignment="Center">
                        <StackPanel>
                            <TextBlock Style="{StaticResource DialogTitleStyle}">
                                <TextBlock.Text><Binding Source="{StaticResource Goals.AddTitle}"/></TextBlock.Text>
                            </TextBlock>
                            <TextBlock Style="{StaticResource LabelStyle}">
                                <TextBlock.Text><Binding Source="{StaticResource Goals.Name}"/></TextBlock.Text>
                            </TextBlock>
                            <TextBox Text="{Binding NewName, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource InputStyle}" Margin="0,0,0,16"/>
                            <Grid Margin="0,0,0,16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="16"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Style="{StaticResource LabelStyle}">
                                        <TextBlock.Text><Binding Source="{StaticResource Goals.TargetAmount}"/></TextBlock.Text>
                                    </TextBlock>
                                    <TextBox Text="{Binding NewTargetAmount, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource InputStyle}"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Style="{StaticResource LabelStyle}">
                                        <TextBlock.Text><Binding Source="{StaticResource Goals.CurrentAmount}"/></TextBlock.Text>
                                    </TextBlock>
                                    <TextBox Text="{Binding NewCurrentAmount, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource InputStyle}"/>
                                </StackPanel>
                            </Grid>
                            <TextBlock Style="{StaticResource LabelStyle}">
                                <TextBlock.Text><Binding Source="{StaticResource Goals.TargetDate}"/></TextBlock.Text>
                            </TextBlock>
                            <DatePicker SelectedDate="{Binding NewTargetDate}" Margin="0,0,0,16"/>
                            <TextBlock Style="{StaticResource LabelStyle}">
                                <TextBlock.Text><Binding Source="{StaticResource Goals.Note}"/></TextBlock.Text>
                            </TextBlock>
                            <TextBox Text="{Binding NewNote, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource InputStyle}" Margin="0,0,0,24"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <Button Style="{StaticResource SecondaryButton}" Command="{Binding CancelAddCommand}" Margin="0,0,12,0">
                                    <Button.Content><Binding Source="{StaticResource Common.Cancel}"/></Button.Content>
                                </Button>
                                <Button Style="{StaticResource PrimaryButton}" Command="{Binding ConfirmAddCommand}">
                                    <Button.Content><Binding Source="{StaticResource Common.Add}"/></Button.Content>
                                </Button>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Border>

                <!-- Delete Confirmation -->
                <Border Background="{StaticResource DialogOverlayBrush}" Visibility="{Binding IsConfirmDeleteOpen, Converter={StaticResource BoolToVis}}" Panel.ZIndex="100">
                    <Border.InputBindings>
                        <KeyBinding Key="Escape" Command="{Binding CancelDeleteCommand}"/>
                        <KeyBinding Key="Enter" Command="{Binding ExecuteDeleteCommand}"/>
                    </Border.InputBindings>
                    <Border Background="{StaticResource DialogBackgroundBrush}" CornerRadius="{StaticResource DialogCornerRadius}" Padding="32" Width="400" VerticalAlignment="Center" HorizontalAlignment="Center">
                        <StackPanel>
                            <TextBlock Style="{StaticResource DialogTitleStyle}">
                                <TextBlock.Text><Binding Source="{StaticResource Goals.DeleteTitle}"/></TextBlock.Text>
                            </TextBlock>
                            <TextBlock FontSize="14" Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap" Margin="0,0,0,24">
                                <TextBlock.Text><Binding Source="{StaticResource Goals.DeleteMessage}"/></TextBlock.Text>
                            </TextBlock>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <Button Style="{StaticResource SecondaryButton}" Command="{Binding CancelDeleteCommand}" Margin="0,0,12,0">
                                    <Button.Content><Binding Source="{StaticResource Common.Cancel}"/></Button.Content>
                                </Button>
                                <Button Style="{StaticResource DangerButton}" Command="{Binding ExecuteDeleteCommand}">
                                    <Button.Content><Binding Source="{StaticResource Common.Delete}"/></Button.Content>
                                </Button>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Border>

                <!-- Edit Dialog -->
                <Border Background="{StaticResource DialogOverlayBrush}" Visibility="{Binding IsEditDialogOpen, Converter={StaticResource BoolToVis}}" Panel.ZIndex="100">
                    <Border.InputBindings>
                        <KeyBinding Key="Escape" Command="{Binding CancelEditCommand}"/>
                        <KeyBinding Key="Enter" Command="{Binding ConfirmEditCommand}"/>
                    </Border.InputBindings>
                    <Border Background="{StaticResource DialogBackgroundBrush}" CornerRadius="{StaticResource DialogCornerRadius}" Padding="32" Width="480" VerticalAlignment="Center" HorizontalAlignment="Center">
                        <StackPanel>
                            <TextBlock Style="{StaticResource DialogTitleStyle}">
                                <TextBlock.Text><Binding Source="{StaticResource Goals.EditTitle}"/></TextBlock.Text>
                            </TextBlock>
                            <TextBlock Style="{StaticResource LabelStyle}">
                                <TextBlock.Text><Binding Source="{StaticResource Goals.Name}"/></TextBlock.Text>
                            </TextBlock>
                            <TextBox Text="{Binding NewName, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource InputStyle}" Margin="0,0,0,16"/>
                            <Grid Margin="0,0,0,16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="16"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Style="{StaticResource LabelStyle}">
                                        <TextBlock.Text><Binding Source="{StaticResource Goals.TargetAmount}"/></TextBlock.Text>
                                    </TextBlock>
                                    <TextBox Text="{Binding NewTargetAmount, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource InputStyle}"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Style="{StaticResource LabelStyle}">
                                        <TextBlock.Text><Binding Source="{StaticResource Goals.CurrentAmount}"/></TextBlock.Text>
                                    </TextBlock>
                                    <TextBox Text="{Binding NewCurrentAmount, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource InputStyle}"/>
                                </StackPanel>
                            </Grid>
                            <TextBlock Style="{StaticResource LabelStyle}">
                                <TextBlock.Text><Binding Source="{StaticResource Goals.TargetDate}"/></TextBlock.Text>
                            </TextBlock>
                            <DatePicker SelectedDate="{Binding NewTargetDate}" Margin="0,0,0,16"/>
                            <TextBlock Style="{StaticResource LabelStyle}">
                                <TextBlock.Text><Binding Source="{StaticResource Goals.Note}"/></TextBlock.Text>
                            </TextBlock>
                            <TextBox Text="{Binding NewNote, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource InputStyle}" Margin="0,0,0,24"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <Button Style="{StaticResource SecondaryButton}" Command="{Binding CancelEditCommand}" Margin="0,0,12,0">
                                    <Button.Content><Binding Source="{StaticResource Common.Cancel}"/></Button.Content>
                                </Button>
                                <Button Style="{StaticResource PrimaryButton}" Command="{Binding ConfirmEditCommand}">
                                    <Button.Content><Binding Source="{StaticResource Common.Save}"/></Button.Content>
                                </Button>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Border>

                <!-- Progress Dialog -->
                <Border Background="{StaticResource DialogOverlayBrush}" Visibility="{Binding IsProgressDialogOpen, Converter={StaticResource BoolToVis}}" Panel.ZIndex="100">
                    <Border.InputBindings>
                        <KeyBinding Key="Escape" Command="{Binding CancelProgressCommand}"/>
                        <KeyBinding Key="Enter" Command="{Binding ConfirmProgressCommand}"/>
                    </Border.InputBindings>
                    <Border Background="{StaticResource DialogBackgroundBrush}" CornerRadius="{StaticResource DialogCornerRadius}" Padding="32" Width="400" VerticalAlignment="Center" HorizontalAlignment="Center">
                        <StackPanel>
                            <TextBlock FontSize="22" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,8">
                                <TextBlock.Text><Binding Source="{StaticResource Goals.ProgressTitle}"/></TextBlock.Text>
                            </TextBlock>
                            <TextBlock FontSize="14" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,20">
                                <Run><Run.Text><Binding Source="{StaticResource Goals.ProgressLabel}" Mode="OneWay"/></Run.Text></Run>
                                <Run Text="{Binding ProgressGoalName, Mode=OneWay}" FontWeight="SemiBold"/>
                            </TextBlock>
                            <TextBlock Style="{StaticResource LabelStyle}">
                                <TextBlock.Text><Binding Source="{StaticResource Goals.ProgressAmount}"/></TextBlock.Text>
                            </TextBlock>
                            <TextBox Text="{Binding ProgressAddAmount, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource InputStyle}" Margin="0,0,0,24"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <Button Style="{StaticResource SecondaryButton}" Command="{Binding CancelProgressCommand}" Margin="0,0,12,0">
                                    <Button.Content><Binding Source="{StaticResource Common.Cancel}"/></Button.Content>
                                </Button>
                                <Button Style="{StaticResource PrimaryButton}" Command="{Binding ConfirmProgressCommand}">
                                    <Button.Content><Binding Source="{StaticResource Common.Add}"/></Button.Content>
                                </Button>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
