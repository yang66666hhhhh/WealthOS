<UserControl x:Class="WealthOS.Presentation.Views.ReportsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
             xmlns:conv="clr-namespace:WealthOS.Presentation.Converters">

    <UserControl.Resources>
        <conv:CurrencyConverter x:Key="CurrencyConv"/>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>

    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="32,24">
            <StackPanel MaxWidth="1200">
                <!-- Header -->
                <Grid Margin="0,0,0,24">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Style="{StaticResource PageTitleStyle}">
                        <TextBlock.Text><Binding Source="{StaticResource Reports.Title}"/></TextBlock.Text>
                    </TextBlock>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button Margin="0,0,8,0" Padding="12,6" FontSize="12" Background="Transparent" BorderThickness="1"
                                BorderBrush="{StaticResource BorderBrush}" Cursor="Hand"
                                Command="{Binding ExportCsvCommand}">
                            <Button.Content><Binding Source="{StaticResource Reports.ExportCsv}"/></Button.Content>
                        </Button>
                    </StackPanel>
                </Grid>

                <!-- Year Selector -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                    <Button Content="2026" Margin="0,0,8,0" Padding="12,6" FontSize="12"
                            Background="Transparent" BorderThickness="1"
                            BorderBrush="{StaticResource BorderBrush}" Cursor="Hand"
                            Command="{Binding ChangeYearCommand}" CommandParameter="2026"/>
                    <Button Content="2025" Margin="0,0,8,0" Padding="12,6" FontSize="12"
                            Background="Transparent" BorderThickness="1"
                            BorderBrush="{StaticResource BorderBrush}" Cursor="Hand"
                            Command="{Binding ChangeYearCommand}" CommandParameter="2025"/>
                    <Button Content="2024" Margin="0,0,8,0" Padding="12,6" FontSize="12"
                            Background="Transparent" BorderThickness="1"
                            BorderBrush="{StaticResource BorderBrush}" Cursor="Hand"
                            Command="{Binding ChangeYearCommand}" CommandParameter="2024"/>
                </StackPanel>

                <ProgressBar IsIndeterminate="True" Height="3" Margin="0,0,0,16"
                             Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}"
                             Background="Transparent" Foreground="{StaticResource PrimaryBrush}"/>

                <!-- Summary Cards -->
                <Grid Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock FontSize="13" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,8">
                                <TextBlock.Text><Binding Source="{StaticResource Reports.TotalIncome}"/></TextBlock.Text>
                            </TextBlock>
                            <TextBlock FontSize="28" FontWeight="Bold" Foreground="{StaticResource IncomeBrush}">
                                <TextBlock.Text><Binding Path="Report.TotalIncome" Converter="{StaticResource CurrencyConv}"/></TextBlock.Text>
                            </TextBlock>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="2" Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock FontSize="13" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,8">
                                <TextBlock.Text><Binding Source="{StaticResource Reports.TotalExpense}"/></TextBlock.Text>
                            </TextBlock>
                            <TextBlock FontSize="28" FontWeight="Bold" Foreground="{StaticResource ExpenseBrush}">
                                <TextBlock.Text><Binding Path="Report.TotalExpense" Converter="{StaticResource CurrencyConv}"/></TextBlock.Text>
                            </TextBlock>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="4" Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock FontSize="13" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,8">
                                <TextBlock.Text><Binding Source="{StaticResource Reports.SavingsRate}"/></TextBlock.Text>
                            </TextBlock>
                            <TextBlock FontSize="28" FontWeight="Bold" Foreground="{StaticResource AccentBrush}">
                                <TextBlock.Text><Binding Path="Report.SavingsRate" StringFormat="{}{0:F1}%"/></TextBlock.Text>
                            </TextBlock>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="6" Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock FontSize="13" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,8">
                                <TextBlock.Text><Binding Source="{StaticResource Reports.NetWorthGrowth}"/></TextBlock.Text>
                            </TextBlock>
                            <TextBlock FontSize="28" FontWeight="Bold" Foreground="{StaticResource AccentBrush}">
                                <TextBlock.Text><Binding Path="Report.NetWorthGrowth" Converter="{StaticResource CurrencyConv}"/></TextBlock.Text>
                            </TextBlock>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- Monthly Breakdown Chart -->
                <Border Style="{StaticResource CardStyle}" Margin="0,0,0,20">
                    <StackPanel>
                        <TextBlock Style="{StaticResource SectionTitleStyle}">
                            <TextBlock.Text><Binding Source="{StaticResource Reports.MonthlyBreakdown}"/></TextBlock.Text>
                        </TextBlock>
                        <ItemsControl ItemsSource="{Binding Report.MonthlyBreakdown}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="8,6" BorderThickness="0,0,0,1" BorderBrush="{StaticResource BorderBrush}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="80"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="{Binding Month}" FontSize="14" VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="1" FontSize="14" Foreground="{StaticResource IncomeBrush}" VerticalAlignment="Center">
                                                <Run Text="+"/><Run Text="{Binding Income, StringFormat='￥{0:N0}'}"/>
                                            </TextBlock>
                                            <TextBlock Grid.Column="2" FontSize="14" Foreground="{StaticResource ExpenseBrush}" VerticalAlignment="Center">
                                                <Run Text="-"/><Run Text="{Binding Expense, StringFormat='￥{0:N0}'}"/>
                                            </TextBlock>
                                            <TextBlock Grid.Column="3" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center">
                                                <TextBlock.Text><Binding Path="Savings" Converter="{StaticResource CurrencyConv}"/></TextBlock.Text>
                                            </TextBlock>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <!-- Top Categories -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock Style="{StaticResource SectionTitleStyle}">
                                <TextBlock.Text><Binding Source="{StaticResource Reports.TopExpense}"/></TextBlock.Text>
                            </TextBlock>
                            <ItemsControl ItemsSource="{Binding Report.TopExpenseCategories}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Padding="0,8" BorderThickness="0,0,0,1" BorderBrush="{StaticResource BorderBrush}">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0">
                                                    <TextBlock Text="{Binding Category}" FontSize="14" Foreground="{StaticResource TextPrimaryBrush}"/>
                                                    <TextBlock Text="{Binding Percentage, StringFormat='{}{0:F1}%'}" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"/>
                                                </StackPanel>
                                                <TextBlock Grid.Column="1" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource ExpenseBrush}">
                                                    <Run Text="-"/><Run Text="{Binding Amount, StringFormat='￥{0:N0}'}"/>
                                                </TextBlock>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="2" Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock Style="{StaticResource SectionTitleStyle}">
                                <TextBlock.Text><Binding Source="{StaticResource Reports.TopIncome}"/></TextBlock.Text>
                            </TextBlock>
                            <ItemsControl ItemsSource="{Binding Report.TopIncomeCategories}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Padding="0,8" BorderThickness="0,0,0,1" BorderBrush="{StaticResource BorderBrush}">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0">
                                                    <TextBlock Text="{Binding Category}" FontSize="14" Foreground="{StaticResource TextPrimaryBrush}"/>
                                                    <TextBlock Text="{Binding Percentage, StringFormat='{}{0:F1}%'}" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"/>
                                                </StackPanel>
                                                <TextBlock Grid.Column="1" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource IncomeBrush}">
                                                    <Run Text="+"/><Run Text="{Binding Amount, StringFormat='￥{0:N0}'}"/>
                                                </TextBlock>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>
                </Grid>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
