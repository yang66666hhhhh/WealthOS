<UserControl x:Class="WealthOS.Presentation.Views.ReportsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
             xmlns:conv="clr-namespace:WealthOS.Presentation.Converters"
             xmlns:views="clr-namespace:WealthOS.Presentation.Views">

    <UserControl.Resources>
        <conv:CurrencyConverter x:Key="CurrencyConv"/>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>

    <Grid>
        <Border Background="{StaticResource PrimaryBrush}" 
                Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}"
                Panel.ZIndex="50" HorizontalAlignment="Stretch" VerticalAlignment="Top" Height="3"/>

        <views:ErrorBanner DataContext="{Binding}"/>

        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="28,24">
            <StackPanel MaxWidth="1200">
                <!-- 页面标题 -->
                <Grid Margin="0,0,0,24">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Style="{StaticResource PageTitleStyle}">
                            <TextBlock.Text><Binding Source="{StaticResource Reports.Title}"/></TextBlock.Text>
                        </TextBlock>
                        <!-- 年份选择器 -->
                        <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                            <Button Content="2026" Margin="0,0,8,0" Padding="12,6" FontSize="12" Cursor="Hand"
                                    Command="{Binding ChangeYearCommand}" CommandParameter="2026">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource SecondaryButton}">
                                        <Setter Property="Padding" Value="12,6"/>
                                        <Setter Property="FontSize" Value="12"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SelectedYear}" Value="2026">
                                                <Setter Property="Background" Value="{StaticResource PrimaryBrush}"/>
                                                <Setter Property="Foreground" Value="White"/>
                                                <Setter Property="BorderThickness" Value="0"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                            <Button Content="2025" Margin="0,0,8,0" Padding="12,6" FontSize="12" Cursor="Hand"
                                    Command="{Binding ChangeYearCommand}" CommandParameter="2025">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource SecondaryButton}">
                                        <Setter Property="Padding" Value="12,6"/>
                                        <Setter Property="FontSize" Value="12"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SelectedYear}" Value="2025">
                                                <Setter Property="Background" Value="{StaticResource PrimaryBrush}"/>
                                                <Setter Property="Foreground" Value="White"/>
                                                <Setter Property="BorderThickness" Value="0"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                            <Button Content="2024" Margin="0,0,8,0" Padding="12,6" FontSize="12" Cursor="Hand"
                                    Command="{Binding ChangeYearCommand}" CommandParameter="2024">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource SecondaryButton}">
                                        <Setter Property="Padding" Value="12,6"/>
                                        <Setter Property="FontSize" Value="12"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SelectedYear}" Value="2024">
                                                <Setter Property="Background" Value="{StaticResource PrimaryBrush}"/>
                                                <Setter Property="Foreground" Value="White"/>
                                                <Setter Property="BorderThickness" Value="0"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </StackPanel>
                    </StackPanel>
                    <Button Grid.Column="1" Style="{StaticResource SecondaryButton}" 
                            Command="{Binding ExportCsvCommand}" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#x1F4E5;" FontSize="14" Margin="0,0,8,0"/>
                            <TextBlock Text="{DynamicResource Reports.ExportCsv}"/>
                        </StackPanel>
                    </Button>
                    <Button Grid.Column="1" Style="{StaticResource SecondaryButton}" 
                            Command="{Binding ExportPdfCommand}" VerticalAlignment="Center" Margin="8,0,0,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#x1F4D1;" FontSize="14" Margin="0,0,8,0"/>
                            <TextBlock Text="{DynamicResource Reports.ExportPdf}"/>
                        </StackPanel>
                    </Button>
                    <Button Grid.Column="1" Style="{StaticResource SecondaryButton}" 
                            Command="{Binding ShowImportDialogCommand}" VerticalAlignment="Center" Margin="8,0,0,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#x1F4E4;" FontSize="14" Margin="0,0,8,0"/>
                            <TextBlock Text="{DynamicResource Reports.ImportCsv}"/>
                        </StackPanel>
                    </Button>
                </Grid>

                <TextBlock Text="{Binding StatusMessage}" FontSize="12" Foreground="{StaticResource IncomeBrush}" Margin="0,8,0,0" Visibility="{Binding StatusMessage, Converter={StaticResource BoolToVis}}"/>

                <!-- 空状态 -->
                <Border Padding="60" Visibility="Collapsed">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding HasReport}" Value="False">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Style="{StaticResource EmptyStateIconStyle}" Text="&#x1F4CA;"/>
                        <TextBlock Style="{StaticResource EmptyStateTitleStyle}">
                            <TextBlock.Text><Binding Source="{StaticResource Reports.NoData}"/></TextBlock.Text>
                        </TextBlock>
                        <TextBlock Style="{StaticResource EmptyStateHintStyle}">
                            <TextBlock.Text><Binding Source="{StaticResource Reports.NoDataHint}"/></TextBlock.Text>
                        </TextBlock>
                    </StackPanel>
                </Border>

                <!-- KPI 统计卡片 -->
                <Grid Margin="0,0,0,20" Visibility="{Binding HasReport, Converter={StaticResource BoolToVis}}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- 总收入 -->
                    <Border Grid.Column="0" CornerRadius="14" Padding="20,16"
                            BorderThickness="1" BorderBrush="{StaticResource BorderBrush}"
                            Background="{StaticResource CardBackgroundBrush}">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                <Border Width="36" Height="36" CornerRadius="{StaticResource IconCornerRadius}" Margin="0,0,12,0">
                                    <Border.Background>
                                        <SolidColorBrush Color="{StaticResource IconBgGreenColor}"/>
                                    </Border.Background>
                                    <TextBlock Text="&#x2191;" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center"
                                               Foreground="{StaticResource IncomeBrush}"/>
                                </Border>
                                <TextBlock Text="{DynamicResource Reports.TotalIncome}" FontSize="12" 
                                           Foreground="{StaticResource TextTertiaryBrush}" VerticalAlignment="Center"/>
                            </StackPanel>
                            <TextBlock FontSize="22" FontWeight="Bold" Foreground="{StaticResource IncomeBrush}">
                                <TextBlock.Text><Binding Path="Report.TotalIncome" Converter="{StaticResource CurrencyConv}"/></TextBlock.Text>
                            </TextBlock>
                        </StackPanel>
                    </Border>

                    <!-- 总支出 -->
                    <Border Grid.Column="2" CornerRadius="14" Padding="20,16"
                            BorderThickness="1" BorderBrush="{StaticResource BorderBrush}"
                            Background="{StaticResource CardBackgroundBrush}">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                <Border Width="36" Height="36" CornerRadius="{StaticResource IconCornerRadius}" Margin="0,0,12,0">
                                    <Border.Background>
                                        <SolidColorBrush Color="{StaticResource IconBgRedColor}"/>
                                    </Border.Background>
                                    <TextBlock Text="&#x2193;" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center"
                                               Foreground="{StaticResource ExpenseBrush}"/>
                                </Border>
                                <TextBlock Text="{DynamicResource Reports.TotalExpense}" FontSize="12" 
                                           Foreground="{StaticResource TextTertiaryBrush}" VerticalAlignment="Center"/>
                            </StackPanel>
                            <TextBlock FontSize="22" FontWeight="Bold" Foreground="{StaticResource ExpenseBrush}">
                                <TextBlock.Text><Binding Path="Report.TotalExpense" Converter="{StaticResource CurrencyConv}"/></TextBlock.Text>
                            </TextBlock>
                        </StackPanel>
                    </Border>

                    <!-- 储蓄率 -->
                    <Border Grid.Column="4" CornerRadius="14" Padding="20,16"
                            BorderThickness="1" BorderBrush="{StaticResource BorderBrush}"
                            Background="{StaticResource CardBackgroundBrush}">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                <Border Width="36" Height="36" CornerRadius="{StaticResource IconCornerRadius}" Margin="0,0,12,0">
                                    <Border.Background>
                                        <SolidColorBrush Color="{StaticResource IconBgPurpleColor}"/>
                                    </Border.Background>
                                    <TextBlock Text="&#x1F3AF;" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="{DynamicResource Reports.SavingsRate}" FontSize="12" 
                                           Foreground="{StaticResource TextTertiaryBrush}" VerticalAlignment="Center"/>
                            </StackPanel>
                            <TextBlock FontSize="22" FontWeight="Bold" Foreground="{StaticResource AccentBrush}">
                                <TextBlock.Text><Binding Path="Report.SavingsRate" StringFormat="{}{0:F1}%"/></TextBlock.Text>
                            </TextBlock>
                        </StackPanel>
                    </Border>

                    <!-- 净资产增长 -->
                    <Border Grid.Column="6" CornerRadius="14" Padding="20,16"
                            BorderThickness="1" BorderBrush="{StaticResource BorderBrush}"
                            Background="{StaticResource CardBackgroundBrush}">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                <Border Width="36" Height="36" CornerRadius="{StaticResource IconCornerRadius}" Margin="0,0,12,0">
                                    <Border.Background>
                                        <SolidColorBrush Color="{StaticResource IconBgGreenColor}"/>
                                    </Border.Background>
                                    <TextBlock Text="&#x1F4C8;" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="{DynamicResource Reports.NetWorthGrowth}" FontSize="12" 
                                           Foreground="{StaticResource TextTertiaryBrush}" VerticalAlignment="Center"/>
                            </StackPanel>
                            <TextBlock FontSize="22" FontWeight="Bold" Foreground="{StaticResource AccentBrush}">
                                <TextBlock.Text><Binding Path="Report.NetWorthGrowth" Converter="{StaticResource CurrencyConv}"/></TextBlock.Text>
                            </TextBlock>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- 月度明细 -->
                <Border CornerRadius="14" Padding="20" Margin="0,0,0,20"
                        BorderThickness="1" BorderBrush="{StaticResource BorderBrush}"
                        Background="{StaticResource CardBackgroundBrush}"
                        Visibility="{Binding HasReport, Converter={StaticResource BoolToVis}}">
                    <StackPanel>
                        <TextBlock Text="{DynamicResource Reports.MonthlyBreakdown}" 
                                   FontSize="15" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,16"/>
                        <ItemsControl ItemsSource="{Binding Report.MonthlyBreakdown}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="12,10" BorderThickness="0,0,0,1" BorderBrush="{StaticResource BorderLightBrush}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="80"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="{Binding Month}" FontSize="14" FontWeight="Medium" 
                                                       VerticalAlignment="Center" Foreground="{StaticResource TextPrimaryBrush}"/>
                                            <TextBlock Grid.Column="1" FontSize="14" Foreground="{StaticResource IncomeBrush}" VerticalAlignment="Center">
                                                <Run Text="+"/><Run><Run.Text><Binding Path="Income" Converter="{StaticResource CurrencyConv}"/></Run.Text></Run>
                                            </TextBlock>
                                            <TextBlock Grid.Column="2" FontSize="14" Foreground="{StaticResource ExpenseBrush}" VerticalAlignment="Center">
                                                <Run Text="-"/><Run><Run.Text><Binding Path="Expense" Converter="{StaticResource CurrencyConv}"/></Run.Text></Run>
                                            </TextBlock>
                                            <TextBlock Grid.Column="3" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center">
                                                <TextBlock.Text><Binding Path="Savings" Converter="{StaticResource CurrencyConv}"/></TextBlock.Text>
                                            </TextBlock>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <!-- 收支排行 -->
                <Grid Visibility="{Binding HasReport, Converter={StaticResource BoolToVis}}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- 支出排行 -->
                    <Border Grid.Column="0" CornerRadius="14" Padding="20"
                            BorderThickness="1" BorderBrush="{StaticResource BorderBrush}"
                            Background="{StaticResource CardBackgroundBrush}">
                        <StackPanel>
                            <TextBlock Text="{DynamicResource Reports.TopExpense}" 
                                       FontSize="15" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,16"/>
                            <ItemsControl ItemsSource="{Binding Report.TopExpenseCategories}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Padding="0,10" BorderThickness="0,0,0,1" BorderBrush="{StaticResource BorderLightBrush}">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0">
                                                    <TextBlock Text="{Binding Category}" FontSize="14" Foreground="{StaticResource TextPrimaryBrush}"/>
                                                    <TextBlock Text="{Binding Percentage, StringFormat='{}{0:F1}%'}" FontSize="12" 
                                                               Foreground="{StaticResource TextTertiaryBrush}"/>
                                                </StackPanel>
                                                <TextBlock Grid.Column="1" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource ExpenseBrush}"
                                                           VerticalAlignment="Center">
                                                     <Run Text="-"/><Run><Run.Text><Binding Path="Amount" Converter="{StaticResource CurrencyConv}"/></Run.Text></Run>
                                                </TextBlock>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <!-- 收入排行 -->
                    <Border Grid.Column="2" CornerRadius="14" Padding="20"
                            BorderThickness="1" BorderBrush="{StaticResource BorderBrush}"
                            Background="{StaticResource CardBackgroundBrush}">
                        <StackPanel>
                            <TextBlock Text="{DynamicResource Reports.TopIncome}" 
                                       FontSize="15" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,16"/>
                            <ItemsControl ItemsSource="{Binding Report.TopIncomeCategories}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Padding="0,10" BorderThickness="0,0,0,1" BorderBrush="{StaticResource BorderLightBrush}">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0">
                                                    <TextBlock Text="{Binding Category}" FontSize="14" Foreground="{StaticResource TextPrimaryBrush}"/>
                                                    <TextBlock Text="{Binding Percentage, StringFormat='{}{0:F1}%'}" FontSize="12" 
                                                               Foreground="{StaticResource TextTertiaryBrush}"/>
                                                </StackPanel>
                                                <TextBlock Grid.Column="1" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource IncomeBrush}"
                                                           VerticalAlignment="Center">
                                                     <Run Text="+"/><Run><Run.Text><Binding Path="Amount" Converter="{StaticResource CurrencyConv}"/></Run.Text></Run>
                                                </TextBlock>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>
                </Grid>

                <Border Height="20"/>
            </StackPanel>
        </ScrollViewer>

        <!-- Import Dialog -->
        <Border Background="{StaticResource DialogOverlayBrush}" Visibility="{Binding IsImportDialogOpen, Converter={StaticResource BoolToVis}}" Panel.ZIndex="100">
            <Border.InputBindings>
                <KeyBinding Key="Escape" Command="{Binding CancelImportCommand}"/>
            </Border.InputBindings>
            <Border Background="{StaticResource DialogBackgroundBrush}" CornerRadius="{StaticResource CardCornerRadius}" Padding="28" Width="440" VerticalAlignment="Center" HorizontalAlignment="Center">
                <StackPanel>
                    <TextBlock Style="{StaticResource DialogTitleStyle}">
                        <TextBlock.Text><Binding Source="{StaticResource Reports.ImportTitle}"/></TextBlock.Text>
                    </TextBlock>
                    <TextBlock Style="{StaticResource LabelStyle}">
                        <TextBlock.Text><Binding Source="{StaticResource Reports.ImportAccount}"/></TextBlock.Text>
                    </TextBlock>
                    <ComboBox ItemsSource="{Binding Accounts}" SelectedItem="{Binding SelectedAccount}" DisplayMemberPath="Name" Margin="0,0,0,24"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Style="{StaticResource SecondaryButton}" Command="{Binding CancelImportCommand}" Margin="0,0,12,0">
                            <Button.Content><Binding Source="{StaticResource Common.Cancel}"/></Button.Content>
                        </Button>
                        <Button Style="{StaticResource PrimaryButton}" Command="{Binding ConfirmImportCommand}">
                            <Button.Content><Binding Source="{StaticResource Common.Confirm}"/></Button.Content>
                        </Button>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Border>
    </Grid>
</UserControl>
