<UserControl x:Class="WealthOS.Presentation.Views.LiabilitiesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:WealthOS.Presentation.Converters"
             xmlns:enums="clr-namespace:WealthOS.Domain.Enums;assembly=WealthOS.Domain"
             xmlns:views="clr-namespace:WealthOS.Presentation.Views">

    <UserControl.Resources>
        <conv:CurrencyConverter x:Key="CurrencyConv"/>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <ObjectDataProvider x:Key="LiabilityTypes" MethodName="GetValues" ObjectType="{x:Type enums:LiabilityType}">
            <ObjectDataProvider.MethodParameters><x:Type TypeName="enums:LiabilityType"/></ObjectDataProvider.MethodParameters>
        </ObjectDataProvider>
    </UserControl.Resources>

    <Grid>
        <Border Background="{StaticResource PrimaryBrush}" 
                Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}"
                Panel.ZIndex="50" HorizontalAlignment="Stretch" VerticalAlignment="Top" Height="3"/>
        <views:ErrorBanner DataContext="{Binding}"/>

        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="28,24">
            <StackPanel MaxWidth="1200">
                <Grid Margin="0,0,0,24">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Style="{StaticResource PageTitleStyle}">
                        <TextBlock.Text><Binding Source="{StaticResource Liabilities.Title}"/></TextBlock.Text>
                    </TextBlock>
                    <Button Grid.Column="1" Style="{StaticResource PrimaryButton}" Command="{Binding ShowAddDialogCommand}" VerticalAlignment="Center">
                        <Button.Content><Binding Source="{StaticResource Liabilities.Add}"/></Button.Content>
                    </Button>
                </Grid>

                <!-- 负债总额卡片 -->
                <Border CornerRadius="{StaticResource CardCornerRadius}" Padding="24,20" Margin="0,0,0,20"
                        BorderThickness="1" BorderBrush="{StaticResource BorderBrush}"
                        Background="{StaticResource CardBackgroundBrush}">
                    <Grid>
                        <StackPanel>
                            <TextBlock FontSize="13" Foreground="{StaticResource TextTertiaryBrush}" Margin="0,0,0,8" FontWeight="Medium">
                                <TextBlock.Text><Binding Source="{StaticResource Liabilities.TotalLiabilities}"/></TextBlock.Text>
                            </TextBlock>
                            <TextBlock FontSize="36" FontWeight="Bold" Foreground="{StaticResource ExpenseBrush}">
                                <TextBlock.Text><Binding Path="TotalBalance" Converter="{StaticResource CurrencyConv}"/></TextBlock.Text>
                            </TextBlock>
                        </StackPanel>
                        <Border Width="48" Height="48" CornerRadius="12" HorizontalAlignment="Right" VerticalAlignment="Top">
                            <Border.Background>
                                <SolidColorBrush Color="{StaticResource ExpenseLightColor}"/>
                            </Border.Background>
                            <TextBlock Text="&#x1F4B8;" FontSize="22" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </Grid>
                </Border>

                <!-- 空状态 -->
                <Border Padding="60">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <MultiDataTrigger>
                                    <MultiDataTrigger.Conditions>
                                        <Condition Binding="{Binding IsLoading}" Value="False"/>
                                        <Condition Binding="{Binding Liabilities.Count}" Value="0"/>
                                    </MultiDataTrigger.Conditions>
                                    <Setter Property="Visibility" Value="Visible"/>
                                </MultiDataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Style="{StaticResource EmptyStateIconStyle}" Text="&#x1F4C9;"/>
                        <TextBlock Style="{StaticResource EmptyStateTitleStyle}">
                            <TextBlock.Text><Binding Source="{StaticResource Liabilities.NoLiabilities}"/></TextBlock.Text>
                        </TextBlock>
                        <TextBlock Style="{StaticResource EmptyStateHintStyle}">
                            <TextBlock.Text><Binding Source="{StaticResource Liabilities.NoLiabilitiesHint}"/></TextBlock.Text>
                        </TextBlock>
                    </StackPanel>
                </Border>

                <ItemsControl ItemsSource="{Binding Liabilities}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border CornerRadius="{StaticResource CardCornerRadius}" Padding="20" Margin="0,0,16,16" Width="300"
                                    BorderThickness="1" BorderBrush="{StaticResource BorderBrush}"
                                    Background="{StaticResource CardBackgroundBrush}">
                                <StackPanel>
                                    <Grid Margin="0,0,0,16">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <!-- 机构标签 -->
                                        <Border Grid.Column="0" CornerRadius="6" Padding="8,4" 
                                                Background="{StaticResource SurfaceBrush}" HorizontalAlignment="Left">
                                            <TextBlock Text="{Binding Institution}" FontSize="11" 
                                                       Foreground="{StaticResource TextTertiaryBrush}" FontWeight="Medium"/>
                                        </Border>
                                        <!-- 操作按钮 -->
                                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                                            <Button Content="&#x270E;" FontSize="14" Background="Transparent" BorderThickness="0" 
                                                    Foreground="{StaticResource TextTertiaryBrush}" Cursor="Hand" Padding="6,2"
                                                    ToolTip="{DynamicResource Tooltip.Edit}"
                                                    Command="{Binding DataContext.ShowEditDialogCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                    CommandParameter="{Binding}"/>
                                            <Button Content="&#x2716;" FontSize="12" Background="Transparent" BorderThickness="0" 
                                                    Foreground="{StaticResource TextHintBrush}" Cursor="Hand" Padding="6,2"
                                                    ToolTip="{DynamicResource Tooltip.Delete}"
                                                    Command="{Binding DataContext.ConfirmDeleteCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                    CommandParameter="{Binding Id}"/>
                                        </StackPanel>
                                    </Grid>
                                    <!-- 负债名称 -->
                                    <TextBlock Text="{Binding Name}" FontSize="15" FontWeight="SemiBold" 
                                               Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,12"/>
                                    <!-- 金额 -->
                                    <TextBlock FontSize="24" FontWeight="Bold" Foreground="{StaticResource ExpenseBrush}">
                                        <TextBlock.Text><Binding Path="Balance" Converter="{StaticResource CurrencyConv}"/></TextBlock.Text>
                                    </TextBlock>
                                    <!-- 详细信息 -->
                                    <Grid Margin="0,16,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock FontSize="11" Foreground="{StaticResource TextTertiaryBrush}">
                                                <TextBlock.Text><Binding Source="{StaticResource Liabilities.InterestRateLabel}"/></TextBlock.Text>
                                            </TextBlock>
                                            <TextBlock Text="{Binding InterestRate, StringFormat='{}{0:F2}%'}" FontSize="14" FontWeight="SemiBold"
                                                       Foreground="{StaticResource TextPrimaryBrush}"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                                            <TextBlock FontSize="11" Foreground="{StaticResource TextTertiaryBrush}">
                                                <TextBlock.Text><Binding Source="{StaticResource Liabilities.MonthlyPaymentLabel}"/></TextBlock.Text>
                                            </TextBlock>
                                            <TextBlock FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}">
                                                <TextBlock.Text><Binding Path="MonthlyPayment" Converter="{StaticResource CurrencyConv}"/></TextBlock.Text>
                                            </TextBlock>
                                        </StackPanel>
                                    </Grid>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Add Dialog -->
                <Border Background="{StaticResource DialogOverlayBrush}" Visibility="{Binding IsAddDialogOpen, Converter={StaticResource BoolToVis}}" Panel.ZIndex="100">
                    <Border.InputBindings>
                        <KeyBinding Key="Escape" Command="{Binding CancelAddCommand}"/>
                        <KeyBinding Key="Enter" Command="{Binding ConfirmAddCommand}"/>
                    </Border.InputBindings>
                    <Border Background="{StaticResource DialogBackgroundBrush}" CornerRadius="{StaticResource DialogCornerRadius}" Padding="32" Width="480" VerticalAlignment="Center" HorizontalAlignment="Center">
                        <StackPanel>
                            <TextBlock Style="{StaticResource DialogTitleStyle}">
                                <TextBlock.Text><Binding Source="{StaticResource Liabilities.AddTitle}"/></TextBlock.Text>
                            </TextBlock>
                            <TextBlock Style="{StaticResource LabelStyle}">
                                <TextBlock.Text><Binding Source="{StaticResource Liabilities.Name}"/></TextBlock.Text>
                            </TextBlock>
                            <TextBox Text="{Binding NewName, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource InputStyle}" Margin="0,0,0,16"/>
                            <TextBlock Style="{StaticResource LabelStyle}">
                                <TextBlock.Text><Binding Source="{StaticResource Liabilities.Type}"/></TextBlock.Text>
                            </TextBlock>
                            <ComboBox ItemsSource="{Binding Source={StaticResource LiabilityTypes}}" SelectedItem="{Binding NewType}" Margin="0,0,0,16"/>
                            <TextBlock Style="{StaticResource LabelStyle}">
                                <TextBlock.Text><Binding Source="{StaticResource Liabilities.Institution}"/></TextBlock.Text>
                            </TextBlock>
                            <TextBox Text="{Binding NewInstitution, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource InputStyle}" Margin="0,0,0,16"/>
                            <Grid Margin="0,0,0,16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="16"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Style="{StaticResource LabelStyle}">
                                        <TextBlock.Text><Binding Source="{StaticResource Liabilities.Balance}"/></TextBlock.Text>
                                    </TextBlock>
                                    <TextBox Text="{Binding NewBalance, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource InputStyle}"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Style="{StaticResource LabelStyle}">
                                        <TextBlock.Text><Binding Source="{StaticResource Liabilities.InterestRate}"/></TextBlock.Text>
                                    </TextBlock>
                                    <TextBox Text="{Binding NewInterestRate, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource InputStyle}"/>
                                </StackPanel>
                            </Grid>
                            <TextBlock Style="{StaticResource LabelStyle}">
                                <TextBlock.Text><Binding Source="{StaticResource Liabilities.MonthlyPayment}"/></TextBlock.Text>
                            </TextBlock>
                            <TextBox Text="{Binding NewMonthlyPayment, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource InputStyle}" Margin="0,0,0,16"/>
                            <TextBlock Style="{StaticResource LabelStyle}">
                                <TextBlock.Text><Binding Source="{StaticResource Liabilities.StartDate}"/></TextBlock.Text>
                            </TextBlock>
                            <DatePicker SelectedDate="{Binding NewStartDate}" Margin="0,0,0,24"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <Button Style="{StaticResource SecondaryButton}" Command="{Binding CancelAddCommand}" Margin="0,0,12,0">
                                    <Button.Content><Binding Source="{StaticResource Common.Cancel}"/></Button.Content>
                                </Button>
                                <Button Style="{StaticResource PrimaryButton}" Command="{Binding ConfirmAddCommand}">
                                    <Button.Content><Binding Source="{StaticResource Common.Add}"/></Button.Content>
                                </Button>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Border>

                <!-- Delete Confirmation -->
                <Border Background="{StaticResource DialogOverlayBrush}" Visibility="{Binding IsConfirmDeleteOpen, Converter={StaticResource BoolToVis}}" Panel.ZIndex="100">
                    <Border.InputBindings>
                        <KeyBinding Key="Escape" Command="{Binding CancelDeleteCommand}"/>
                        <KeyBinding Key="Enter" Command="{Binding ExecuteDeleteCommand}"/>
                    </Border.InputBindings>
                    <Border Background="{StaticResource DialogBackgroundBrush}" CornerRadius="{StaticResource DialogCornerRadius}" Padding="32" Width="400" VerticalAlignment="Center" HorizontalAlignment="Center">
                        <StackPanel>
                            <TextBlock Style="{StaticResource DialogTitleStyle}">
                                <TextBlock.Text><Binding Source="{StaticResource Liabilities.DeleteTitle}"/></TextBlock.Text>
                            </TextBlock>
                            <TextBlock FontSize="14" Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap" Margin="0,0,0,24">
                                <TextBlock.Text><Binding Source="{StaticResource Liabilities.DeleteMessage}"/></TextBlock.Text>
                            </TextBlock>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <Button Style="{StaticResource SecondaryButton}" Command="{Binding CancelDeleteCommand}" Margin="0,0,12,0">
                                    <Button.Content><Binding Source="{StaticResource Common.Cancel}"/></Button.Content>
                                </Button>
                                <Button Style="{StaticResource DangerButton}" Command="{Binding ExecuteDeleteCommand}">
                                    <Button.Content><Binding Source="{StaticResource Common.Delete}"/></Button.Content>
                                </Button>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Border>

                <!-- Edit Dialog -->
                <Border Background="{StaticResource DialogOverlayBrush}" Visibility="{Binding IsEditDialogOpen, Converter={StaticResource BoolToVis}}" Panel.ZIndex="100">
                    <Border.InputBindings>
                        <KeyBinding Key="Escape" Command="{Binding CancelEditCommand}"/>
                        <KeyBinding Key="Enter" Command="{Binding ConfirmEditCommand}"/>
                    </Border.InputBindings>
                    <Border Background="{StaticResource DialogBackgroundBrush}" CornerRadius="{StaticResource DialogCornerRadius}" Padding="32" Width="480" VerticalAlignment="Center" HorizontalAlignment="Center">
                        <StackPanel>
                            <TextBlock Style="{StaticResource DialogTitleStyle}">
                                <TextBlock.Text><Binding Source="{StaticResource Liabilities.EditTitle}"/></TextBlock.Text>
                            </TextBlock>
                            <TextBlock Style="{StaticResource LabelStyle}">
                                <TextBlock.Text><Binding Source="{StaticResource Liabilities.Name}"/></TextBlock.Text>
                            </TextBlock>
                            <TextBox Text="{Binding NewName, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource InputStyle}" Margin="0,0,0,16"/>
                            <TextBlock Style="{StaticResource LabelStyle}">
                                <TextBlock.Text><Binding Source="{StaticResource Liabilities.Type}"/></TextBlock.Text>
                            </TextBlock>
                            <ComboBox ItemsSource="{Binding Source={StaticResource LiabilityTypes}}" SelectedItem="{Binding NewType}" Margin="0,0,0,16"/>
                            <TextBlock Style="{StaticResource LabelStyle}">
                                <TextBlock.Text><Binding Source="{StaticResource Liabilities.Institution}"/></TextBlock.Text>
                            </TextBlock>
                            <TextBox Text="{Binding NewInstitution, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource InputStyle}" Margin="0,0,0,16"/>
                            <Grid Margin="0,0,0,16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="16"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Style="{StaticResource LabelStyle}">
                                        <TextBlock.Text><Binding Source="{StaticResource Liabilities.Balance}"/></TextBlock.Text>
                                    </TextBlock>
                                    <TextBox Text="{Binding NewBalance, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource InputStyle}"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Style="{StaticResource LabelStyle}">
                                        <TextBlock.Text><Binding Source="{StaticResource Liabilities.InterestRate}"/></TextBlock.Text>
                                    </TextBlock>
                                    <TextBox Text="{Binding NewInterestRate, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource InputStyle}"/>
                                </StackPanel>
                            </Grid>
                            <TextBlock Style="{StaticResource LabelStyle}">
                                <TextBlock.Text><Binding Source="{StaticResource Liabilities.MonthlyPayment}"/></TextBlock.Text>
                            </TextBlock>
                            <TextBox Text="{Binding NewMonthlyPayment, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource InputStyle}" Margin="0,0,0,16"/>
                            <TextBlock Style="{StaticResource LabelStyle}">
                                <TextBlock.Text><Binding Source="{StaticResource Liabilities.StartDate}"/></TextBlock.Text>
                            </TextBlock>
                            <DatePicker SelectedDate="{Binding NewStartDate}" Margin="0,0,0,24"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <Button Style="{StaticResource SecondaryButton}" Command="{Binding CancelEditCommand}" Margin="0,0,12,0">
                                    <Button.Content><Binding Source="{StaticResource Common.Cancel}"/></Button.Content>
                                </Button>
                                <Button Style="{StaticResource PrimaryButton}" Command="{Binding ConfirmEditCommand}">
                                    <Button.Content><Binding Source="{StaticResource Common.Save}"/></Button.Content>
                                </Button>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
