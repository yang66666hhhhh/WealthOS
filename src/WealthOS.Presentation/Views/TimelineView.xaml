<UserControl x:Class="WealthOS.Presentation.Views.TimelineView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:WealthOS.Presentation.Converters">

    <UserControl.Resources>
        <conv:CurrencyConverter x:Key="CurrencyConv"/>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <conv:TransactionSignMultiConverter x:Key="SignConv"/>
    </UserControl.Resources>

    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="32,24">
            <StackPanel MaxWidth="1200">
                <TextBlock Style="{StaticResource PageTitleStyle}">
                    <TextBlock.Text><Binding Source="{DynamicResource Timeline.Title}"/></TextBlock.Text>
                </TextBlock>

                <ProgressBar IsIndeterminate="True" Height="3" Margin="0,0,0,16"
                             Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}"
                             Background="Transparent" Foreground="{StaticResource PrimaryBrush}"/>

                <!-- Empty State -->
                <Border Padding="60" Visibility="{Binding Days.Count, Converter={StaticResource BoolToVis}}">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Days.Count}" Value="0"><Setter Property="Visibility" Value="Visible"/></DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock FontSize="20" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Center">
                            <TextBlock.Text><Binding Source="{DynamicResource Timeline.NoData}"/></TextBlock.Text>
                        </TextBlock>
                    </StackPanel>
                </Border>

                <ItemsControl ItemsSource="{Binding Days}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Style="{StaticResource CardStyle}" Margin="0,0,0,16">
                                <StackPanel>
                                    <!-- Day Header -->
                                    <Grid Margin="0,0,0,12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding Date, StringFormat='yyyy-MM-dd dddd'}"
                                                   FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}"/>
                                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                                            <TextBlock FontSize="14" Foreground="{StaticResource IncomeBrush}" Margin="0,0,12,0">
                                                <Run Text="+"/><Run Text="{Binding TotalIncome, StringFormat='￥{0:N0}'}"/>
                                            </TextBlock>
                                            <TextBlock FontSize="14" Foreground="{StaticResource ExpenseBrush}">
                                                <Run Text="-"/><Run Text="{Binding TotalExpense, StringFormat='￥{0:N0}'}"/>
                                            </TextBlock>
                                        </StackPanel>
                                    </Grid>

                                    <!-- Transactions -->
                                    <ItemsControl ItemsSource="{Binding Transactions}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Padding="6,0" Margin="0,4,0,0">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <Ellipse Grid.Column="0" Width="8" Height="8" Margin="0,0,12,0">
                                                            <Ellipse.Style>
                                                                <Style TargetType="Ellipse">
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding Type}" Value="Income">
                                                                            <Setter Property="Fill" Value="{StaticResource IncomeBrush}"/>
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding Type}" Value="Expense">
                                                                            <Setter Property="Fill" Value="{StaticResource ExpenseBrush}"/>
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding Type}" Value="Transfer">
                                                                            <Setter Property="Fill" Value="{StaticResource TransferBrush}"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Ellipse.Style>
                                                        </Ellipse>
                                                        <StackPanel Grid.Column="1">
                                                            <TextBlock Text="{Binding Note, FallbackValue='Transaction'}"
                                                                       FontSize="14" Foreground="{StaticResource TextPrimaryBrush}"/>
                                                            <TextBlock Text="{Binding AccountName}" FontSize="12"
                                                                       Foreground="{StaticResource TextSecondaryBrush}"/>
                                                        </StackPanel>
                                                        <TextBlock Grid.Column="2" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center">
                                                            <TextBlock.Style>
                                                                <Style TargetType="TextBlock">
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding Type}" Value="Income">
                                                                            <Setter Property="Foreground" Value="{StaticResource IncomeBrush}"/>
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding Type}" Value="Expense">
                                                                            <Setter Property="Foreground" Value="{StaticResource ExpenseBrush}"/>
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding Type}" Value="Transfer">
                                                                            <Setter Property="Foreground" Value="{StaticResource TransferBrush}"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBlock.Style>
                                                            <TextBlock.Text>
                                                                <MultiBinding Converter="{StaticResource SignConv}">
                                                                    <Binding Path="Type"/>
                                                                    <Binding Path="Amount"/>
                                                                </MultiBinding>
                                                            </TextBlock.Text>
                                                        </TextBlock>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
