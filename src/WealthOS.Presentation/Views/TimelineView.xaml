<UserControl x:Class="WealthOS.Presentation.Views.TimelineView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:WealthOS.Presentation.Converters"
             xmlns:views="clr-namespace:WealthOS.Presentation.Views">

    <UserControl.Resources>
        <conv:CurrencyConverter x:Key="CurrencyConv"/>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <conv:TransactionSignMultiConverter x:Key="SignConv"/>
    </UserControl.Resources>

    <Grid>
        <Border Background="{StaticResource PrimaryBrush}" 
                Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}"
                Panel.ZIndex="50" HorizontalAlignment="Stretch" VerticalAlignment="Top" Height="3"/>

        <views:ErrorBanner DataContext="{Binding}"/>

        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="28,24">
            <StackPanel MaxWidth="1200">
                <!-- 页面标题 -->
                <Grid Margin="0,0,0,24">
                    <StackPanel>
                        <TextBlock Style="{StaticResource PageTitleStyle}">
                            <TextBlock.Text><Binding Source="{StaticResource Timeline.Title}"/></TextBlock.Text>
                        </TextBlock>
                        <TextBlock FontSize="13" Foreground="{StaticResource TextTertiaryBrush}" Margin="0,4,0,0">
                            <Run Text="&#x1F4C5; "/>
                            <Run Text="{DynamicResource Timeline.Subtitle}"/>
                        </TextBlock>
                    </StackPanel>
                </Grid>

                <!-- 空状态 -->
                <Border Padding="60">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <MultiDataTrigger>
                                    <MultiDataTrigger.Conditions>
                                        <Condition Binding="{Binding IsLoading}" Value="False"/>
                                        <Condition Binding="{Binding Days.Count}" Value="0"/>
                                    </MultiDataTrigger.Conditions>
                                    <Setter Property="Visibility" Value="Visible"/>
                                </MultiDataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Style="{StaticResource EmptyStateIconStyle}" Text="&#x1F4C5;"/>
                        <TextBlock Style="{StaticResource EmptyStateTitleStyle}">
                            <TextBlock.Text><Binding Source="{StaticResource Timeline.NoData}"/></TextBlock.Text>
                        </TextBlock>
                    </StackPanel>
                </Border>

                <!-- 时间轴列表 -->
                <ItemsControl ItemsSource="{Binding Days}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border CornerRadius="14" Padding="20" Margin="0,0,0,16"
                                    BorderThickness="1" BorderBrush="{StaticResource BorderBrush}"
                                    Background="{StaticResource CardBackgroundBrush}">
                                <StackPanel>
                                    <!-- 日期标题 -->
                                    <Grid Margin="0,0,0,16">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" Orientation="Horizontal">
                                            <Border Width="36" Height="36" CornerRadius="{StaticResource IconCornerRadius}" Margin="0,0,10,0">
                                                <Border.Background>
                                                    <SolidColorBrush Color="{StaticResource IconBgPurpleColor}"/>
                                                </Border.Background>
                                                <TextBlock Text="&#x1F4C5;" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <TextBlock Text="{Binding Date, StringFormat='yyyy-MM-dd dddd'}"
                                                       FontSize="15" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}"
                                                       VerticalAlignment="Center"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                            <Border CornerRadius="6" Padding="8,4" Margin="0,0,8,0">
                                                <Border.Background>
                                                    <SolidColorBrush Color="{StaticResource IconBgGreenColor}"/>
                                                </Border.Background>
                                                <TextBlock FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource IncomeBrush}">
                                                     <Run Text="+"/><Run><Run.Text><Binding Path="TotalIncome" Converter="{StaticResource CurrencyConv}"/></Run.Text></Run>
                                                </TextBlock>
                                            </Border>
                                            <Border CornerRadius="6" Padding="8,4">
                                                <Border.Background>
                                                    <SolidColorBrush Color="{StaticResource IconBgRedColor}"/>
                                                </Border.Background>
                                                <TextBlock FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource ExpenseBrush}">
                                                     <Run Text="-"/><Run><Run.Text><Binding Path="TotalExpense" Converter="{StaticResource CurrencyConv}"/></Run.Text></Run>
                                                </TextBlock>
                                            </Border>
                                        </StackPanel>
                                    </Grid>

                                    <!-- 交易列表 -->
                                    <ItemsControl ItemsSource="{Binding Transactions}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Padding="8,6" BorderThickness="0,0,0,1" BorderBrush="{StaticResource BorderLightBrush}">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <!-- 类型指示器 -->
                                                        <Border Grid.Column="0" Width="32" Height="32" CornerRadius="8" Margin="0,0,12,0">
                                                            <Border.Style>
                                                                <Style TargetType="Border">
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding Type}" Value="Income">
                                                                            <Setter Property="Background" Value="{StaticResource IncomeLightBrush}"/>
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding Type}" Value="Expense">
                                                                            <Setter Property="Background" Value="{StaticResource ExpenseLightBrush}"/>
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding Type}" Value="Transfer">
                                                                            <Setter Property="Background" Value="{StaticResource TransferLightBrush}"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Border.Style>
                                                            <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="12">
                                                                <TextBlock.Style>
                                                                    <Style TargetType="TextBlock">
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding Type}" Value="Income">
                                                                                <Setter Property="Text" Value="&#x2191;"/>
                                                                                <Setter Property="Foreground" Value="{StaticResource IncomeBrush}"/>
                                                                            </DataTrigger>
                                                                            <DataTrigger Binding="{Binding Type}" Value="Expense">
                                                                                <Setter Property="Text" Value="&#x2193;"/>
                                                                                <Setter Property="Foreground" Value="{StaticResource ExpenseBrush}"/>
                                                                            </DataTrigger>
                                                                            <DataTrigger Binding="{Binding Type}" Value="Transfer">
                                                                                <Setter Property="Text" Value="&#x2194;"/>
                                                                                <Setter Property="Foreground" Value="{StaticResource TransferBrush}"/>
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </TextBlock.Style>
                                                            </TextBlock>
                                                        </Border>
                                                        <!-- 交易信息 -->
                                                        <StackPanel Grid.Column="1">
                                                            <TextBlock Text="{Binding Note, FallbackValue='Transaction'}"
                                                                       FontSize="13" FontWeight="Medium" Foreground="{StaticResource TextPrimaryBrush}"/>
                                                            <TextBlock FontSize="11" Foreground="{StaticResource TextTertiaryBrush}">
                                                                <TextBlock.Style>
                                                                    <Style TargetType="TextBlock">
                                                                        <Setter Property="Text" Value="{Binding AccountName}"/>
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding Type}" Value="Transfer">
                                                                                <Setter Property="Text">
                                                                                    <Setter.Value>
                                                                                        <MultiBinding StringFormat="{}{0} → {1}">
                                                                                            <Binding Path="AccountName"/>
                                                                                            <Binding Path="ToAccountName"/>
                                                                                        </MultiBinding>
                                                                                    </Setter.Value>
                                                                                </Setter>
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </TextBlock.Style>
                                                            </TextBlock>
                                                        </StackPanel>
                                                        <!-- 金额 -->
                                                        <TextBlock Grid.Column="2" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center">
                                                            <TextBlock.Style>
                                                                <Style TargetType="TextBlock">
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding Type}" Value="Income">
                                                                            <Setter Property="Foreground" Value="{StaticResource IncomeBrush}"/>
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding Type}" Value="Expense">
                                                                            <Setter Property="Foreground" Value="{StaticResource ExpenseBrush}"/>
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding Type}" Value="Transfer">
                                                                            <Setter Property="Foreground" Value="{StaticResource TransferBrush}"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBlock.Style>
                                                            <TextBlock.Text>
                                                                <MultiBinding Converter="{StaticResource SignConv}">
                                                                    <Binding Path="Type"/>
                                                                    <Binding Path="Amount"/>
                                                                </MultiBinding>
                                                            </TextBlock.Text>
                                                        </TextBlock>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <Border Height="20"/>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
