<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ============================================ -->
    <!--  深色主题色彩系统 - 柔和深邃 -->
    <!-- ============================================ -->
    
    <!-- 主色调 -->
    <Color x:Key="PrimaryColor">#60A5FA</Color>
    <Color x:Key="PrimaryLightColor">#1E3A5F</Color>
    <Color x:Key="PrimaryDarkColor">#93C5FD</Color>
    <Color x:Key="PrimaryMutedColor">#1E40AF</Color>
    
    <!-- 强调色 -->
    <Color x:Key="AccentColor">#34D399</Color>
    <Color x:Key="AccentLightColor">#064E3B</Color>
    
    <!-- 中性色 -->
    <Color x:Key="BackgroundColor">#0F172A</Color>
    <Color x:Key="CardBackgroundColor">#1E293B</Color>
    <Color x:Key="SurfaceColor">#1E293B</Color>
    <Color x:Key="SurfaceHoverColor">#334155</Color>
    
    <!-- 文字色 -->
    <Color x:Key="TextPrimaryColor">#F1F5F9</Color>
    <Color x:Key="TextSecondaryColor">#94A3B8</Color>
    <Color x:Key="TextTertiaryColor">#64748B</Color>
    <Color x:Key="TextHintColor">#475569</Color>
    
    <!-- 边框色 -->
    <Color x:Key="BorderColor">#334155</Color>
    <Color x:Key="BorderLightColor">#1E293B</Color>
    <Color x:Key="FocusBorderColor">#60A5FA</Color>
    
    <!-- 功能色 -->
    <Color x:Key="IncomeColor">#34D399</Color>
    <Color x:Key="IncomeLightColor">#064E3B</Color>
    <Color x:Key="ExpenseColor">#F87171</Color>
    <Color x:Key="ExpenseLightColor">#7F1D1D</Color>
    <Color x:Key="TransferColor">#818CF8</Color>
    <Color x:Key="TransferLightColor">#312E81</Color>
    
    <!-- 侧边栏 - 深色但不压抑 -->
    <Color x:Key="SidebarColor">#1E293B</Color>
    <Color x:Key="SidebarHoverColor">#334155</Color>
    <Color x:Key="SidebarActiveColor">#3B82F6</Color>
    <Color x:Key="SidebarTextColor">#94A3B8</Color>
    <Color x:Key="SidebarActiveTextColor">#FFFFFF</Color>
    
    <!-- 对话框 -->
    <Color x:Key="DialogOverlayColor">#80000000</Color>
    <Color x:Key="DialogBackgroundColor">#1E293B</Color>
    
    <!-- 状态色 -->
    <Color x:Key="SuccessColor">#34D399</Color>
    <Color x:Key="WarningColor">#FBBF24</Color>
    <Color x:Key="ErrorColor">#F87171</Color>
    <Color x:Key="InfoColor">#60A5FA</Color>

    <!-- ============================================ -->
    <!--  画刷资源 -->
    <!-- ============================================ -->
    
    <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource PrimaryColor}"/>
    <SolidColorBrush x:Key="PrimaryLightBrush" Color="{StaticResource PrimaryLightColor}"/>
    <SolidColorBrush x:Key="PrimaryDarkBrush" Color="{StaticResource PrimaryDarkColor}"/>
    <SolidColorBrush x:Key="PrimaryMutedBrush" Color="{StaticResource PrimaryMutedColor}"/>
    
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}"/>
    <SolidColorBrush x:Key="AccentLightBrush" Color="{StaticResource AccentLightColor}"/>
    
    <SolidColorBrush x:Key="BackgroundBrush" Color="{StaticResource BackgroundColor}"/>
    <SolidColorBrush x:Key="CardBackgroundBrush" Color="{StaticResource CardBackgroundColor}"/>
    <SolidColorBrush x:Key="SurfaceBrush" Color="{StaticResource SurfaceColor}"/>
    <SolidColorBrush x:Key="SurfaceHoverBrush" Color="{StaticResource SurfaceHoverColor}"/>
    
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimaryColor}"/>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondaryColor}"/>
    <SolidColorBrush x:Key="TextTertiaryBrush" Color="{StaticResource TextTertiaryColor}"/>
    <SolidColorBrush x:Key="TextHintBrush" Color="{StaticResource TextHintColor}"/>
    
    <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource BorderColor}"/>
    <SolidColorBrush x:Key="BorderLightBrush" Color="{StaticResource BorderLightColor}"/>
    <SolidColorBrush x:Key="FocusBorderBrush" Color="{StaticResource FocusBorderColor}"/>
    
    <SolidColorBrush x:Key="IncomeBrush" Color="{StaticResource IncomeColor}"/>
    <SolidColorBrush x:Key="IncomeLightBrush" Color="{StaticResource IncomeLightColor}"/>
    <SolidColorBrush x:Key="ExpenseBrush" Color="{StaticResource ExpenseColor}"/>
    <SolidColorBrush x:Key="ExpenseLightBrush" Color="{StaticResource ExpenseLightColor}"/>
    <SolidColorBrush x:Key="TransferBrush" Color="{StaticResource TransferColor}"/>
    <SolidColorBrush x:Key="TransferLightBrush" Color="{StaticResource TransferLightColor}"/>
    
    <SolidColorBrush x:Key="SidebarBrush" Color="{StaticResource SidebarColor}"/>
    <SolidColorBrush x:Key="SidebarHoverBrush" Color="{StaticResource SidebarHoverColor}"/>
    <SolidColorBrush x:Key="SidebarActiveBrush" Color="{StaticResource SidebarActiveColor}"/>
    <SolidColorBrush x:Key="SidebarTextBrush" Color="{StaticResource SidebarTextColor}"/>
    <SolidColorBrush x:Key="SidebarActiveTextBrush" Color="{StaticResource SidebarActiveTextColor}"/>
    
    <SolidColorBrush x:Key="DialogOverlayBrush" Color="{StaticResource DialogOverlayColor}"/>
    <SolidColorBrush x:Key="DialogBackgroundBrush" Color="{StaticResource DialogBackgroundColor}"/>
    
    <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource SuccessColor}"/>
    <SolidColorBrush x:Key="WarningBrush" Color="{StaticResource WarningColor}"/>
    <SolidColorBrush x:Key="ErrorBrush" Color="{StaticResource ErrorColor}"/>
    <SolidColorBrush x:Key="InfoBrush" Color="{StaticResource InfoColor}"/>

    <!-- ============================================ -->
    <!--  引入公共样式（必须在画刷之后） -->
    <!-- ============================================ -->
    
    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="pack://application:,,,/WealthOS.Presentation;component/Resources/CommonStyles.xaml"/>
    </ResourceDictionary.MergedDictionaries>

</ResourceDictionary>
