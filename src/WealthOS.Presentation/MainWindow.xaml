<Window x:Class="WealthOS.Presentation.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:WealthOS.Presentation.ViewModels"
        xmlns:views="clr-namespace:WealthOS.Presentation.Views"
        mc:Ignorable="d"
        Title="WealthOS - Personal Wealth Operating System"
        Height="900" Width="1400"
        MinHeight="700" MinWidth="1100"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BackgroundBrush}">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/Theme.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="240"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <Border Grid.Column="0" Background="{StaticResource SidebarBrush}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Logo -->
                <StackPanel Grid.Row="0" Margin="24,28,24,32">
                    <TextBlock Text="WealthOS" FontSize="22" FontWeight="Bold"
                               Foreground="White" Margin="0,0,0,4"/>
                    <TextBlock Text="Personal Wealth Operating System"
                               FontSize="11" Foreground="{StaticResource SidebarTextBrush}"/>
                </StackPanel>

                <!-- Navigation -->
                <StackPanel Grid.Row="1">
                    <Button Command="{Binding NavigateToCommand}" CommandParameter="Dashboard"
                            Background="Transparent" BorderThickness="0" Cursor="Hand"
                            HorizontalContentAlignment="Left" Padding="0">
                        <Border CornerRadius="10" Padding="20,12" Margin="8,2">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsDashboardSelected}" Value="True">
                                            <Setter Property="Background" Value="{StaticResource SidebarActiveBrush}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <TextBlock Text="&#x1F3E0;  Dashboard" FontSize="14">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="{StaticResource SidebarTextBrush}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsDashboardSelected}" Value="True">
                                                <Setter Property="Foreground" Value="{StaticResource SidebarActiveTextBrush}"/>
                                                <Setter Property="FontWeight" Value="SemiBold"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Border>
                    </Button>
                    <Button Command="{Binding NavigateToCommand}" CommandParameter="Assets"
                            Background="Transparent" BorderThickness="0" Cursor="Hand"
                            HorizontalContentAlignment="Left" Padding="0">
                        <Border CornerRadius="10" Padding="20,12" Margin="8,2">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsAssetsSelected}" Value="True">
                                            <Setter Property="Background" Value="{StaticResource SidebarActiveBrush}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <TextBlock Text="&#x1F4B0;  Assets" FontSize="14">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="{StaticResource SidebarTextBrush}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsAssetsSelected}" Value="True">
                                                <Setter Property="Foreground" Value="{StaticResource SidebarActiveTextBrush}"/>
                                                <Setter Property="FontWeight" Value="SemiBold"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Border>
                    </Button>
                    <Button Command="{Binding NavigateToCommand}" CommandParameter="Liabilities"
                            Background="Transparent" BorderThickness="0" Cursor="Hand"
                            HorizontalContentAlignment="Left" Padding="0">
                        <Border CornerRadius="10" Padding="20,12" Margin="8,2">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsLiabilitiesSelected}" Value="True">
                                            <Setter Property="Background" Value="{StaticResource SidebarActiveBrush}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <TextBlock Text="&#x1F4C9;  Liabilities" FontSize="14">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="{StaticResource SidebarTextBrush}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsLiabilitiesSelected}" Value="True">
                                                <Setter Property="Foreground" Value="{StaticResource SidebarActiveTextBrush}"/>
                                                <Setter Property="FontWeight" Value="SemiBold"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Border>
                    </Button>
                    <Button Command="{Binding NavigateToCommand}" CommandParameter="Transactions"
                            Background="Transparent" BorderThickness="0" Cursor="Hand"
                            HorizontalContentAlignment="Left" Padding="0">
                        <Border CornerRadius="10" Padding="20,12" Margin="8,2">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsTransactionsSelected}" Value="True">
                                            <Setter Property="Background" Value="{StaticResource SidebarActiveBrush}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <TextBlock Text="&#x1F4CA;  Transactions" FontSize="14">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="{StaticResource SidebarTextBrush}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsTransactionsSelected}" Value="True">
                                                <Setter Property="Foreground" Value="{StaticResource SidebarActiveTextBrush}"/>
                                                <Setter Property="FontWeight" Value="SemiBold"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Border>
                    </Button>
                    <Button Command="{Binding NavigateToCommand}" CommandParameter="Goals"
                            Background="Transparent" BorderThickness="0" Cursor="Hand"
                            HorizontalContentAlignment="Left" Padding="0">
                        <Border CornerRadius="10" Padding="20,12" Margin="8,2">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsGoalsSelected}" Value="True">
                                            <Setter Property="Background" Value="{StaticResource SidebarActiveBrush}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <TextBlock Text="&#x1F3AF;  Goals" FontSize="14">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="{StaticResource SidebarTextBrush}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsGoalsSelected}" Value="True">
                                                <Setter Property="Foreground" Value="{StaticResource SidebarActiveTextBrush}"/>
                                                <Setter Property="FontWeight" Value="SemiBold"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Border>
                    </Button>
                </StackPanel>

                <!-- Footer -->
                <StackPanel Grid.Row="2" Margin="24,0,24,24">
                    <Border Background="{StaticResource SidebarActiveBrush}" CornerRadius="12" Padding="16,12">
                        <TextBlock Text="v1.1.0" FontSize="11"
                                   Foreground="{StaticResource SidebarTextBrush}"/>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main Content -->
        <ContentControl Grid.Column="1"
                        Content="{Binding Navigation.CurrentViewModel}">
            <ContentControl.Resources>
                <DataTemplate DataType="{x:Type vm:DashboardViewModel}">
                    <views:DashboardView/>
                </DataTemplate>
                <DataTemplate DataType="{x:Type vm:AssetsViewModel}">
                    <views:AssetsView/>
                </DataTemplate>
                <DataTemplate DataType="{x:Type vm:LiabilitiesViewModel}">
                    <views:LiabilitiesView/>
                </DataTemplate>
                <DataTemplate DataType="{x:Type vm:TransactionsViewModel}">
                    <views:TransactionsView/>
                </DataTemplate>
                <DataTemplate DataType="{x:Type vm:GoalsViewModel}">
                    <views:GoalsView/>
                </DataTemplate>
            </ContentControl.Resources>
        </ContentControl>
    </Grid>
</Window>
