<Window x:Class="WealthOS.Presentation.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:WealthOS.Presentation.ViewModels"
        xmlns:views="clr-namespace:WealthOS.Presentation.Views"
        mc:Ignorable="d"
        Title="{DynamicResource App.Title}"
        Height="900" Width="1400"
        MinHeight="700" MinWidth="1100"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BackgroundBrush}">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/WealthOS.Presentation;component/Resources/Theme.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- 侧边栏 -->
        <Border Grid.Column="0" Background="{StaticResource SidebarBrush}" 
                BorderThickness="0,0,1,0" BorderBrush="{StaticResource BorderBrush}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Logo 区域 -->
                <StackPanel Grid.Row="0" Margin="20,24,20,28">
                    <StackPanel Orientation="Horizontal">
                        <Border Width="36" Height="36" CornerRadius="10" 
                                Background="{StaticResource PrimaryBrush}" Margin="0,0,10,0">
                            <TextBlock Text="W" FontSize="18" FontWeight="Bold" Foreground="White"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="WealthOS" FontSize="16" FontWeight="Bold"
                                       Foreground="{StaticResource TextPrimaryBrush}"/>
                            <TextBlock Text="v1.1.0" FontSize="10" 
                                       Foreground="{StaticResource TextTertiaryBrush}"/>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>

                <!-- 导航按钮 -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <!-- 主要导航 -->
                        <TextBlock Text="{DynamicResource Nav.MainSection}" FontSize="11" FontWeight="Medium"
                                   Foreground="{StaticResource TextTertiaryBrush}" Margin="20,0,20,8"/>
                        
                        <Button Command="{Binding NavigateToCommand}" CommandParameter="Dashboard"
                                Style="{StaticResource NavItemStyle}" HorizontalContentAlignment="Left">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#x1F3E0;" FontSize="14" Margin="0,0,10,0"/>
                                <TextBlock Text="{DynamicResource Nav.Dashboard}">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="{StaticResource SidebarTextBrush}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsDashboardSelected}" Value="True">
                                                    <Setter Property="Foreground" Value="{StaticResource SidebarActiveTextBrush}"/>
                                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>
                            
                        </Button>

                        <Button Command="{Binding NavigateToCommand}" CommandParameter="Assets"
                                Style="{StaticResource NavItemStyle}" HorizontalContentAlignment="Left">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#x1F4B0;" FontSize="14" Margin="0,0,10,0"/>
                                <TextBlock Text="{DynamicResource Nav.Assets}">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="{StaticResource SidebarTextBrush}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsAssetsSelected}" Value="True">
                                                    <Setter Property="Foreground" Value="{StaticResource SidebarActiveTextBrush}"/>
                                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>
                            
                        </Button>

                        <Button Command="{Binding NavigateToCommand}" CommandParameter="Liabilities"
                                Style="{StaticResource NavItemStyle}" HorizontalContentAlignment="Left">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#x1F4C9;" FontSize="14" Margin="0,0,10,0"/>
                                <TextBlock Text="{DynamicResource Nav.Liabilities}">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="{StaticResource SidebarTextBrush}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsLiabilitiesSelected}" Value="True">
                                                    <Setter Property="Foreground" Value="{StaticResource SidebarActiveTextBrush}"/>
                                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>
                            
                        </Button>

                        <Button Command="{Binding NavigateToCommand}" CommandParameter="Transactions"
                                Style="{StaticResource NavItemStyle}" HorizontalContentAlignment="Left">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#x1F4CA;" FontSize="14" Margin="0,0,10,0"/>
                                <TextBlock Text="{DynamicResource Nav.Transactions}">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="{StaticResource SidebarTextBrush}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsTransactionsSelected}" Value="True">
                                                    <Setter Property="Foreground" Value="{StaticResource SidebarActiveTextBrush}"/>
                                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>
                            
                        </Button>

                        <Button Command="{Binding NavigateToCommand}" CommandParameter="Goals"
                                Style="{StaticResource NavItemStyle}" HorizontalContentAlignment="Left">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#x1F3AF;" FontSize="14" Margin="0,0,10,0"/>
                                <TextBlock Text="{DynamicResource Nav.Goals}">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="{StaticResource SidebarTextBrush}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsGoalsSelected}" Value="True">
                                                    <Setter Property="Foreground" Value="{StaticResource SidebarActiveTextBrush}"/>
                                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>
                            
                        </Button>

                        <Button Command="{Binding NavigateToCommand}" CommandParameter="Budgets"
                                Style="{StaticResource NavItemStyle}" HorizontalContentAlignment="Left">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#x1F4B0;" FontSize="14" Margin="0,0,10,0"/>
                                <TextBlock Text="{DynamicResource Nav.Budgets}">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="{StaticResource SidebarTextBrush}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsBudgetsSelected}" Value="True">
                                                    <Setter Property="Foreground" Value="{StaticResource SidebarActiveTextBrush}"/>
                                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>
                            
                        </Button>

                        <!-- 更多导航 -->
                        <TextBlock Text="{DynamicResource Nav.MoreSection}" FontSize="11" FontWeight="Medium"
                                   Foreground="{StaticResource TextTertiaryBrush}" Margin="20,16,20,8"/>

                        <Button Command="{Binding NavigateToCommand}" CommandParameter="Accounts"
                                Style="{StaticResource NavItemStyle}" HorizontalContentAlignment="Left">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#x1F3E6;" FontSize="14" Margin="0,0,10,0"/>
                                <TextBlock Text="{DynamicResource Nav.Accounts}">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="{StaticResource SidebarTextBrush}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsAccountsSelected}" Value="True">
                                                    <Setter Property="Foreground" Value="{StaticResource SidebarActiveTextBrush}"/>
                                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>
                            
                        </Button>

                        <Button Command="{Binding NavigateToCommand}" CommandParameter="Investments"
                                Style="{StaticResource NavItemStyle}" HorizontalContentAlignment="Left">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#x1F4C8;" FontSize="14" Margin="0,0,10,0"/>
                                <TextBlock Text="{DynamicResource Nav.Investments}">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="{StaticResource SidebarTextBrush}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsInvestmentsSelected}" Value="True">
                                                    <Setter Property="Foreground" Value="{StaticResource SidebarActiveTextBrush}"/>
                                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>
                            
                        </Button>

                        <Button Command="{Binding NavigateToCommand}" CommandParameter="FixedAssets"
                                Style="{StaticResource NavItemStyle}" HorizontalContentAlignment="Left">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#x1F3E2;" FontSize="14" Margin="0,0,10,0"/>
                                <TextBlock Text="{DynamicResource Nav.FixedAssets}">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="{StaticResource SidebarTextBrush}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsFixedAssetsSelected}" Value="True">
                                                    <Setter Property="Foreground" Value="{StaticResource SidebarActiveTextBrush}"/>
                                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>
                            
                        </Button>

                        <Button Command="{Binding NavigateToCommand}" CommandParameter="Analytics"
                                Style="{StaticResource NavItemStyle}" HorizontalContentAlignment="Left">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#x1F4CA;" FontSize="14" Margin="0,0,10,0"/>
                                <TextBlock Text="{DynamicResource Nav.Analytics}">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="{StaticResource SidebarTextBrush}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsAnalyticsSelected}" Value="True">
                                                    <Setter Property="Foreground" Value="{StaticResource SidebarActiveTextBrush}"/>
                                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>
                            
                        </Button>

                        <Button Command="{Binding NavigateToCommand}" CommandParameter="Timeline"
                                Style="{StaticResource NavItemStyle}" HorizontalContentAlignment="Left">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#x1F4C5;" FontSize="14" Margin="0,0,10,0"/>
                                <TextBlock Text="{DynamicResource Nav.Timeline}">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="{StaticResource SidebarTextBrush}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsTimelineSelected}" Value="True">
                                                    <Setter Property="Foreground" Value="{StaticResource SidebarActiveTextBrush}"/>
                                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>
                            
                        </Button>

                        <Button Command="{Binding NavigateToCommand}" CommandParameter="Reports"
                                Style="{StaticResource NavItemStyle}" HorizontalContentAlignment="Left">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#x1F4CB;" FontSize="14" Margin="0,0,10,0"/>
                                <TextBlock Text="{DynamicResource Nav.Reports}">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="{StaticResource SidebarTextBrush}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsReportsSelected}" Value="True">
                                                    <Setter Property="Foreground" Value="{StaticResource SidebarActiveTextBrush}"/>
                                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>
                            
                        </Button>
                    </StackPanel>
                </ScrollViewer>

                <!-- 底部设置和语言切换 -->
                <StackPanel Grid.Row="2" Margin="12,0,12,16">
                    <Border Height="1" Background="{StaticResource BorderBrush}" Margin="8,0,8,12"/>
                    
                    <Button Command="{Binding NavigateToCommand}" CommandParameter="Settings"
                            Style="{StaticResource NavItemStyle}" HorizontalContentAlignment="Left">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#x2699;" FontSize="14" Margin="0,0,10,0"/>
                            <TextBlock Text="{DynamicResource Nav.Settings}">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="{StaticResource SidebarTextBrush}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsSettingsSelected}" Value="True">
                                                <Setter Property="Foreground" Value="{StaticResource SidebarActiveTextBrush}"/>
                                                <Setter Property="FontWeight" Value="SemiBold"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                        
                    </Button>

                    <!-- 语言切换 -->
                    <Button Command="{Binding ToggleLanguageCommand}" 
                            Style="{StaticResource NavItemStyle}" HorizontalContentAlignment="Left">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#x1F310;" FontSize="14" Margin="0,0,10,0"/>
                            <TextBlock Text="{DynamicResource Lang.Current}" FontSize="12"/>
                            <TextBlock Text=" / " FontSize="12" Foreground="{StaticResource TextHintBrush}" Margin="4,0"/>
                            <TextBlock Text="{DynamicResource Lang.Switch}" FontSize="12" 
                                       Foreground="{StaticResource PrimaryBrush}"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- 主内容区域 -->
        <ContentControl Grid.Column="1"
                        Content="{Binding Navigation.CurrentViewModel}">
            <ContentControl.Resources>
                <DataTemplate DataType="{x:Type vm:DashboardViewModel}">
                    <views:DashboardView/>
                </DataTemplate>
                <DataTemplate DataType="{x:Type vm:AssetsViewModel}">
                    <views:AssetsView/>
                </DataTemplate>
                <DataTemplate DataType="{x:Type vm:LiabilitiesViewModel}">
                    <views:LiabilitiesView/>
                </DataTemplate>
                <DataTemplate DataType="{x:Type vm:TransactionsViewModel}">
                    <views:TransactionsView/>
                </DataTemplate>
                <DataTemplate DataType="{x:Type vm:GoalsViewModel}">
                    <views:GoalsView/>
                </DataTemplate>
                <DataTemplate DataType="{x:Type vm:AccountsViewModel}">
                    <views:AccountsView/>
                </DataTemplate>
                <DataTemplate DataType="{x:Type vm:InvestmentsViewModel}">
                    <views:InvestmentsView/>
                </DataTemplate>
                <DataTemplate DataType="{x:Type vm:FixedAssetsViewModel}">
                    <views:FixedAssetsView/>
                </DataTemplate>
                <DataTemplate DataType="{x:Type vm:AnalyticsViewModel}">
                    <views:AnalyticsView/>
                </DataTemplate>
                <DataTemplate DataType="{x:Type vm:TimelineViewModel}">
                    <views:TimelineView/>
                </DataTemplate>
                <DataTemplate DataType="{x:Type vm:ReportsViewModel}">
                    <views:ReportsView/>
                </DataTemplate>
                <DataTemplate DataType="{x:Type vm:SettingsViewModel}">
                    <views:SettingsView/>
                </DataTemplate>
                <DataTemplate DataType="{x:Type vm:BudgetsViewModel}">
                    <views:BudgetsView/>
                </DataTemplate>
            </ContentControl.Resources>
        </ContentControl>
    </Grid>
</Window>
