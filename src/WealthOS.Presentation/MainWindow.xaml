<Window x:Class="WealthOS.Presentation.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:WealthOS.Presentation.ViewModels"
        xmlns:views="clr-namespace:WealthOS.Presentation.Views"
        mc:Ignorable="d"
        Title="{DynamicResource App.Title}"
        Height="900" Width="1400"
        MinHeight="700" MinWidth="1100"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BackgroundBrush}">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/WealthOS.Presentation;component/Resources/Theme.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- 侧边栏 -->
        <Border Grid.Column="0" Background="{StaticResource SidebarBrush}" 
                BorderThickness="0,0,1,0" BorderBrush="{StaticResource BorderBrush}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Logo 区域 -->
                <StackPanel Grid.Row="0" Margin="20,24,20,28">
                    <StackPanel Orientation="Horizontal">
                        <Border Width="36" Height="36" CornerRadius="10" 
                                Background="{StaticResource PrimaryBrush}" Margin="0,0,10,0">
                            <TextBlock Text="W" FontSize="18" FontWeight="Bold" Foreground="White"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="WealthOS" FontSize="16" FontWeight="Bold"
                                       Foreground="{StaticResource TextPrimaryBrush}"/>
                            <TextBlock Text="v1.1.0" FontSize="10" 
                                       Foreground="{StaticResource TextTertiaryBrush}"/>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>

                <!-- 导航按钮 -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <!-- 主要导航 -->
                        <TextBlock Text="{DynamicResource Nav.MainSection}" FontSize="11" FontWeight="Medium"
                                   Foreground="{StaticResource TextTertiaryBrush}" Margin="20,0,20,8"/>

                        <views:NavigationItem Icon="&#x1F3E0;" 
                                              Label="{DynamicResource Nav.Dashboard}"
                                              IsSelected="{Binding IsDashboardSelected}"
                                              Command="{Binding NavigateToCommand}" 
                                              CommandParameter="Dashboard"/>

                        <views:NavigationItem Icon="&#x1F4B0;" 
                                              Label="{DynamicResource Nav.Assets}"
                                              IsSelected="{Binding IsAssetsSelected}"
                                              Command="{Binding NavigateToCommand}" 
                                              CommandParameter="Assets"/>

                        <views:NavigationItem Icon="&#x1F4C9;" 
                                              Label="{DynamicResource Nav.Liabilities}"
                                              IsSelected="{Binding IsLiabilitiesSelected}"
                                              Command="{Binding NavigateToCommand}" 
                                              CommandParameter="Liabilities"/>

                        <views:NavigationItem Icon="&#x1F4CA;" 
                                              Label="{DynamicResource Nav.Transactions}"
                                              IsSelected="{Binding IsTransactionsSelected}"
                                              Command="{Binding NavigateToCommand}" 
                                              CommandParameter="Transactions"/>

                        <views:NavigationItem Icon="&#x1F3AF;" 
                                              Label="{DynamicResource Nav.Goals}"
                                              IsSelected="{Binding IsGoalsSelected}"
                                              Command="{Binding NavigateToCommand}" 
                                              CommandParameter="Goals"/>

                        <views:NavigationItem Icon="&#x1F4B0;" 
                                              Label="{DynamicResource Nav.Budgets}"
                                              IsSelected="{Binding IsBudgetsSelected}"
                                              Command="{Binding NavigateToCommand}" 
                                              CommandParameter="Budgets"/>

                        <!-- 更多导航 -->
                        <TextBlock Text="{DynamicResource Nav.MoreSection}" FontSize="11" FontWeight="Medium"
                                   Foreground="{StaticResource TextTertiaryBrush}" Margin="20,16,20,8"/>

                        <views:NavigationItem Icon="&#x1F3E6;" 
                                              Label="{DynamicResource Nav.Accounts}"
                                              IsSelected="{Binding IsAccountsSelected}"
                                              Command="{Binding NavigateToCommand}" 
                                              CommandParameter="Accounts"/>

                        <views:NavigationItem Icon="&#x1F4C8;" 
                                              Label="{DynamicResource Nav.Investments}"
                                              IsSelected="{Binding IsInvestmentsSelected}"
                                              Command="{Binding NavigateToCommand}" 
                                              CommandParameter="Investments"/>

                        <views:NavigationItem Icon="&#x1F3E2;" 
                                              Label="{DynamicResource Nav.FixedAssets}"
                                              IsSelected="{Binding IsFixedAssetsSelected}"
                                              Command="{Binding NavigateToCommand}" 
                                              CommandParameter="FixedAssets"/>

                        <views:NavigationItem Icon="&#x1F4CA;" 
                                              Label="{DynamicResource Nav.Analytics}"
                                              IsSelected="{Binding IsAnalyticsSelected}"
                                              Command="{Binding NavigateToCommand}" 
                                              CommandParameter="Analytics"/>

                        <views:NavigationItem Icon="&#x1F4C5;" 
                                              Label="{DynamicResource Nav.Timeline}"
                                              IsSelected="{Binding IsTimelineSelected}"
                                              Command="{Binding NavigateToCommand}" 
                                              CommandParameter="Timeline"/>

                        <views:NavigationItem Icon="&#x1F4CB;" 
                                              Label="{DynamicResource Nav.Reports}"
                                              IsSelected="{Binding IsReportsSelected}"
                                              Command="{Binding NavigateToCommand}" 
                                              CommandParameter="Reports"/>
                    </StackPanel>
                </ScrollViewer>

                <!-- 底部设置和语言切换 -->
                <StackPanel Grid.Row="2" Margin="12,0,12,16">
                    <Border Height="1" Background="{StaticResource BorderBrush}" Margin="8,0,8,12"/>

                    <views:NavigationItem Icon="&#x2699;" 
                                          Label="{DynamicResource Nav.Settings}"
                                          IsSelected="{Binding IsSettingsSelected}"
                                          Command="{Binding NavigateToCommand}" 
                                          CommandParameter="Settings"/>

                    <!-- 语言切换 -->
                    <Button Command="{Binding ToggleLanguageCommand}" 
                            Style="{StaticResource NavItemStyle}" HorizontalContentAlignment="Left">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#x1F310;" FontSize="14" Margin="0,0,10,0"/>
                            <TextBlock Text="{DynamicResource Lang.Current}" FontSize="12"/>
                            <TextBlock Text=" / " FontSize="12" Foreground="{StaticResource TextHintBrush}" Margin="4,0"/>
                            <TextBlock Text="{DynamicResource Lang.Switch}" FontSize="12" 
                                       Foreground="{StaticResource PrimaryBrush}"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- 主内容区域 -->
        <ContentControl Grid.Column="1"
                        Content="{Binding Navigation.CurrentViewModel}">
            <ContentControl.Resources>
                <DataTemplate DataType="{x:Type vm:DashboardViewModel}">
                    <views:DashboardView/>
                </DataTemplate>
                <DataTemplate DataType="{x:Type vm:AssetsViewModel}">
                    <views:AssetsView/>
                </DataTemplate>
                <DataTemplate DataType="{x:Type vm:LiabilitiesViewModel}">
                    <views:LiabilitiesView/>
                </DataTemplate>
                <DataTemplate DataType="{x:Type vm:TransactionsViewModel}">
                    <views:TransactionsView/>
                </DataTemplate>
                <DataTemplate DataType="{x:Type vm:GoalsViewModel}">
                    <views:GoalsView/>
                </DataTemplate>
                <DataTemplate DataType="{x:Type vm:AccountsViewModel}">
                    <views:AccountsView/>
                </DataTemplate>
                <DataTemplate DataType="{x:Type vm:InvestmentsViewModel}">
                    <views:InvestmentsView/>
                </DataTemplate>
                <DataTemplate DataType="{x:Type vm:FixedAssetsViewModel}">
                    <views:FixedAssetsView/>
                </DataTemplate>
                <DataTemplate DataType="{x:Type vm:AnalyticsViewModel}">
                    <views:AnalyticsView/>
                </DataTemplate>
                <DataTemplate DataType="{x:Type vm:TimelineViewModel}">
                    <views:TimelineView/>
                </DataTemplate>
                <DataTemplate DataType="{x:Type vm:ReportsViewModel}">
                    <views:ReportsView/>
                </DataTemplate>
                <DataTemplate DataType="{x:Type vm:SettingsViewModel}">
                    <views:SettingsView/>
                </DataTemplate>
                <DataTemplate DataType="{x:Type vm:BudgetsViewModel}">
                    <views:BudgetsView/>
                </DataTemplate>
            </ContentControl.Resources>
        </ContentControl>
    </Grid>
</Window>
